From 1168e7ca34973c1276b88d95e8d489021f20576f Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Thu, 30 Apr 2026 22:47:49 -0700
Subject: [PATCH] Try installing the out-of-tree module the same way the Nvidia drivers are installed

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/elements/gnomeos-deps/apple-macbook12-drivers-modules.bst b/elements/gnomeos-deps/apple-macbook12-drivers-modules.bst
new file mode 100644
index 0000000000000000000000000000000000000000..7abfeee99c75a859bb282d7642b4c253927cf759
--- /dev/null
+++ b/elements/gnomeos-deps/apple-macbook12-drivers-modules.bst
@@ -0,0 +1,9 @@
+kind: filter
+
+build-depends:
+- gnomeos-deps/apple-macbook12-drivers.bst
+
+config:
+  include:
+  - modules
+  include-orphans: false
diff --git a/elements/gnomeos-deps/apple-macbook12-drivers.bst b/elements/gnomeos-deps/apple-macbook12-drivers.bst
new file mode 100644
index 0000000000000000000000000000000000000000..782785e6774431859135d6b9217bd9f04110ef9f
--- /dev/null
+++ b/elements/gnomeos-deps/apple-macbook12-drivers.bst
@@ -0,0 +1,78 @@
+kind: manual
+
+sources:
+- kind: tar
+  url: kernel_org:v7.x/linux-7.0.1.tar.xz
+  ref: b2c935a36d24980e11e59bed3ca558ea6d67619ec0065faa335cdc0b64d887bf
+  base-dir: linux-7.0.1
+  directory: linux-src
+- kind: tar
+  url: github_files:juicecultus/macbook12-audio-driver/archive/75884e2b685c8c4ca249f66e23b921d8f69a98f9.tar.gz
+  ref: 441fb51589b365d9d75ce18851e6beb53443df678d1d4fbdc072d99fd56d4e57
+  base-dir: macbook12-audio-driver-75884e2b685c8c4ca249f66e23b921d8f69a98f9
+  directory: macbook12-audio-driver
+- kind: local
+  path: files/apple-macbook12-config/modprobe.conf
+  directory: local-config
+- kind: local
+  path: files/apple-macbook12-config/modules-load.conf
+  directory: local-config
+
+build-depends:
+- freedesktop-sdk.bst:public-stacks/buildsystem-make.bst
+- filename: freedesktop-sdk.bst:components/linux.bst
+  strict: true
+
+variables:
+  strip-binaries: ''
+
+environment-nocache:
+- MAKEFLAGS
+
+environment:
+  MAKEFLAGS: -j%{max-jobs}
+
+config:
+  build-commands:
+  # Stage patched cs420x sources from the audio-driver repo into the kernel
+  # source tree, then build snd-hda-codec-cs420x out-of-tree against the
+  # installed kernel build directory.
+  - |
+    cd macbook12-audio-driver
+    hda_dir="../linux-src/sound/hda/codecs/cirrus"
+    mv "${hda_dir}/Makefile" "${hda_dir}/Makefile.orig"
+    mv "${hda_dir}/cs420x.c" "${hda_dir}/cs420x.c.orig"
+    cp patch_cirrus/cs420x.c \
+       patch_cirrus/patch_cirrus_a1534_setup.h \
+       patch_cirrus/patch_cirrus_a1534_pcm.h \
+       "${hda_dir}/"
+    cp patch_cirrus/Makefile_cs420x "${hda_dir}/Makefile"
+    sed -i 's/\.free/.remove/' "${hda_dir}/patch_cirrus_a1534_pcm.h"
+    printf '\nccflags-y += -Wno-error=missing-prototypes\n' >>"${hda_dir}/Makefile"
+
+  - |
+    kernel_version=$(basename /usr/lib/modules/*)
+    cd linux-src/sound/hda/codecs/cirrus
+    make -C "/usr/lib/modules/${kernel_version}/build" M="$(pwd)" modules
+
+  install-commands:
+  - |
+    kernel_version=$(basename /usr/lib/modules/*)
+    install -Dm644 \
+      linux-src/sound/hda/codecs/cirrus/snd-hda-codec-cs420x.ko \
+      "%{install-root}%{indep-libdir}/modules/${kernel_version}/extra/snd-hda-codec-cs420x.ko"
+
+  - |
+    install -Dm644 local-config/modprobe.conf "%{install-root}%{indep-libdir}/modprobe.d/apple-macbook12.conf"
+    install -Dm644 local-config/modules-load.conf "%{install-root}%{indep-libdir}/modules-load.d/apple-macbook12.conf"
+
+  - |
+    %{install-extra}
+
+public:
+  bst:
+    split-rules:
+      modules:
+      - '%{indep-libdir}/modules/**'
+      - '%{indep-libdir}/modprobe.d/**'
+      - '%{indep-libdir}/modules-load.d/**'
diff --git a/elements/gnomeos/apple-macbook12-modules/image.bst b/elements/gnomeos/apple-macbook12-modules/image.bst
new file mode 100644
index 0000000000000000000000000000000000000000..568f956801620903810ffedeb5b61e34671829f6
--- /dev/null
+++ b/elements/gnomeos/apple-macbook12-modules/image.bst
@@ -0,0 +1,64 @@
+kind: manual
+
+build-depends:
+- gnomeos/save-perms.bst
+- freedesktop-sdk.bst:components/fakecap.bst
+- freedesktop-sdk.bst:components/systemd.bst
+- freedesktop-sdk.bst:components/erofs-utils.bst
+- gnomeos/os-release-base.bst
+- filename: gnomeos/apple-macbook12-modules/layer.bst
+  config:
+    location: '/sysroot'
+
+sources:
+- kind: local
+  path: files/boot-keys/SYSEXT.key
+- kind: local
+  path: files/boot-keys/SYSEXT.crt
+
+variables:
+  repart-seed: b3f81dc6-746f-43a3-ac1e-2e4e02002fca
+  strip-binaries: ''
+
+environment:
+  EROFS_OPTIONS: -z zstd --all-time -T %{filesystem-time} -E fragments,fragdedupe=inode
+  EROFS_WORKERS: --workers=%{max-jobs}
+  LD_PRELOAD: /usr/libexec/fakecap/fakecap.so
+  FAKECAP_DB: '%{build-root}/fakecap'
+
+environment-nocache:
+- EROFS_WORKERS
+
+config:
+  build-commands:
+  - mkdir fakecap
+  - cp -a /sysroot sysroot
+  - save-perms.py --restore sysroot/perms-usr.json sysroot/usr
+
+  - |
+    mkdir -p tmp
+
+  - |
+    TMPDIR='%{build-root}/tmp' \
+    SYSTEMD_LOG_LEVEL=debug \
+    SYSTEMD_REPART_MKFS_OPTIONS_EROFS="${EROFS_OPTIONS} ${EROFS_WORKERS}" \
+      systemd-repart \
+        --make-ddi=sysext \
+        --empty=create \
+        --size=auto \
+        --dry-run=no \
+        --discard=no \
+        --offline=true \
+        --no-pager \
+        --private-key=SYSEXT.key \
+        --certificate=SYSEXT.crt \
+        --seed %{repart-seed} \
+        --copy-source=sysroot \
+        apple-macbook12-modules-%{systemd-arch}.raw
+
+  install-commands:
+  - |
+    # Output filename is version-independent so the expensive erofs+zstd
+    # build caches across image-version bumps. The version is stamped into
+    # the filename by update-images-slim.bst / update-images.bst.
+    mv apple-macbook12-modules-%{systemd-arch}.raw %{install-root}
diff --git a/elements/gnomeos/apple-macbook12-modules/layer.bst b/elements/gnomeos/apple-macbook12-modules/layer.bst
new file mode 100644
index 0000000000000000000000000000000000000000..cd966eb3cd71a2670db7a0280f1699b154135a31
--- /dev/null
+++ b/elements/gnomeos/apple-macbook12-modules/layer.bst
@@ -0,0 +1,36 @@
+kind: script
+
+build-depends:
+- gnomeos/save-perms.bst
+- freedesktop-sdk.bst:components/fakecap.bst
+- freedesktop-sdk.bst:components/systemd.bst
+- freedesktop-sdk.bst:components/erofs-utils.bst
+- gnomeos/os-release-base.bst
+- filename: gnomeos/initramfs/signed-apple-macbook12-modules.bst
+  config:
+    location: '/sysroot-apple-macbook12-modules'
+
+variables:
+  install-root: '/sysroot-apple-macbook12-modules'
+
+environment:
+  LD_PRELOAD: /usr/libexec/fakecap/fakecap.so
+  FAKECAP_DB: '/fakecap'
+
+config:
+  commands:
+  - mkdir /fakecap
+  - |
+    # ID=_any (systemd 252+) makes the sysext load on any host without the
+    # extension-release file embedding a specific version. This keeps the
+    # sysext content (and the expensive image.bst that consumes it) cache-
+    # stable across image-version bumps. The version is stamped into the
+    # output filename by a downstream rename step in update-images-slim.bst
+    # / update-images.bst, which is what sysupdate's MatchPattern keys off.
+    mkdir -p /sysroot-apple-macbook12-modules/usr/lib/extension-release.d
+    cat <<EOF >/sysroot-apple-macbook12-modules/usr/lib/extension-release.d/extension-release.apple-macbook12-modules
+    ID=_any
+    SYSEXT_SCOPE=initrd system
+    EOF
+
+  - save-perms.py /sysroot-apple-macbook12-modules/perms-usr.json /sysroot-apple-macbook12-modules/usr
