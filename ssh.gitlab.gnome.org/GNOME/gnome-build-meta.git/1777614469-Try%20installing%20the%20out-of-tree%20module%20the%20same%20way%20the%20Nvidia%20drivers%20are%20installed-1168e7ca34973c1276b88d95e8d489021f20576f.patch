diff --git a/elements/gnomeos/os-release-base.bst b/elements/gnomeos/os-release-base.bst
new file mode 100644
index 0000000000000000000000000000000000000000..053ea668c015568d94685dee6f81333bc2b7b9b0
--- /dev/null
+++ b/elements/gnomeos/os-release-base.bst
@@ -0,0 +1,29 @@
+kind: meson
+description: |
+  Cache-stable os-release content. Same source as os-release.bst, but version
+  and commit fields are baked as placeholder strings. The os-release.bst
+  element overlays this with a thin sed step that injects the real values.
+  Downstream consumers that don't read version/commit content (e.g. layer.bst
+  / image.bst elements that only need the file present in the sandbox) should
+  build-depend on this element directly so their cache keys stay stable
+  across image-version bumps.
+
+sources:
+- kind: local
+  path: files/os-release
+
+build-depends:
+- freedesktop-sdk.bst:public-stacks/buildsystem-meson.bst
+- freedesktop-sdk.bst:components/appstream-minimal.bst
+
+depends:
+- freedesktop-sdk.bst:public-stacks/runtime-minimal.bst
+
+variables:
+  meson-local: >-
+    -Dbranch=%{branch}
+    -Dcommit-date='__BST_GNOMEOS_COMMIT_DATE__'
+    -Dcommit=__BST_GNOMEOS_COMMIT__
+    -Dimage-version=__BST_IMAGE_VERSION__
+    -Dmode=sysupdate
+    -Dvariant=user
diff --git a/elements/gnomeos/os-release-confext/image.bst b/elements/gnomeos/os-release-confext/image.bst
new file mode 100644
index 0000000000000000000000000000000000000000..7ab7c105865faf249b725bc32bcaa1c26c7ec3e2
--- /dev/null
+++ b/elements/gnomeos/os-release-confext/image.bst
@@ -0,0 +1,68 @@
+kind: manual
+description: |
+  Confext .raw containing the version-stamped /etc/os-release. Delivered via
+  sysupdate alongside the rest of the image. The base usr image's
+  /etc/os-release symlink points at /usr/lib/os-release (which has
+  placeholders); this confext shadows that symlink with a real file
+  containing the actual version.
+
+build-depends:
+- gnomeos/save-perms.bst
+- freedesktop-sdk.bst:components/fakecap.bst
+- freedesktop-sdk.bst:components/erofs-utils.bst
+- freedesktop-sdk.bst:components/systemd.bst
+- filename: gnomeos/os-release-confext/layer.bst
+  config:
+    location: '/sysroot'
+
+sources:
+- kind: local
+  path: files/boot-keys/SYSEXT.key
+- kind: local
+  path: files/boot-keys/SYSEXT.crt
+
+variables:
+  repart-seed: 1b565ff4-62f6-4748-87b0-0da5c8b7e2ca
+  strip-binaries: ''
+
+environment:
+  EROFS_OPTIONS: -z zstd --all-time -T %{filesystem-time} -E fragments,fragdedupe=inode
+  EROFS_WORKERS: --workers=%{max-jobs}
+  LD_PRELOAD: /usr/libexec/fakecap/fakecap.so
+  FAKECAP_DB: '%{build-root}/fakecap'
+
+environment-nocache:
+- EROFS_WORKERS
+
+config:
+  build-commands:
+  - mkdir fakecap
+  - cp -a /sysroot sysroot
+
+  - |
+    mkdir -p tmp
+
+  - |
+    TMPDIR='%{build-root}/tmp' \
+    SYSTEMD_LOG_LEVEL=debug \
+    SYSTEMD_REPART_MKFS_OPTIONS_EROFS="${EROFS_OPTIONS} ${EROFS_WORKERS}" \
+      systemd-repart \
+        --make-ddi=confext \
+        --empty=create \
+        --size=auto \
+        --dry-run=no \
+        --discard=no \
+        --offline=true \
+        --no-pager \
+        --private-key=SYSEXT.key \
+        --certificate=SYSEXT.crt \
+        --seed %{repart-seed} \
+        --copy-source=sysroot \
+        os-release-confext-%{systemd-arch}.raw
+
+  install-commands:
+  - |
+    # Output filename is version-independent. The aggregator
+    # update-images-slim.bst / update-images.bst stamps the version into the
+    # filename for sysupdate to match.
+    mv os-release-confext-%{systemd-arch}.raw %{install-root}
diff --git a/elements/gnomeos/os-release-confext/layer.bst b/elements/gnomeos/os-release-confext/layer.bst
new file mode 100644
index 0000000000000000000000000000000000000000..0c26c87d3d3f96a2170a4c54391a0b1704236ed5
--- /dev/null
+++ b/elements/gnomeos/os-release-confext/layer.bst
@@ -0,0 +1,48 @@
+kind: manual
+description: |
+  Layer for the version-stamped /etc/os-release confext. Ships a single file
+  at /etc/os-release (overrides the symlink in the base usr image, which
+  points at the placeholder /usr/lib/os-release) plus the confext
+  extension-release. Cheap to rebuild: only sed steps, no compression.
+
+build-depends:
+- freedesktop-sdk.bst:public-stacks/buildsystem-make.bst
+- freedesktop-sdk.bst:components/sed.bst
+- freedesktop-sdk.bst:components/grep.bst
+- gnomeos/os-release-base.bst
+
+variables:
+  strip-binaries: ''
+  # image-version, commit, commit-date-pretty are pulled from
+  # include/image-version.yml as element-local variables (not project-wide)
+  # so their values only contribute to this element's cache key.
+  (@):
+  - include/image-version.yml
+
+config:
+  install-commands:
+  - |
+    set -e
+    mkdir -p "%{install-root}/etc"
+    mkdir -p "%{install-root}/etc/extension-release.d"
+
+    # Take the placeholder os-release and stamp the version into it.
+    cp /usr/lib/os-release "%{install-root}/etc/os-release"
+    sed -i \
+      -e "s|__BST_IMAGE_VERSION__|%{image-version}|g" \
+      -e "s|__BST_GNOMEOS_COMMIT__|%{commit}|g" \
+      -e "s|__BST_GNOMEOS_COMMIT_DATE__|%{commit-date-pretty}|g" \
+      "%{install-root}/etc/os-release"
+
+    if grep -q "__BST_" "%{install-root}/etc/os-release"; then
+      echo "ERROR: leftover placeholders in os-release confext:" >&2
+      grep "__BST_" "%{install-root}/etc/os-release" >&2
+      exit 1
+    fi
+
+    # Confext extension-release with ID=_any so the confext loads on any
+    # host. The version match is enforced by sysupdate's MatchPattern on
+    # the .raw filename, not by extension-release content.
+    cat <<EOF >"%{install-root}/etc/extension-release.d/extension-release.os-release"
+    ID="_any"
+    EOF
