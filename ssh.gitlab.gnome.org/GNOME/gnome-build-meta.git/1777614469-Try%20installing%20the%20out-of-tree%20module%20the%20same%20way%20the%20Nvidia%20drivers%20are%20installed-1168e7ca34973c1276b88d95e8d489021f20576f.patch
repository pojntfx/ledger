new file mode 100644
index 0000000000000000000000000000000000000000..c3d1671eb29b5419d89dd37608608701f7892be3
--- /dev/null
+++ b/elements/gnomeos/update-images-slim.bst
@@ -0,0 +1,89 @@
+kind: script
+
+build-depends:
+- filename: gnomeos/update-images-user-only.bst
+  strict: true
+  config:
+    location: "%{install-root}"
+- filename: gnomeos/devel/image.bst
+  strict: true
+  config:
+    location: "%{install-root}"
+- filename: gnomeos/os-release-confext/image.bst
+  strict: true
+  config:
+    location: "%{install-root}"
+- freedesktop-sdk.bst:public-stacks/runtime-minimal.bst
+
+(?):
+- arch in ["x86_64"]:
+    build-depends:
+      (>):
+      - filename: gnomeos/apple-macbook12-modules/image.bst
+        strict: true
+        config:
+          location: "%{install-root}"
+
+variables:
+  # image-version is pulled in here as element-local (not project-wide) so
+  # only this element's cache key bumps on a version change.
+  (@):
+  - include/image-version.yml
+
+config:
+  commands:
+  # Version-stamp all artifact filenames produced by the now version-stable
+  # upstream elements. This is the only place where %{image-version} is
+  # referenced for slim builds, so this element re-runs cheaply on bump while
+  # the rest of the chain stays cached.
+  #
+  # Patterns covered (post-rename used by sysupdate's MatchPattern):
+  #   usr-<arch>_<uuid>.raw         -> usr-<arch>_<ver>_<uuid>.raw
+  #   usr-<arch>_<uuid>.verity      -> usr-<arch>_<ver>_<uuid>.verity
+  #   gnomeos-<arch>.efi            -> gnomeos-<arch>_<ver>.efi
+  #   gnomeos-apparmor-<arch>.efi   -> gnomeos-apparmor-<arch>_<ver>.efi
+  #   <name>-<arch>.raw             -> <name>-<arch>_<ver>.raw
+  #   <name>-confext-<arch>.raw     -> <name>-confext-<arch>_<ver>.raw
+  #   gnomeos-nvidia-<arch>.addon.efi -> gnomeos-nvidia-<arch>_<ver>.addon.efi
+  - |
+    cd "%{install-root}"
+    arch='%{systemd-arch}'
+    ver='%{image-version}'
+
+    # usr_*: keep UUID suffix, inject version between arch and UUID
+    for f in usr-${arch}_*.raw usr-${arch}_*.verity; do
+      [ -f "$f" ] || continue
+      uuid_and_ext="${f#usr-${arch}_}"   # <uuid>.raw or <uuid>.verity
+      mv "$f" "usr-${arch}_${ver}_${uuid_and_ext}"
+    done
+
+    # gnomeos main UKI + apparmor addon (sibling .efi files)
+    for f in gnomeos-${arch}.efi gnomeos-apparmor-${arch}.efi; do
+      [ -f "$f" ] || continue
+      base="${f%.efi}"   # gnomeos-<arch> or gnomeos-apparmor-<arch>
+      mv "$f" "${base}_${ver}.efi"
+    done
+
+    # nvidia EFI addon (different suffix)
+    for f in gnomeos-nvidia-${arch}.addon.efi; do
+      [ -f "$f" ] || continue
+      mv "$f" "gnomeos-nvidia-${arch}_${ver}.addon.efi"
+    done
+
+    # apple-macbook12 EFI addon (different suffix)
+    for f in gnomeos-apple-macbook12-${arch}.addon.efi; do
+      [ -f "$f" ] || continue
+      mv "$f" "gnomeos-apple-macbook12-${arch}_${ver}.addon.efi"
+    done
+
+    # Generic <name>-<arch>.raw and <name>-confext-<arch>.raw
+    for f in *-${arch}.raw; do
+      [ -f "$f" ] || continue
+      base="${f%-${arch}.raw}"
+      mv "$f" "${base}-${arch}_${ver}.raw"
+    done
+
+  - |
+    cd "%{install-root}"
+    rm SHA256SUMS
+    sha256sum * | tee SHA256SUMS
