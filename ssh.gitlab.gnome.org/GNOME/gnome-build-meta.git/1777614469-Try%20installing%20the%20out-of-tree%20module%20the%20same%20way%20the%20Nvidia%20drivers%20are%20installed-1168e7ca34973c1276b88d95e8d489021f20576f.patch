diff --git a/elements/gnomeos/initramfs.bst b/elements/gnomeos/initramfs.bst
index 4410320008b343bbb886c6379bb3a4f19feb358b..6950d493bd1f7be196b9d2f7d4593153795e136a 100644
--- a/elements/gnomeos/initramfs.bst
+++ b/elements/gnomeos/initramfs.bst
@@ -32,13 +32,38 @@     version="$(ls -1 /lib/modules | head -n1)"
     generate-initramfs /initramfs-root "${version}" "%{libdir}" "%{libdir}/systemd"
 
   - |
+    # Stage out-of-tree modules into the initramfs's modules tree, run
+    # depmod so the initramfs's modules.dep / modules.alias know about
+    # them, then remove the .ko files. The .ko files themselves are
+    # delivered at boot time by systemd-stub via sysext .raw files in
+    # <UKI>.efi.extra.d/, but the kernel's modprobe inside the initrd
+    # needs depmod data to find them. Without this, the kernel's HDA
+    # subsystem's request_module() for the codec via modalias falls
+    # through to the in-tree generic codec.
     case '%{arch}' in
       x86_64)
         version="$(ls -1 /lib/modules | head -n1)"
+        # Nvidia modules
         mkdir -p /initramfs-root/usr/lib/modules/"${version}"/kernel/drivers/video
         cp /usr/lib/modules/"${version}"/kernel/drivers/video/nvidia*.ko* /initramfs-root/usr/lib/modules/"${version}"/kernel/drivers/video/
+        # Apple MacBook 12" patched cs420x codec
+        mkdir -p /initramfs-root/usr/lib/modules/"${version}"/extra
+        cp /usr/lib/modules/"${version}"/extra/snd-hda-codec-cs420x.ko.zst /initramfs-root/usr/lib/modules/"${version}"/extra/
+        # Remove the in-tree cs420x so depmod only sees the patched one
+        # under extra/. Without this, the in-tree path wins and our
+        # patched module never gets resolved by modprobe.
+        rm -f /initramfs-root/usr/lib/modules/"${version}"/kernel/sound/hda/codecs/cirrus/snd-hda-codec-cs420x.ko*
+        # depmod precomputes softdeps from modprobe.d into modules.softdep,
+        # so the apple-macbook12.conf softdep file must be staged into the
+        # initramfs's /usr/lib/modprobe.d before depmod runs. Otherwise the
+        # initramfs's modules.softdep won't carry the cs420x pre-dep on
+        # snd_hda_intel.
+        mkdir -p /initramfs-root/usr/lib/modprobe.d
+        cp /usr/lib/modprobe.d/apple-macbook12.conf /initramfs-root/usr/lib/modprobe.d/
         depmod -a -b /initramfs-root/usr "${version}"
         rm -rf /initramfs-root/usr/lib/modules/"${version}"/kernel/drivers/video/nvidia*.ko*
+        rm -f /initramfs-root/usr/lib/modules/"${version}"/extra/snd-hda-codec-cs420x.ko.zst
