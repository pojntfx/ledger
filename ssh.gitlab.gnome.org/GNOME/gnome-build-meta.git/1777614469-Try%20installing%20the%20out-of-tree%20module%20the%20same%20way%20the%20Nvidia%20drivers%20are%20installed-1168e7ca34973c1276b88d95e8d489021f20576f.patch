@@ -1,17 +1,57 @@
-kind: meson
-sources:
-- kind: local
-  path: files/os-release
+kind: manual
+description: |
+  Final os-release content. Stamps the cache-stable os-release-base artifact
+  with the current image-version and commit metadata via a cheap sed step.
+  This element is the only one that references %{image-version}, %{commit},
+  %{commit-date-pretty}, so it is the only one whose cache key changes on
+  bump. Consumers that need version-stamped /usr/lib/os-release should
+  build-depend on this element. Consumers that only need the file present
+  (without reading version content) should build-depend on os-release-base.bst
+  to keep their cache keys stable across bumps.
+
 build-depends:
-- freedesktop-sdk.bst:public-stacks/buildsystem-meson.bst
-- freedesktop-sdk.bst:components/appstream-minimal.bst
-depends:
-- freedesktop-sdk.bst:public-stacks/runtime-minimal.bst
+- freedesktop-sdk.bst:public-stacks/buildsystem-make.bst
+- freedesktop-sdk.bst:components/sed.bst
+- freedesktop-sdk.bst:components/grep.bst
+- gnomeos/os-release-base.bst
+
 variables:
-  meson-local: >-
-    -Dbranch=%{branch}
-    -Dcommit-date='%{commit-date-pretty}'
-    -Dcommit='%{commit}'
-    -Dimage-version=%{image-version}
-    -Dmode=sysupdate
-    -Dvariant=user
+  strip-binaries: ''
+  # image-version, commit, commit-date-pretty are intentionally pulled from
+  # include/image-version.yml here (instead of being project-wide variables)
+  # so their values only contribute to this element's cache key, not to
+  # every element's. See project.conf for the rationale.
+  (@):
+  - include/image-version.yml
+
+config:
+  install-commands:
+  # Copy only the os-release-base outputs into our install-root, then sed-
+  # replace placeholders with real values. This avoids harvesting the entire
+  # build sandbox (which would include runtime-minimal staging) into our
+  # artifact and causing overlap conflicts in downstream consumers.
+  - |
+    set -e
+    mkdir -p "%{install-root}/usr/lib"
+    mkdir -p "%{install-root}/etc"
+
+    # Copy only the files produced by the os-release-base meson build.
+    cp /usr/lib/os-release "%{install-root}/usr/lib/os-release"
+    cp /etc/issue "%{install-root}/etc/issue"
+    cp /etc/issue.net "%{install-root}/etc/issue.net"
+
+    # Re-create the /etc/os-release symlink (relative to /etc).
+    ln -s ../usr/lib/os-release "%{install-root}/etc/os-release"
+
+    # Stamp the version-dependent placeholders.
+    sed -i \
+      -e "s|__BST_IMAGE_VERSION__|%{image-version}|g" \
+      -e "s|__BST_GNOMEOS_COMMIT__|%{commit}|g" \
+      -e "s|__BST_GNOMEOS_COMMIT_DATE__|%{commit-date-pretty}|g" \
+      "%{install-root}/usr/lib/os-release"
+
+    if grep -q "__BST_" "%{install-root}/usr/lib/os-release"; then
+      echo "ERROR: leftover placeholders in os-release:" >&2
+      grep "__BST_" "%{install-root}/usr/lib/os-release" >&2
+      exit 1
+    fi
