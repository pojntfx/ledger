From 5c99ae06cd0569794a02931d7684dabdaaca4307 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Thu, 19 Mar 2026 20:36:27 -0700
Subject: [PATCH] Add architecture auto-detection with split download button

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/style.css b/assets/style.css
index 8caf94d4e6fb5597e24e7cdcc7b760316392bee1..f7299b71b034b52bf8bc71fac0119144321923c4 100755
--- a/assets/style.css
+++ b/assets/style.css
@@ -876,3 +876,64 @@   gap: 12px;
 }
 .social { fill: rgba(255,255,255,0.6); transition: all 200ms ease-out; }
 .social:hover { fill: rgba(255,255,255,1); }
+
+/* Download split button */
+#dl-split {
+  anchor-name: --dl-split;
+
+  /* We don't want this to be visible if JS is disabled, that's what the <noscript> fallback is for */
+  &:not([hidden]) {
+    display: inline-flex;
+  }
+
+  /* Right side of the left part of the split button should not be rounded */
+  & .btn.suggested:first-child {
+    border-radius: var(--btnround) 0 0 var(--btnround);
+    margin-right: 0;
+  }
+
+  & #dl-toggle {
+    /* Left side of the right part of the split button should not be rounded */
+    border-radius: 0 var(--btnround) var(--btnround) 0;
+    border-left: 1px solid color-mix(in srgb, var(--light1) 25%, transparent);
+    margin-left: 0;
+    padding-inline: 0.7rem;
+    min-width: 0;
+    cursor: pointer;
+  }
+
+  & [popover] {
+    position-anchor: --dl-split;
+    position-area: bottom span-left;
+    position-try-fallbacks: bottom span-right;
+    border: none;
+    border-radius: var(--defaultrds);
+
+    & button {
+      all: unset;
+      display: block;
+      width: 100%;
+      padding: 0.4rem 0.7rem;
+      border-radius: var(--defaultrds);
+      cursor: pointer;
+      box-sizing: border-box;
+
+      &:hover {
+        background: var(--btn-bg);
+      }
+
+      &:focus-visible {
+        outline: 2px solid var(--blue3);
+      }
+
+      & .check {
+        visibility: hidden;
+        color: var(--blue3);
+      }
+
+      &.selected .check {
+        visibility: visible;
+      }
+    }
+  }
+}
