     <h1 id="subtitle" class="title">Try the latest GNOME software</h1>
-      <a class="btn suggested" href="https://os.gnome.org/download/latest/gnome_os_nightly_x86_64.iso">Download (Intel &amp; AMD)</a>
-      <a class="btn suggested" href="https://os.gnome.org/download/latest/gnome_os_nightly_aarch64.iso">Download (ARM)</a>
+      <noscript>
+        <a class="btn suggested" href="https://os.gnome.org/download/latest/gnome_os_nightly_x86_64.iso">Download (Intel &amp; AMD)</a>
+        <a class="btn suggested" href="https://os.gnome.org/download/latest/gnome_os_nightly_aarch64.iso">Download (ARM)</a>
+      </noscript>
+      <div id="dl-split" hidden>
+        <a class="btn suggested" id="dl-link" href="https://os.gnome.org/download/latest/gnome_os_nightly_x86_64.iso">Download (Intel &amp; AMD)</a>
+        <button class="btn suggested" id="dl-toggle" aria-label="Select architecture" popovertarget="dl-menu">&#9662;</button>
+        <div id="dl-menu" popover role="menu">
+          <button class="selected" role="menuitemradio" aria-checked="true" data-url="https://os.gnome.org/download/latest/gnome_os_nightly_x86_64.iso" data-text="Download (Intel &amp; AMD)" data-arch="x86_64">Intel &amp; AMD <span class="check">&#10003;</span></button>
+          <button role="menuitemradio" aria-checked="false" data-url="https://os.gnome.org/download/latest/gnome_os_nightly_aarch64.iso" data-text="Download (ARM)" data-arch="aarch64">ARM <span class="check">&#10003;</span></button>
+        </div>
+      </div>
+      <script type="module">
+        const split = document.querySelector("#dl-split");
+        const link = split.querySelector("#dl-link");
+        const menu = split.querySelector("#dl-menu");
+
+        split.hidden = false;
+
+        const select = (arch) => menu.querySelectorAll("button").forEach((opt) => {
+          const match = opt.dataset.arch === arch;
+          opt.classList.toggle("selected", match);
+          opt.ariaChecked = match;
+          if (match) {
+            link.href = opt.dataset.url;
+            link.textContent = opt.dataset.text;
+          }
+        });
+
+        menu.querySelectorAll("button").forEach((opt) => opt.addEventListener("click", () => {
+          select(opt.dataset.arch);
+          menu.hidePopover();
+        }));
+
+        navigator.userAgentData?.getHighEntropyValues(["architecture"])
+          .then(({ architecture }) => architecture === "arm" && select("aarch64"));
+      </script>
       <p class="warning">This is pre-release software. Bad things may happen if you use it in production.</p>
     </div>
   </div><!--hero-->

