-  <div class="hero">
-    <section class="header">
-      <h2 id="logo"><a href="/">GNOME OS Nightly</a></h2>
-      <ul class="nav">
-        <li><a href="https://www.gnome.org/about/">About Us</a></li>
-        <li><a href="https://handbook.gnome.org">Get Involved</a></li>
-        <!--<li><a href="https://shop.gnome.org/">Shop</a></li>-->
