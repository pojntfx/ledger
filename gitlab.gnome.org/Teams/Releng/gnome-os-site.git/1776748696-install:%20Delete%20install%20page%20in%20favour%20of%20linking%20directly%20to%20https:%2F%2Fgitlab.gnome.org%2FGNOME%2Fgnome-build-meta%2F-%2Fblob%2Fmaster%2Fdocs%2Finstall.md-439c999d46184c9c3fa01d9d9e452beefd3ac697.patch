From 439c999d46184c9c3fa01d9d9e452beefd3ac697 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Mon, 20 Apr 2026 22:18:16 -0700
Subject: [PATCH] install: Delete install page in favour of linking directly to https://gitlab.gnome.org/GNOME/gnome-build-meta/-/blob/master/docs/install.md

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/.gitlab-ci.yml b/.gitlab-ci.yml
index b60ea6358919059e4e1f2987d0194d7326694e13..79abd4e9b9a2412aa8f7738604fd489152938b53 100644
--- a/.gitlab-ci.yml
+++ b/.gitlab-ci.yml
@@ -2,7 +2,7 @@ make-pages:
   stage: "build"
   script:
   - mkdir ./public
-  - cp -R ./{index.html,install.html,404.html,403.html,assets} ./public
+  - cp -R ./{index.html,404.html,403.html,assets} ./public
   artifacts:
     when: "always"
     expire_in: "2 days"
diff --git a/README.md b/README.md
index 7c6da0b4c5f38a1716350187d0a7d7ff1b131319..c9413d6a867166dae87bc7c968215179827201ae 100644
--- a/README.md
+++ b/README.md
@@ -6,6 +6,6 @@ Download URLs under `/download/` are proxied to the redirect service ([gnome-os-website](https://gitlab.gnome.org/Teams/Releng/gnome-os-website)); this repo only holds HTML and assets for the main site.
 
 ## Matomo analytics
 
-**Any new HTML page must include the Matomo tracking snippet in `<head>`** (before `</head>`). Copy the full block from an existing page—between `<!-- Matomo -->` and `<!-- End Matomo Code -->`—in `index.html`, `install.html`, `403.html`, or `404.html`.
+**Any new HTML page must include the Matomo tracking snippet in `<head>`** (before `</head>`). Copy the full block from an existing page—between `<!-- Matomo -->` and `<!-- End Matomo Code -->`—in `index.html`, `403.html`, or `404.html`.
 
 The Matomo site id for os.gnome.org is **`73`** in that snippet. It must match the id shown in Matomo for this site; update every HTML file if the Websites team assigns a different id. Do not change the tracker URL (`https://webstats.gnome.org/`) unless analytics setup changes.
