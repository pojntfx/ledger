From cfb2a30c85afe832e74c31822fc31a7f8e59c97e Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Mon, 11 May 2026 23:50:21 -0700
Subject: [PATCH] ci: Add Flatpak builds to CI/CD configuration

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/.github/workflows/nightly.yml b/.github/workflows/nightly.yml
index 69946b91b1f16d54a7fb9e883db9b5ab45ebea18..1569c81a7c41b0801c44f7d9617caba050098020 100644
--- a/.github/workflows/nightly.yml
+++ b/.github/workflows/nightly.yml
@@ -213,6 +213,37 @@               with:
                   name: ${{ steps.artifact_details.outputs.artifact_name }}
                   path: artifact_root/
 
+    build_flatpak:
+        name: Build Flatpak (${{ matrix.target.arch }})
+        needs: check_for_commits
+        if: needs.check_for_commits.outputs.has_new_commits == 'true'
+        runs-on: ${{ matrix.target.runner }}
+        permissions:
+            contents: read
+        container:
+            image: ghcr.io/flathub-infra/flatpak-github-actions:kde-6.10
+            options: --privileged
+        strategy:
+            matrix:
+                target:
+                    - id: flatpak-x86_64
+                      arch: x86_64
+                      runner: ubuntu-24.04
+                    - id: flatpak-aarch64
+                      arch: aarch64
+                      runner: ubuntu-24.04-arm
+        steps:
+            - name: Checkout Repository
+              uses: actions/checkout@v6
+
+            - name: Build Flatpak and upload output
+              uses: flatpak/flatpak-github-actions/flatpak-builder@v6
+              with:
+                  bundle: io.github.crankboyhq.crankboy-manager.flatpak
+                  manifest-path: io.github.crankboyhq.crankboy-manager.json
+                  cache-key: flatpak-builder-${{ github.sha }}
+                  arch: ${{ matrix.target.arch }}
+
     build_linux:
         name: Build Linux Executable
         needs: check_for_commits
diff --git a/.github/workflows/release.yml b/.github/workflows/release.yml
index ae21f60e1ac591965787147817517c343d5c735d..19255926558d4e1a30453335dfd289e775f7c58c 100644
--- a/.github/workflows/release.yml
+++ b/.github/workflows/release.yml
@@ -191,10 +191,39 @@         with:
           name: linux-build
           path: artifact_root/
 
+  build_flatpak:
+    name: Build Flatpak (${{ matrix.target.arch }})
+    runs-on: ${{ matrix.target.runner }}
+    permissions:
+      contents: read
+    container:
+      image: ghcr.io/flathub-infra/flatpak-github-actions:kde-6.10
+      options: --privileged
+    strategy:
+      matrix:
+        target:
+          - id: flatpak-x86_64
+            arch: x86_64
+            runner: ubuntu-24.04
+          - id: flatpak-aarch64
+            arch: aarch64
+            runner: ubuntu-24.04-arm
+    steps:
+      - name: Checkout Repository
+        uses: actions/checkout@v6
+
+      - name: Build Flatpak and upload output
+        uses: flatpak/flatpak-github-actions/flatpak-builder@v6
+        with:
+          bundle: io.github.crankboyhq.crankboy-manager.flatpak
+          manifest-path: io.github.crankboyhq.crankboy-manager.json
+          cache-key: flatpak-builder-${{ github.sha }}
+          arch: ${{ matrix.target.arch }}
+
   release:
     name: Create Draft Release and Upload Assets
     runs-on: ubuntu-latest
-    needs: [build_windows, build_macos, build_linux]
+    needs: [build_windows, build_macos, build_linux, build_flatpak]
     permissions:
       contents: write
 
@@ -255,6 +284,14 @@           # Linux
           if [ -n "$(ls artifacts/linux-build/*.AppImage 2>/dev/null)" ]; then
             cp artifacts/linux-build/*.AppImage "release_assets/CrankBoyManager-${VERSION}-x86_64.AppImage"
           fi
+
+          # Flatpak
+          for arch in x86_64 aarch64; do
+            src="artifacts/io.github.crankboyhq.crankboy-manager-${arch}.flatpak/io.github.crankboyhq.crankboy-manager.flatpak"
+            if [ -f "$src" ]; then
+              cp "$src" "release_assets/CrankBoyManager-${VERSION}-${arch}.flatpak"
+            fi
+          done
 
       - name: Create Draft Release
         env:

