diff --git a/components/Map.tsx b/components/Map.tsx
index 8e9eef3e8198557dc21afbd45031f37adcf72ec4..366510e7525eaaeaa95b247b205710e388ddfd65 100644
--- a/components/Map.tsx
+++ b/components/Map.tsx
