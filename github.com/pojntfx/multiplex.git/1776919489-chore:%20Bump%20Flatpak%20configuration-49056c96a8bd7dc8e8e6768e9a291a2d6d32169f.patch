From 49056c96a8bd7dc8e8e6768e9a291a2d6d32169f Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 22 Apr 2026 21:44:49 -0700
Subject: [PATCH] chore: Bump Flatpak configuration

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/.github/workflows/flatpak.yaml b/.github/workflows/flatpak.yaml
index ed960d15896445d0d4b03734707ba875895c661d..7a7fa66cff69950b8b3eb062dab28b7f70d957f1 100644
--- a/.github/workflows/flatpak.yaml
+++ b/.github/workflows/flatpak.yaml
@@ -10,7 +10,7 @@     runs-on: ${{ matrix.target.runner }}
     permissions:
       contents: read
     container:
-      image: ghcr.io/flathub-infra/flatpak-github-actions:gnome-48
+      image: ghcr.io/flathub-infra/flatpak-github-actions:gnome-50
       options: --privileged
     strategy:
       matrix:
@@ -23,7 +23,7 @@             arch: aarch64
             runner: ubuntu-24.04-arm
     steps:
       - name: Checkout
-        uses: actions/checkout@v4
+        uses: actions/checkout@v6
       - name: Build Flatpak and upload output
         uses: flatpak/flatpak-github-actions/flatpak-builder@v6
         with:
@@ -38,12 +38,11 @@     permissions:
       contents: write
     needs: build-linux
     if: github.event_name != 'pull_request' || github.event.pull_request.head.repo.full_name == github.repository
-
     steps:
       - name: Checkout
-        uses: actions/checkout@v4
+        uses: actions/checkout@v6
       - name: Download output
-        uses: actions/download-artifact@v4
+        uses: actions/download-artifact@v7
         with:
           path: /tmp/out
       - name: Extract branch name
@@ -51,7 +50,7 @@         id: extract_branch
         run: echo "branch=$(echo ${GITHUB_REF#refs/heads/})" >> $GITHUB_OUTPUT
       - name: Publish pre-release to GitHub releases
         if: ${{ !startsWith(github.ref, 'refs/tags/v') }}
-        uses: softprops/action-gh-release@605f567f95cfaf9465d68c7dbf509f374691fb12
+        uses: softprops/action-gh-release@v2
         with:
           tag_name: release-${{ steps.extract_branch.outputs.branch }}
           prerelease: true
@@ -60,7 +59,7 @@           files: |
             /tmp/out/*/*
       - name: Publish release to GitHub releases
         if: startsWith(github.ref, 'refs/tags/v')
-        uses: softprops/action-gh-release@605f567f95cfaf9465d68c7dbf509f374691fb12
+        uses: softprops/action-gh-release@v2
         with:
           prerelease: false
           overwrite_files: true

