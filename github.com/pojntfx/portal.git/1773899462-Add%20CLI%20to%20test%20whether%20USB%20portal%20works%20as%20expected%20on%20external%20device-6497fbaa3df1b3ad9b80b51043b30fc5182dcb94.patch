From 6497fbaa3df1b3ad9b80b51043b30fc5182dcb94 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 18 Mar 2026 22:51:02 -0700
Subject: [PATCH] Add CLI to test whether USB portal works as expected on external device

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/cmd/usb/main.go b/cmd/usb/main.go
new file mode 100644
index 0000000000000000000000000000000000000000..fb57d861955a986da4d10b34bbeb4581a6846492
--- /dev/null
+++ b/cmd/usb/main.go
@@ -0,0 +1,138 @@
+package main
+
+import (
+	"encoding/json"
+	"flag"
+	"fmt"
+	"log/slog"
+	"os"
+	"os/signal"
+	"syscall"
+
+	"github.com/rymdport/portal/usb"
+)
+
+func main() {
+	flag.Parse()
+
+	switch flag.Arg(0) {
+	case "enumerate":
+		devices, err := usb.EnumerateDevices()
+		if err != nil {
+			panic(err)
+		}
+
+		for _, d := range devices {
+			b, err := json.Marshal(d)
+			if err != nil {
+				panic(err)
+			}
+
+			fmt.Println(string(b))
+		}
+
+	case "monitor":
+		session, err := usb.CreateSession()
+		if err != nil {
+			panic(err)
+		}
+		defer session.Close()
+
+		err = session.SetOnDeviceEvents(func(events []usb.DeviceEvent) {
+			for _, e := range events {
+				b, err := json.Marshal(e)
+				if err != nil {
+					panic(err)
+				}
+
+				fmt.Println(string(b))
+			}
+		})
+		if err != nil {
+			panic(err)
+		}
+
+		slog.Info(`Monitoring USB device events`)
+
+		sig := make(chan os.Signal, 1)
+		signal.Notify(sig, syscall.SIGINT, syscall.SIGTERM)
+		<-sig
+
+	case "acquire":
+		writable := false
+		for _, a := range flag.Args()[1:] {
+			if a == "--writable" {
+				writable = true
+			}
+		}
+
+		ids := []string{}
+		for _, a := range flag.Args()[1:] {
+			if a != "--writable" {
+				ids = append(ids, a)
+			}
+		}
+
+		access := make([]usb.DeviceAccess, len(ids))
+		for i, id := range ids {
+			access[i] = usb.DeviceAccess{ID: id, Writable: writable}
+		}
+
+		handle, err := usb.AcquireDevices("", access, nil)
+		if err != nil {
+			panic(err)
+		}
+		if handle == "" {
+			panic("access denied")
+		}
+
+		var files []*os.File
+		for {
+			results, finished, err := usb.FinishAcquireDevices(handle)
+			if err != nil {
+				panic(err)
+			}
+
+			for _, r := range results {
+				b, err := json.Marshal(r)
+				if err != nil {
+					panic(err)
+				}
+
+				fmt.Println(string(b))
+
+				if r.File != nil {
+					files = append(files, r.File)
+				}
+			}
+
+			if finished {
+				break
+			}
+		}
+
+		slog.Info(`Holding devices, press Ctrl+C to release`)
+
+		sig := make(chan os.Signal, 1)
+		signal.Notify(sig, syscall.SIGINT, syscall.SIGTERM)
+		<-sig
+
+		for _, f := range files {
+			f.Close()
+		}
+
+		if err := usb.ReleaseDevices(ids); err != nil {
+			panic(err)
+		}
+
+	default:
+		fmt.Fprintf(os.Stderr, `Usage: %s <command> [args...]
+
+Commands:
+  enumerate                    List connected USB devices as JSONL
+  monitor                      Watch for USB device events as JSONL
+  acquire <id> [--writable]    Acquire USB devices and hold until Ctrl+C
+`, os.Args[0])
+		os.Exit(1)
+	}
+}

