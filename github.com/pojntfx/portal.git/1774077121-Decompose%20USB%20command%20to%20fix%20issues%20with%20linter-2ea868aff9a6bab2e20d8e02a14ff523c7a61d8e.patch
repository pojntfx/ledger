diff --git a/cmd/usb/main.go b/cmd/usb/main.go
index 60966b8b2c0c50a2d73d77d29d51e3d6d55c7efa..2dd202536254d03b62f38cd5da119620422b6055 100644
--- a/cmd/usb/main.go
+++ b/cmd/usb/main.go
@@ -19,101 +19,117 @@ 	enc := json.NewEncoder(os.Stdout)
 
 	switch flag.Arg(0) {
 	case "enumerate":
-		devices, err := usb.EnumerateDevices()
-		if err != nil {
-			panic(err)
-		}
+		enumerate(enc)
 
-		for _, dev := range devices {
-			if err := enc.Encode(map[string]any{
-				"ID":         dev.ID,
