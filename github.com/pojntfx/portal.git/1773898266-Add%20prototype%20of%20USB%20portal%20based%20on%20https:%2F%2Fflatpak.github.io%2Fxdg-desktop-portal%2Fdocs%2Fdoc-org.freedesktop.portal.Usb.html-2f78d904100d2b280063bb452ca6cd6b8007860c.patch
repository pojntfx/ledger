+// CallOnObjectWithResults calls the specified callName on the given object and stores
+// all output arguments into the provided destinations (as with dbus.Call.Store).
+func CallOnObjectWithResults(path dbus.ObjectPath, callName string, args []any, dest ...any) error {
+	call, err := callOnObject(path, callName, args...)
+	if err != nil {
+		return err
+	}
+
+	return call.Store(dest...)
