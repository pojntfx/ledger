diff --git a/usb/acquire.go b/usb/acquire.go
new file mode 100644
index 0000000000000000000000000000000000000000..b07cc25983ca3fb1821bf0389f2a684905029e10
--- /dev/null
+++ b/usb/acquire.go
@@ -0,0 +1,126 @@
+package usb
+
+import (
+	"os"
+
+	"github.com/godbus/dbus/v5"
+	"github.com/rymdport/portal/internal/apis"
+	"github.com/rymdport/portal/internal/convert"
+	"github.com/rymdport/portal/internal/request"
+)
+
+const (
+	acquireDevicesCallName      = interfaceName + ".AcquireDevices"
+	finishAcquireDevicesCallName = interfaceName + ".FinishAcquireDevices"
+)
+
+// AcquireOptions contains options for the AcquireDevices call.
+type AcquireOptions struct {
+	HandleToken string // A string that will be used as the last element of the handle.
+}
+
+type deviceEntry struct {
+	ID      string
+	Options map[string]dbus.Variant
+}
+
+// DeviceAccess specifies access options for a single device in an acquire request.
+type DeviceAccess struct {
+	ID       string // Device ID to acquire.
+	Writable bool   // Whether to open in read-write mode. Default: false (read-only).
+}
+
+// DeviceResult contains the outcome of acquiring a single device.
+type DeviceResult struct {
+	ID      string   // Device ID.
+	Success bool     // Whether access was granted.
+	File    *os.File // Open file for the device. Only present on success.
+	Error   string   // Error message. Only present on failure.
+}
+
+// AcquireDevices requests access to the given USB device nodes.
+// Pass the returned handle to FinishAcquireDevices to retrieve the file descriptors.
+func AcquireDevices(parentWindow string, devices []DeviceAccess, options *AcquireOptions) (dbus.ObjectPath, error) {
+	data := map[string]dbus.Variant{}
+	if options != nil && options.HandleToken != "" {
+		data["handle_token"] = convert.FromString(options.HandleToken)
+	}
+
+	rawDevices := make([]deviceEntry, len(devices))
+	for i, d := range devices {
+		rawDevices[i] = deviceEntry{
+			ID:      d.ID,
+			Options: map[string]dbus.Variant{"writable": convert.FromBool(d.Writable)},
+		}
+	}
+
+	result, err := apis.Call(acquireDevicesCallName, parentWindow, rawDevices, data)
+	if err != nil {
+		return "", err
+	}
+
+	handle := result.(dbus.ObjectPath)
+	status, _, err := request.OnSignalResponse(handle)
+	if err != nil {
+		return "", err
+	} else if status > request.Success {
+		return "", nil
+	}
+
+	return handle, nil
+}
+
+// FinishAcquireDevices retrieves the file descriptors for devices requested via AcquireDevices.
+// If finished is false, call FinishAcquireDevices again until it returns true.
+func FinishAcquireDevices(handle dbus.ObjectPath) (results []DeviceResult, finished bool, err error) {
+	var rawResults [][]any
+
+	err = apis.CallOnObjectWithResults(
+		apis.ObjectPath,
+		finishAcquireDevicesCallName,
+		[]any{handle, map[string]dbus.Variant{}},
+		&rawResults,
+		&finished,
+	)
+	if err != nil {
+		return nil, false, err
+	}
+
+	results = make([]DeviceResult, 0, len(rawResults))
+	for _, raw := range rawResults {
+		if len(raw) != 2 {
+			continue
+		}
+
+		id, ok := raw[0].(string)
+		if !ok {
+			continue
+		}
+
+		props, ok := raw[1].(map[string]dbus.Variant)
+		if !ok {
+			continue
+		}
+
+		dr := DeviceResult{ID: id}
+		if v, ok := props["success"]; ok {
+			dr.Success, _ = v.Value().(bool)
+		}
+
+		if dr.Success {
+			if v, ok := props["fd"]; ok {
+				if fd, ok := v.Value().(dbus.UnixFD); ok {
+					dr.File = os.NewFile(uintptr(fd), id)
+				}
+			}
+		} else {
+			if v, ok := props["error"]; ok {
+				dr.Error, _ = v.Value().(string)
+			}
+		}
+
+		results = append(results, dr)
+	}
+
+	return results, finished, nil
+}
diff --git a/usb/enumerate.go b/usb/enumerate.go
new file mode 100644
index 0000000000000000000000000000000000000000..d67ad01c56a20f1e08f514a0a16d6d5131d4e2ed
--- /dev/null
+++ b/usb/enumerate.go
@@ -0,0 +1,76 @@
+package usb
+
+import (
+	"github.com/godbus/dbus/v5"
+	"github.com/rymdport/portal/internal/apis"
+)
+
+const enumerateDevicesCallName = interfaceName + ".EnumerateDevices"
+
+// EnumerateDevices returns all connected USB devices that this application has permission to see.
+func EnumerateDevices() ([]Device, error) {
+	result, err := apis.Call(enumerateDevicesCallName, map[string]dbus.Variant{})
+	if err != nil {
+		return nil, err
+	}
+
+	rawDevices, ok := result.([][]any)
+	if !ok {
+		return nil, nil
+	}
+
+	devices := make([]Device, 0, len(rawDevices))
+	for _, raw := range rawDevices {
+		if len(raw) != 2 {
+			continue
+		}
+
+		id, ok := raw[0].(string)
+		if !ok {
+			continue
+		}
+
+		props, ok := raw[1].(map[string]dbus.Variant)
+		if !ok {
+			continue
+		}
+
+		devices = append(devices, parseDevice(id, props))
+	}
+
+	return devices, nil
+}
+
+// parseDevice builds a Device from a device ID and its property vardict.
+func parseDevice(id string, props map[string]dbus.Variant) Device {
+	d := Device{ID: id}
+
+	if v, ok := props["parent"]; ok {
+		d.Parent, _ = v.Value().(string)
+	}
+
+	if v, ok := props["readable"]; ok {
+		d.Readable, _ = v.Value().(bool)
+	}
+
+	if v, ok := props["writable"]; ok {
+		d.Writable, _ = v.Value().(bool)
+	}
+
+	if v, ok := props["device-file"]; ok {
+		d.DeviceFile, _ = v.Value().(string)
+	}
+
+	if v, ok := props["properties"]; ok {
+		if raw, ok := v.Value().(map[string]dbus.Variant); ok {
+			d.Properties = make(map[string]string, len(raw))
+			for k, pv := range raw {
+				if s, ok := pv.Value().(string); ok {
+					d.Properties[k] = s
+				}
+			}
+		}
+	}
+
+	return d
+}
diff --git a/usb/release.go b/usb/release.go
