diff --git a/qt/main.go b/qt/main.go
new file mode 100644
index 0000000000000000000000000000000000000000..454c234ebeecfce44659a63fb86dd47bb77f0744
--- /dev/null
+++ b/qt/main.go
@@ -0,0 +1,105 @@
+package main
+
+import (
+	_ "embed"
+	"os"
+	"path/filepath"
+	"runtime"
+
+	qt "github.com/mappu/miqt/qt6"
+	"github.com/mappu/miqt/qt6/qml"
+)
+
+//go:embed alarm-clock-elapsed.oga
+var alarmSound []byte
+
+const (
+	appID            = "com.pojtinger.felicitas.Sessions"
+	appName          = "Sessions"
+	appOrganization  = "pojtinger.felicitas"
+	appVersion       = "0.1.17"
+	appDescription   = "Focus with timed work intervals."
+	appHomepageURL   = "https://github.com/pojntfx/sessions"
+	appCopyrightYear = "2026"
+)
+
+func writableTempDir() (string, error) {
+	base := qt.QStandardPaths_WritableLocation(qt.QStandardPaths__CacheLocation)
+	if base == "" {
+		base = os.TempDir()
+	}
+	dir := filepath.Join(base, "sessions-runtime")
+	if err := os.MkdirAll(dir, 0o755); err != nil {
+		return "", err
+	}
+	return dir, nil
+}
+
+func main() {
+	if os.Getenv("QT_QUICK_CONTROLS_STYLE") == "" && runtime.GOOS != "android" {
+		os.Setenv("QT_QUICK_CONTROLS_STYLE", "org.kde.desktop")
+	}
+
+	app := qt.NewQApplication(os.Args)
+	defer app.Delete()
+
+	qt.QCoreApplication_SetApplicationName(appName)
+	qt.QCoreApplication_SetOrganizationName(appOrganization)
+	qt.QCoreApplication_SetApplicationVersion(appVersion)
+	qt.QGuiApplication_SetApplicationDisplayName(appName)
+	qt.QGuiApplication_SetDesktopFileName(appID)
+	if runtime.GOOS != "android" {
+		qt.QIcon_SetThemeName("breeze")
+	}
+
+	tmpDir, err := writableTempDir()
+	if err != nil {
+		panic(err)
+	}
+
+	alarmPath := filepath.Join(tmpDir, "alarm.oga")
+	if err := os.WriteFile(alarmPath, alarmSound, 0o644); err != nil {
+		panic(err)
+	}
+
+	mainQmlPath := filepath.Join(tmpDir, "main.qml")
+	if err := os.WriteFile(mainQmlPath, mainQml, 0o644); err != nil {
+		panic(err)
+	}
+	if err := os.WriteFile(filepath.Join(tmpDir, "Dial.qml"), dialQml, 0o644); err != nil {
+		panic(err)
+	}
+
+	var trayIconObj *qt.QObject
+	if qt.QSystemTrayIcon_IsSystemTrayAvailable() && qt.QSystemTrayIcon_SupportsMessages() {
+		trayIcon := qt.NewQSystemTrayIcon()
+		trayIcon.SetIcon(qt.QIcon_FromTheme("clock"))
+		trayIcon.SetToolTip(appName)
+		trayIcon.SetVisible(true)
+		trayIconObj = trayIcon.QObject
+	}
+
+	engine := qml.NewQQmlApplicationEngine()
+	defer engine.Delete()
+
+	rootCtx := engine.RootContext()
+	if trayIconObj != nil {
+		rootCtx.SetContextProperty("trayIcon", trayIconObj)
+	}
+	rootCtx.SetContextProperty2("hasTrayIcon", qt.NewQVariant8(trayIconObj != nil))
+	rootCtx.SetContextProperty2("alarmSourceUrl", qt.NewQVariant14(qt.QUrl_FromLocalFile(alarmPath).ToString()))
+	rootCtx.SetContextProperty2("appID", qt.NewQVariant14(appID))
+	rootCtx.SetContextProperty2("appName", qt.NewQVariant14(appName))
+	rootCtx.SetContextProperty2("appVersion", qt.NewQVariant14(appVersion))
+	rootCtx.SetContextProperty2("appDescription", qt.NewQVariant14(appDescription))
+	rootCtx.SetContextProperty2("appHomepageURL", qt.NewQVariant14(appHomepageURL))
+	rootCtx.SetContextProperty2("appCopyrightYear", qt.NewQVariant14(appCopyrightYear))
+
+	engine.Load(qt.QUrl_FromLocalFile(mainQmlPath))
+
+	if len(engine.RootObjects()) == 0 {
+		os.Exit(1)
+	}
+
+	os.Exit(qt.QApplication_Exec())
+}
diff --git a/qt/qml/Dial.qml b/qt/qml/Dial.qml
new file mode 100644
index 0000000000000000000000000000000000000000..c8617bdcd64a38738d96ffd079e0bfcc0aae03a3
--- /dev/null
+++ b/qt/qml/Dial.qml
@@ -0,0 +1,176 @@
+import QtQuick
+import QtQuick.Shapes
+
+Item {
+    id: root
+
+    property int totalSec: 300
+    property int maxSec: 3600
+    property bool running: false
+    property real remainSec: 0
+
+    property color accentColorOverride: "#3daee9"
+    property color errorColorOverride: "#da4453"
+
+    signal dialed(int totalSec)
+    signal dialReleased
+
+    readonly property real progress: maxSec > 0 ? totalSec / maxSec : 0
+    readonly property real remainRatio: (running && totalSec > 0) ? remainSec / totalSec : 1
+    readonly property real angle: -Math.PI / 2 + 2 * Math.PI * progress * remainRatio
+
+    readonly property real cx: width / 2
+    readonly property real cy: height / 2
+    readonly property real r: Math.min(cx, cy) - 15
+
+    readonly property real handleX: cx + r * Math.cos(angle)
+    readonly property real handleY: cy + r * Math.sin(angle)
+
+    readonly property color trackColor: "#b3b3b3"
+    readonly property color activeColor: running ? errorColorOverride : accentColorOverride
+    readonly property color fillColor: running
+        ? Qt.rgba(errorColorOverride.r, errorColorOverride.g, errorColorOverride.b, 0.3)
+        : Qt.rgba(0.6, 0.6, 0.6, 0.2)
+
+    Shape {
+        anchors.fill: parent
+        antialiasing: true
+        smooth: true
+
+        ShapePath {
+            strokeWidth: 10
+            strokeColor: root.trackColor
+            fillColor: "transparent"
+            capStyle: ShapePath.RoundCap
+            startX: root.cx + root.r
+            startY: root.cy
+
+            PathArc {
+                x: root.cx + root.r
+                y: root.cy - 0.001
+                radiusX: root.r
+                radiusY: root.r
+                useLargeArc: true
+                direction: PathArc.Clockwise
+            }
+        }
+    }
+
+    Shape {
+        anchors.fill: parent
+        antialiasing: true
+        smooth: true
+        visible: root.totalSec > 0
+
+        ShapePath {
+            strokeColor: "transparent"
+            fillColor: root.fillColor
+
+            startX: root.cx
+            startY: root.cy
+
+            PathLine {
+                x: root.cx
+                y: root.cy - root.r
+            }
+
+            PathArc {
+                x: root.handleX
+                y: root.handleY
+                radiusX: root.r
+                radiusY: root.r
+                useLargeArc: (root.angle + Math.PI / 2) > Math.PI
+                direction: PathArc.Clockwise
+            }
+
+            PathLine {
+                x: root.cx
+                y: root.cy
+            }
+        }
+    }
+
+    Shape {
+        anchors.fill: parent
+        antialiasing: true
+        smooth: true
+        visible: root.totalSec > 0
+
+        ShapePath {
+            strokeWidth: 10
+            strokeColor: root.activeColor
+            fillColor: "transparent"
+            capStyle: ShapePath.RoundCap
+
+            startX: root.cx
+            startY: root.cy - root.r
+
+            PathArc {
+                x: root.handleX
+                y: root.handleY
+                radiusX: root.r
+                radiusY: root.r
+                useLargeArc: (root.angle + Math.PI / 2) > Math.PI
+                direction: PathArc.Clockwise
+            }
+        }
+    }
+
+    Rectangle {
+        visible: root.totalSec > 0
+        x: root.handleX - 8
+        y: root.handleY - 8
+        width: 16
+        height: 16
+        radius: 8
+        color: root.activeColor
+        antialiasing: true
+    }
+
+    MouseArea {
+        id: mouseArea
+        anchors.fill: parent
+
+        property bool dialing: false
+
+        function processPoint(px, py) {
+            const dx = px - root.cx
+            const dy = py - root.cy
+
+            if (Math.sqrt(dx * dx + dy * dy) < 15) {
+                return
+            }
+
+            let a = Math.atan2(dy, dx) + Math.PI / 2
+            if (a < 0) {
+                a += 2 * Math.PI
+            }
+
+            let intervals = Math.floor((a / (2 * Math.PI)) * 120)
+            if (intervals === 0) {
+                intervals = 120
+            }
+
+            const newTotal = intervals * 30
+            root.dialed(newTotal)
+        }
+
+        onPressed: function (mouse) {
+            dialing = true
+            processPoint(mouse.x, mouse.y)
+        }
+
+        onPositionChanged: function (mouse) {
+            if (dialing) {
+                processPoint(mouse.x, mouse.y)
+            }
+        }
+
+        onReleased: {
+            if (dialing) {
+                dialing = false
+                root.dialReleased()
+            }
+        }
+    }
+}
