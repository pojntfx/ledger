diff --git a/qt/qml/android/main.qml b/qt/qml/android/main.qml
new file mode 100644
index 0000000000000000000000000000000000000000..b84ad12b35ee28eef0683f1d8291e2ccfaf65e7d
--- /dev/null
+++ b/qt/qml/android/main.qml
@@ -0,0 +1,256 @@
+import QtQuick
+import QtCore
+import QtQuick.Controls as QQC2
+import QtQuick.Window
+import QtQuick.Layouts
+
+QQC2.ApplicationWindow {
+    id: root
+
+    visible: true
+    title: "Sessions"
+
+    width: 420
+    height: 640
+
+    readonly property int minDialValue: 30
+    readonly property int maxDialValue: 3600
+
+    property int totalSec: 300
+    property bool running: false
+    property real remainSec: 0
+    property bool paused: false
+
+    Settings {
+        id: settings
+        property int lastPosition: 300
+    }
+
+    Component.onCompleted: {
+        const v = settings.lastPosition
+        if (v >= minDialValue && v <= maxDialValue) {
+            totalSec = v
+        }
+    }
+
+    function saveLastPosition() {
+        settings.lastPosition = totalSec
+    }
+
+    // Audio playback is intentionally omitted on Android: the Qt for
+    // Android distribution shipped by the upstream miqt docker image does
+    // not include QtMultimedia, so we cannot use MediaPlayer or
+    // SoundEffect here. The system notification (showMessage) provides
+    // its own sound and vibration, which is sufficient on mobile.
+    function playAlarm() {}
+    function stopAlarm() {}
+
+    Timer {
+        id: countdown
+        interval: 1000
+        repeat: true
+        onTriggered: {
+            remainSec -= 1
+            if (remainSec <= 0) {
+                running = false
+                stop()
+                playAlarm()
+                if (hasTrayIcon) {
+                    trayIcon.showMessage("Session finished", "Time to take a break", 1, 5000)
+                }
+            }
+        }
+    }
+
+    function startTimer() {
+        stopAlarm()
+        running = true
+        remainSec = totalSec
+        countdown.start()
+    }
+
+    function stopTimer() {
+        running = false
+        countdown.stop()
+        stopAlarm()
+    }
+
+    function toggleTimer() {
+        if (running) {
+            stopTimer()
+        } else if (totalSec > 0) {
+            startTimer()
+        }
+    }
+
+    function addTime() {
+        if (totalSec < maxDialValue) {
+            totalSec += minDialValue
+            if (running) {
+                remainSec = totalSec
+            }
+            saveLastPosition()
+        }
+    }
+
+    function removeTime() {
+        if (totalSec > minDialValue) {
+            totalSec -= minDialValue
+            if (running) {
+                remainSec = totalSec
+            }
+            saveLastPosition()
+        }
+    }
+
+    function formatTime(seconds) {
+        const m = Math.floor(seconds / 60)
+        const s = Math.floor(seconds % 60)
+        return (m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s)
+    }
+
+    header: QQC2.ToolBar {
+        RowLayout {
+            anchors.fill: parent
+            QQC2.Label {
+                text: "Sessions"
+                Layout.leftMargin: 16
+                font.pixelSize: 20
+                font.bold: true
+                Layout.fillWidth: true
+            }
+            QQC2.ToolButton {
+                text: "About"
+                onClicked: aboutDialog.open()
+            }
+        }
+    }
+
+    QQC2.Dialog {
+        id: aboutDialog
+        modal: true
+        anchors.centerIn: parent
+        width: Math.min(parent.width - 40, 400)
+        title: "About " + appName
+
+        ColumnLayout {
+            spacing: 12
+            anchors.fill: parent
+
+            QQC2.Label {
+                text: appName
+                font.pixelSize: 22
+                font.bold: true
+                Layout.alignment: Qt.AlignHCenter
+            }
+            QQC2.Label {
+                text: "Version " + appVersion
+                Layout.alignment: Qt.AlignHCenter
+            }
+            QQC2.Label {
+                text: appDescription
+                wrapMode: Text.WordWrap
+                Layout.fillWidth: true
+                horizontalAlignment: Text.AlignHCenter
+            }
+            QQC2.Label {
+                text: "© " + appCopyrightYear + " Felicitas Pojtinger"
+                Layout.alignment: Qt.AlignHCenter
+            }
+            QQC2.Label {
+                text: '<a href="' + appHomepageURL + '">' + appHomepageURL + '</a>'
+                onLinkActivated: link => Qt.openUrlExternally(link)
+                Layout.alignment: Qt.AlignHCenter
+            }
+            QQC2.Label {
+                text: "Licensed under AGPL-3.0-or-later"
+                Layout.alignment: Qt.AlignHCenter
+            }
+        }
+
+        standardButtons: QQC2.Dialog.Close
+    }
+
+    ColumnLayout {
+        anchors.fill: parent
+        anchors.margins: 16
+        spacing: 16
+
+        Item {
+            Layout.fillWidth: true
+            Layout.fillHeight: true
+
+            Dial {
+                id: dialItem
+                anchors.centerIn: parent
+
+                readonly property real maxSize: Math.min(parent.width, parent.height)
+                width: maxSize
+                height: maxSize
+
+                totalSec: root.totalSec
+                maxSec: root.maxDialValue
+                running: root.running
+                remainSec: root.remainSec
+
+                accentColorOverride: "#3daee9"
+                errorColorOverride: "#da4453"
+
+                onDialed: function (newTotal) {
+                    if (root.running && !paused) {
+                        paused = true
+                        countdown.stop()
+                    }
+                    root.totalSec = newTotal
+                    if (paused) {
+                        root.remainSec = newTotal
+                    }
+                    saveLastPosition()
+                }
+
+                onDialReleased: {
+                    if (paused) {
+                        paused = false
+                        if (root.remainSec > 0) {
+                            countdown.start()
+                        }
+                    } else if (!root.running && root.totalSec > 0) {
+                        startTimer()
+                    }
+                }
+            }
+
+            QQC2.Label {
+                anchors.centerIn: parent
+                text: root.running ? formatTime(root.remainSec) : formatTime(root.totalSec)
+                font.pixelSize: 48
+                font.bold: true
+            }
+        }
+
+        RowLayout {
+            Layout.alignment: Qt.AlignHCenter
+            spacing: 16
+
+            QQC2.RoundButton {
+                text: "−"
+                font.pixelSize: 24
+                enabled: root.totalSec > minDialValue
+                onClicked: removeTime()
+            }
+
+            QQC2.Button {
+                text: root.running ? "Stop" : "Start Timer"
+                highlighted: true
+                onClicked: toggleTimer()
+            }
+
+            QQC2.RoundButton {
+                text: "+"
+                font.pixelSize: 24
+                enabled: root.totalSec < maxDialValue
+                onClicked: addTime()
+            }
+        }
+    }
+}
diff --git a/qt/qml/main.qml b/qt/qml/main.qml
new file mode 100644
index 0000000000000000000000000000000000000000..fb1e426e5ecc3f80891e8c6bfb4a7c3bd7e03c79
--- /dev/null
+++ b/qt/qml/main.qml
@@ -0,0 +1,318 @@
+import QtQuick
+import QtCore
+import QtQuick.Controls as QQC2
+import QtQuick.Layouts
+import QtMultimedia
+import org.kde.kirigami as Kirigami
+import org.kde.kirigamiaddons.formcard as FormCard
+
+Kirigami.ApplicationWindow {
+    id: root
+
+    title: "Sessions"
+
+    minimumWidth: 360
+    minimumHeight: 460
+    width: 420
+    height: 520
+
+    readonly property int minDialValue: 30
+    readonly property int maxDialValue: 3600
+
+    property int totalSec: 300
+    property bool running: false
+    property real remainSec: 0
+    property bool paused: false
+
+    Settings {
+        id: settings
+        property int lastPosition: 300
+    }
+
+    Component.onCompleted: {
+        const v = settings.lastPosition
+        if (v >= minDialValue && v <= maxDialValue) {
+            totalSec = v
+        }
+    }
+
+    function saveLastPosition() {
+        settings.lastPosition = totalSec
+    }
+
+    MediaPlayer {
+        id: alarm
+        source: alarmSourceUrl
+        audioOutput: AudioOutput {}
+    }
+
+    function playAlarm() {
+        alarm.position = 0
+        alarm.play()
+    }
+
+    function stopAlarm() {
+        alarm.stop()
+    }
+
+    Timer {
+        id: countdown
+        interval: 1000
+        repeat: true
+        onTriggered: {
+            remainSec -= 1
+            if (remainSec <= 0) {
+                running = false
+                stop()
+                playAlarm()
+                trayIcon.showMessage("Session finished", "Time to take a break", 1, 5000)
+            }
+        }
+    }
+
+    Connections {
+        target: trayIcon
+        function onMessageClicked() {
+            stopAlarm()
+            root.show()
+            root.raise()
+            root.requestActivate()
+        }
+    }
+
+    function startTimer() {
+        stopAlarm()
+        running = true
+        remainSec = totalSec
+        countdown.start()
+    }
+
+    function stopTimer() {
+        running = false
+        countdown.stop()
+        stopAlarm()
+    }
+
+    function toggleTimer() {
+        if (running) {
+            stopTimer()
+        } else if (totalSec > 0) {
+            startTimer()
+        }
+    }
+
+    function addTime() {
+        if (totalSec < maxDialValue) {
+            totalSec += minDialValue
+            if (running) {
+                remainSec = totalSec
+            }
+            saveLastPosition()
+        }
+    }
+
+    function removeTime() {
+        if (totalSec > minDialValue) {
+            totalSec -= minDialValue
+            if (running) {
+                remainSec = totalSec
+            }
+            saveLastPosition()
+        }
+    }
+
+    function formatTime(seconds) {
+        const m = Math.floor(seconds / 60)
+        const s = Math.floor(seconds % 60)
+        return (m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s)
+    }
+
+    globalDrawer: Kirigami.GlobalDrawer {
+        isMenu: true
+        actions: [
+            Kirigami.Action {
+                text: "About Sessions"
+                icon.name: "help-about"
+                onTriggered: pageStack.layers.push(aboutPage)
+            },
+            Kirigami.Action {
+                text: "Quit"
+                icon.name: "application-exit"
+                shortcut: "Ctrl+Q"
+                onTriggered: Qt.quit()
+            }
+        ]
+    }
+
+    QQC2.Action {
+        shortcut: "Space"
+        onTriggered: toggleTimer()
+    }
+    QQC2.Action {
+        shortcut: "Ctrl+Space"
+        onTriggered: toggleTimer()
+    }
+    QQC2.Action {
+        shortcut: "Ctrl++"
+        onTriggered: addTime()
+    }
+    QQC2.Action {
+        shortcut: "Ctrl+="
+        onTriggered: addTime()
+    }
+    QQC2.Action {
+        shortcut: "Ctrl+-"
+        onTriggered: removeTime()
+    }
+    QQC2.Action {
+        shortcut: "Ctrl+W"
+        onTriggered: root.close()
+    }
+
+    pageStack.initialPage: Kirigami.Page {
+        id: timerPage
+        title: "Sessions"
+        padding: Kirigami.Units.largeSpacing
+
+        ColumnLayout {
+            anchors.fill: parent
+            spacing: Kirigami.Units.largeSpacing
+
+            Item {
+                Layout.fillWidth: true
+                Layout.fillHeight: true
+
+                Dial {
+                    id: dialItem
+                    anchors.centerIn: parent
+
+                    readonly property real maxSize: Math.min(parent.width, parent.height)
+                    width: maxSize
+                    height: maxSize
+
+                    totalSec: root.totalSec
+                    maxSec: root.maxDialValue
+                    running: root.running
+                    remainSec: root.remainSec
+
+                    accentColorOverride: Kirigami.Theme.highlightColor
+                    errorColorOverride: Kirigami.Theme.negativeTextColor
+
+                    onDialed: function (newTotal) {
+                        if (root.running && !paused) {
+                            paused = true
+                            countdown.stop()
+                        }
+                        root.totalSec = newTotal
+                        if (paused) {
+                            root.remainSec = newTotal
+                        }
+                        saveLastPosition()
+                    }
+
+                    onDialReleased: {
+                        if (paused) {
+                            paused = false
+                            if (root.remainSec > 0) {
+                                countdown.start()
+                            }
+                        } else if (!root.running && root.totalSec > 0) {
+                            startTimer()
+                        }
+                    }
+                }
+
+                Kirigami.Heading {
+                    anchors.centerIn: parent
+                    level: 1
+                    text: root.running ? formatTime(root.remainSec) : formatTime(root.totalSec)
+
+                    Accessible.name: "Remaining time"
+                }
+            }
+
+            RowLayout {
+                Layout.alignment: Qt.AlignHCenter
+                spacing: Kirigami.Units.largeSpacing
+
+                QQC2.RoundButton {
+                    icon.name: "value-decrease-symbolic"
+                    enabled: root.totalSec > minDialValue
+                    QQC2.ToolTip.visible: hovered
+                    QQC2.ToolTip.text: "Remove 30 seconds"
+                    onClicked: removeTime()
+                }
+
+                QQC2.Button {
+                    text: root.running ? "Stop" : "Start Timer"
+                    icon.name: root.running ? "media-playback-stop-symbolic" : "media-playback-start-symbolic"
+                    highlighted: true
+                    QQC2.ToolTip.visible: hovered
+                    QQC2.ToolTip.text: root.running ? "Stop the timer" : "Start the timer"
+                    onClicked: toggleTimer()
+
+                    palette.button: root.running ? Kirigami.Theme.negativeBackgroundColor : Kirigami.Theme.highlightColor
+                }
+
+                QQC2.RoundButton {
+                    icon.name: "value-increase-symbolic"
+                    enabled: root.totalSec < maxDialValue
+                    QQC2.ToolTip.visible: hovered
+                    QQC2.ToolTip.text: "Add 30 seconds"
+                    onClicked: addTime()
+                }
+            }
+        }
+    }
+
+    Component {
+        id: aboutPage
+
+        FormCard.AboutPage {
+            aboutData: ({
+                "displayName": appName,
+                "productName": appName,
+                "componentName": appName.toLowerCase(),
+                "version": appVersion,
+                "shortDescription": appDescription,
+                "homepage": appHomepageURL,
+                "bugAddress": "https://github.com/pojntfx/sessions/issues",
+                "copyrightStatement": "© " + appCopyrightYear + " Felicitas Pojtinger",
+                "desktopFileName": appID,
+                "licenses": [
+                    {
+                        "name": "AGPL-3.0-or-later",
+                        "spdx": "AGPL-3.0-or-later"
+                    }
+                ],
+                "authors": [
+                    {
+                        "name": "Felicitas Pojtinger",
+                        "task": "Maintainer",
+                        "emailAddress": "",
+                        "webAddress": "https://github.com/pojntfx",
+                        "ocsUsername": ""
+                    },
+                    {
+                        "name": "Guido Günther",
+                        "task": "Developer",
+                        "emailAddress": "",
+                        "webAddress": "",
+                        "ocsUsername": ""
+                    }
+                ],
+                "credits": [
+                    {
+                        "name": "Mirabelle Salles",
+                        "task": "Icon design",
+                        "emailAddress": "",
+                        "webAddress": "",
+                        "ocsUsername": ""
+                    }
+                ],
+                "translators": [],
+                "otherText": ""
+            })
+        }
+    }
+}
