From c7a29c0e1af134bb6349dd0dfbc6094668e889a3 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Tue, 12 Aug 2025 01:47:52 -0700
Subject: [PATCH] refactor: Pin commit for Blueprint and update `po` for locales

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/com.pojtinger.felicitas.Sessions.json b/com.pojtinger.felicitas.Sessions.json
index 96cf733d4e9cf48b2ace4e4ede5a2e8ef4fef558..6ae4d6d20dcd17b6c50911295b03cc47f7f99547 100644
--- a/com.pojtinger.felicitas.Sessions.json
+++ b/com.pojtinger.felicitas.Sessions.json
@@ -28,7 +28,8 @@           "x-checker-data": {
             "type": "git",
             "tag-pattern": "^v([\\d.]+)$",
             "version-scheme": "semantic"
-          }
+          },
+          "commit": "07c9c9df9cd1b6b4454ecba21ee58211e9144a4b"
         }
       ]
     },
@@ -41,7 +42,7 @@         ". /usr/lib/sdk/golang/enable.sh && export GOBIN=\"/app/bin\" && go generate ./... && go install -v -mod=vendor .",
         "desktop-file-install --dir=/app/share/applications assets/meta/$FLATPAK_ID.desktop",
         "install -D -m 0644 assets/resources/metainfo.xml /app/share/metainfo/$FLATPAK_ID.metainfo.xml",
         "install -D -m 0644 assets/meta/icon.svg /app/share/icons/hicolor/scalable/apps/$FLATPAK_ID.svg",
-        "mkdir -p /app/share/locale && cp -r config/locales/* /app/share/locale/"
+        "mkdir -p /app/share/locale && cp -r po/* /app/share/locale/"
       ],
       "sources": [{ "type": "dir", "path": "." }, "go.mod.json"]
     }

