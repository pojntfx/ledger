 				require.NoError(t, tt.prepare(s))
 
@@ -182,7 +193,7 @@ 	for _, tt := range stopDraggingTests {
 		t.Run(
 			tt.name,
 			func(t *testing.T) {
-				s := newStateMachine(0)
+				s := newStateMachine(0, &hooks{})
 
 				require.NoError(t, tt.prepare(s))
 

