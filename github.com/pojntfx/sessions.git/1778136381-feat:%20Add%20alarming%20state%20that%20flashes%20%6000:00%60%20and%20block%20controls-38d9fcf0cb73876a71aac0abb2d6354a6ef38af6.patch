From 38d9fcf0cb73876a71aac0abb2d6354a6ef38af6 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 06 May 2026 23:46:21 -0700
Subject: [PATCH] feat: Add alarming state that flashes `00:00` and block controls

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/resources/style.css b/assets/resources/style.css
index a41ae4b164f2d0bffe350f2e5af39f39a00006cf..a86a767307bd275f93cf12be0bb04e97dbc2102e 100644
--- a/assets/resources/style.css
+++ b/assets/resources/style.css
@@ -6,3 +6,22 @@
 .dial__display {
   font-feature-settings: "tnum";
 }
+
+@media (prefers-reduced-motion: no-preference) {
+  @keyframes dial-display-alarm-blink {
+    0%,
+    49% {
+      opacity: 1;
+    }
+    50%,
+    99% {
+      opacity: 0;
+    }
+    100% {
+      opacity: 1;
+    }
+  }
+  .dial__display--alarming {
+    animation: dial-display-alarm-blink 1s linear infinite;
+  }
+}
