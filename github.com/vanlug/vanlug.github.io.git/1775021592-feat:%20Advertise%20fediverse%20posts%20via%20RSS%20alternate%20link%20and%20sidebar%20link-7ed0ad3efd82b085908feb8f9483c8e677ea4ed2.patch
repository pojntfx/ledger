From 7ed0ad3efd82b085908feb8f9483c8e677ea4ed2 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Tue, 31 Mar 2026 22:33:12 -0700
Subject: [PATCH] feat: Advertise fediverse posts via RSS alternate link and sidebar link

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/data/links.yaml b/data/links.yaml
index 7a32f03c8677f6ec6fd8193136b92f613d458a6b..691d362edc9aebff83c6cf205aae9da39e143fcf 100644
--- a/data/links.yaml
+++ b/data/links.yaml
@@ -30,6 +30,10 @@   - title: Mastodon
     url: https://thecanadian.social/@vanlug
     icon: fa-brands fa-mastodon
     description: Follow us on the fediverse
+  - title: RSS
+    url: https://thecanadian.social/@vanlug.rss
+    icon: fa-solid fa-rss
+    description: Subscribe to our posts
   - title: Bluesky
     url: https://bsky.app/profile/vanlug.thecanadian.social.ap.brid.gy
     icon: fa-brands fa-bluesky
@@ -64,6 +68,8 @@     icon: fa-solid fa-envelope
 donate:
   url: https://www.paypal.com/ncp/payment/5LJ46YPC7JJ7E
   icon: fa-brands fa-paypal
+feed:
+  rss: https://thecanadian.social/@vanlug.rss
 luma:
   calendar: cal-x23GENOxTsZqSMO
   url: https://luma.com/vanlug
diff --git a/layouts/baseof.html b/layouts/baseof.html
index 98bf6816caaa920e1bb1082615a3dfcb5b458aa4..15c5f056a0c38cb8cf0156588810870fc92f67b6 100644
--- a/layouts/baseof.html
+++ b/layouts/baseof.html
@@ -34,6 +34,7 @@
     {{ range .Site.Data.links.me }}
       <link rel="me" href="{{ . }}" />
     {{ end }}
+    <link rel="alternate" type="application/rss+xml" title="Fediverse posts from {{ .Site.Title }}" href="{{ .Site.Data.links.feed.rss }}" />
 
     <meta name="author" content="{{ .Site.Data.site.author }}" />
     <meta name="fediverse:creator" content="@vanlug@thecanadian.social" />

