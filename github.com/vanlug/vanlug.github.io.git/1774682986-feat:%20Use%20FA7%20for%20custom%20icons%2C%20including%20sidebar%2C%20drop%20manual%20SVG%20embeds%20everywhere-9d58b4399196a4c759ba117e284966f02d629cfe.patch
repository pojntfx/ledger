+      rel="stylesheet"
+      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
+      crossorigin="anonymous"
+    />
     <link rel="icon" href="assets/ci/logo.svg" />
     <link rel="me" href="https://thecanadian.social/@vanlug" />
 
@@ -175,7 +185,7 @@                   href="https://discourse.vanlug.ca"
                   target="_blank"
                   rel="noopener"
                   ><span
-                    >Discourse<icon-external></icon-external><br /><small
+                    >Discourse<icon-discourse></icon-discourse><br /><small
                       class="pf-v6-u-font-size-xs pf-v6-u-text-color-subtle"
                       >Our forum for questions &amp; projects</small
                     ></span
@@ -189,7 +199,7 @@                   href="https://signal.group/#CjQKIDT_S1T4NAqQq0UhlMwAVjirsOj6iW1JzpicVudNwr7SEhBRwaLJ9JGEM9CaciluJQdf"
