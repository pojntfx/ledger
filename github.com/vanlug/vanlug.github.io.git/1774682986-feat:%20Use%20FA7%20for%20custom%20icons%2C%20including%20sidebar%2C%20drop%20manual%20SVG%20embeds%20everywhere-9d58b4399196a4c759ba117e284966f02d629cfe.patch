                   ><span
-                    >Signal<icon-external></icon-external><br /><small
+                    >Signal<icon-signal></icon-signal><br /><small
                       class="pf-v6-u-font-size-xs pf-v6-u-text-color-subtle"
                       >Our encrypted group chat</small
                     ></span
@@ -203,7 +213,7 @@                   href="https://thecanadian.social/@vanlug"
                   target="_blank"
                   rel="noopener"
                   ><span
-                    >Mastodon<icon-external></icon-external><br /><small
+                    >Mastodon<icon-mastodon></icon-mastodon><br /><small
                       class="pf-v6-u-font-size-xs pf-v6-u-text-color-subtle"
