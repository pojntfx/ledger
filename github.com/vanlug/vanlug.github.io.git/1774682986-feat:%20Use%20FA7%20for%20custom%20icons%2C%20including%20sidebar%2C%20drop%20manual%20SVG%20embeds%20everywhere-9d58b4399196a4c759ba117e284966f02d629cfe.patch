                     ></span
@@ -217,7 +227,7 @@                   href="https://bsky.app/profile/vanlug.thecanadian.social.ap.brid.gy"
                   target="_blank"
                   rel="noopener"
                   ><span
-                    >Bluesky<icon-external></icon-external><br /><small
