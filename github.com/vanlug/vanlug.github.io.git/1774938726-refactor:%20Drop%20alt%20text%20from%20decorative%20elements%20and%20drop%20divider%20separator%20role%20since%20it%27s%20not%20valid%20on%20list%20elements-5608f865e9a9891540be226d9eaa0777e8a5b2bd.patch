From 5608f865e9a9891540be226d9eaa0777e8a5b2bd Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Mon, 30 Mar 2026 23:32:06 -0700
Subject: [PATCH] refactor: Drop alt text from decorative elements and drop divider separator role since it's not valid on list elements

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/data/content.yaml b/data/content.yaml
index 5235ea20b99d27fb3210134551a7e0577ae00a5f..6dc5b7e32bca2df849a42920cb3b6bba2465f1b3 100644
--- a/data/content.yaml
+++ b/data/content.yaml
@@ -33,9 +33,7 @@     events:
       - title: 2026 Cloud Summit
         date: May 1, 2026
         url: https://cloudsummit.ca
-        image:
-          src: img/cloudsummit-2026.jpg
-          alt: 2026 Cloud Summit venue in Vancouver
+        image: img/cloudsummit-2026.jpg
 
 events:
   past:
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index 8aafc5f6971e58e0d3d9ccbe14fdcad63a92adbd..4bebd18419a2c3d56464562337c5b55c5a88bbe4 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -191,12 +191,10 @@             {{ range .events }}
               <div
                 class="pf-v6-c-card pf-m-compact"
                 style="
-                  background-image: url('{{ .image.src | relURL }}');
+                  background-image: url('{{ .image | relURL }}');
                   background-size: cover;
                   background-position: center;
                 "
-                role="img"
-                aria-label="{{ .image.alt }}"
               >
                 <div class="pf-v6-c-card__body pf-v6-l-flex pf-m-column pf-m-justify-content-flex-end pf-m-gap-sm" style="
                   background: linear-gradient(color-mix(in srgb, var(--pf-t--global--background--color--primary--default) 40%, transparent) 0%, color-mix(in srgb, var(--pf-t--global--background--color--primary--default) 80%, transparent) 50%, var(--pf-t--global--background--color--primary--default) 100%);
diff --git a/layouts/_partials/sidebar.html b/layouts/_partials/sidebar.html
index b52b25abbf3757fcf2189729c0ad6c756af470f4..7302da9cba708c855ebdeb83b318e7962d391342 100644
--- a/layouts/_partials/sidebar.html
+++ b/layouts/_partials/sidebar.html
@@ -5,7 +5,7 @@       <ul class="pf-v6-c-nav__list" role="list">
         {{ $current := $.RelPermalink }}
         {{ range .Site.Data.links.sidebar }}
           {{ if .separator }}
-            <li class="pf-v6-c-divider" role="separator"></li>
+            <li class="pf-v6-c-divider" role="presentation"></li>
           {{ else if .url }}
             <li class="pf-v6-c-nav__item">
               <a

