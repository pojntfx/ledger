From bed6992bcc5a3046907f4139e8c14e870db9f779 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 01 Apr 2026 00:15:17 -0700
Subject: [PATCH] fix: Drop trailing slash from proxy URL and use `api` instead of `proxy` consistently

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/js/luma-next-event.js b/assets/js/luma-next-event.js
index aa327da6b9b27e8f179037bf0f7e6f2a4d86bd83..cb6e1592ed8501b167d23ffff70ecd1b3cabb023 100644
--- a/assets/js/luma-next-event.js
+++ b/assets/js/luma-next-event.js
@@ -60,10 +60,10 @@   "luma-next-event",
   class extends HTMLElement {
     async connectedCallback() {
       const cal = this.getAttribute("calendar");
-      const proxy = this.getAttribute("proxy");
+      const api = this.getAttribute("api");
       try {
         const { entries } = await fetch(
-          `${proxy}/next-event?calendar=${encodeURIComponent(cal)}`,
+          `${api}/next-event?calendar=${encodeURIComponent(cal)}`,
         ).then((r) => r.json());
         const evt = entries?.[0];
         if (!evt) {
diff --git a/assets/js/luma-upcoming-events.js b/assets/js/luma-upcoming-events.js
index d5959c6a25a5040f21cc751d8e62e1dca85ab212..4f3d23a74bb04bbbae1ef59423d31a7d6f7a141f 100644
--- a/assets/js/luma-upcoming-events.js
+++ b/assets/js/luma-upcoming-events.js
@@ -51,10 +51,10 @@   "luma-upcoming-events",
   class extends HTMLElement {
     async connectedCallback() {
       const cal = this.getAttribute("calendar");
-      const proxy = this.getAttribute("proxy");
+      const api = this.getAttribute("api");
       try {
         const { entries } = await fetch(
-          `${proxy}/events?calendar=${encodeURIComponent(cal)}`,
+          `${api}/events?calendar=${encodeURIComponent(cal)}`,
         ).then((r) => r.json());
         if (!entries?.length) {
           this.textContent = "No upcoming events right now. Check back soon!";
