From 1706875edec7f8c72a1bcf99de1dbd826dc7cd02 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Tue, 31 Mar 2026 22:36:09 -0700
Subject: [PATCH] feat: Add background to header

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/data/resources.yaml b/data/resources.yaml
index b10725984cc3643194232b17144acf0bf18bbc5b..777f4f8d6d9ab0792314553f5e130ecd4d66d56d 100644
--- a/data/resources.yaml
+++ b/data/resources.yaml
@@ -141,7 +141,7 @@       description: "VanLUG icon (Tux with Vancouver flag stripes)"
     - name: logo
       description: "VanLUG logo (icon + wordmark for cards)"
     - name: header
-      description: "Banner header for Luma and OpenGraph"
+      description: "Banner header for Luma, OpenGraph and the home page background"
       photo:
         credit: "Lee Robinson"
         url: https://unsplash.com/photos/Yc9h5SJdEzI
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index 4bebd18419a2c3d56464562337c5b55c5a88bbe4..89bf0f83ea806a73e170955aec14de85091526b3 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -2,9 +2,7 @@ {{ $c := .Site.Data.content.home }}
   <section
     class="pf-v6-c-page__main-section pf-m-limit-width pf-m-align-center"
     style="
-      --pf-v6-c-page__main-section--BackgroundColor: var(
-        --pf-t--global--background--color--secondary--default
-      );
+      background: linear-gradient(color-mix(in srgb, var(--pf-t--global--background--color--primary--default) 80%, transparent) 0%, var(--pf-t--global--background--color--primary--default) 100%), url('{{ "design/lee-robinson-Yc9h5SJdEzI-unsplash.jpg" | relURL }}') center / cover;
       padding-block: var(--pf-t--global--spacer--3xl);
     "
   >

