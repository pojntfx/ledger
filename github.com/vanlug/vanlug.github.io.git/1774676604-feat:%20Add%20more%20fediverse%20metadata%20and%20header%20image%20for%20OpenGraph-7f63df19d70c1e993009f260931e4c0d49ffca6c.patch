From 7f63df19d70c1e993009f260931e4c0d49ffca6c Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Fri, 27 Mar 2026 22:43:24 -0700
Subject: [PATCH] feat: Add more fediverse metadata and header image for OpenGraph

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/img/header.png b/assets/img/header.png
new file mode 100644
index 0000000000000000000000000000000000000000..686ad90380f1e89cf5256992b23c828e20aff9a1
Binary files /dev/null and b/assets/img/header.png differ
diff --git a/index.html b/index.html
index 030fee5c7b9ab094cca7604933a161b1571ae24d..113a6337e8828fdc62c6f13527af5069de514d12 100644
--- a/index.html
+++ b/index.html
@@ -16,6 +16,29 @@       crossorigin="anonymous"
     />
     <link rel="icon" href="assets/img/logo.svg" />
     <link rel="me" href="https://thecanadian.social/@vanlug" />
+
+    <meta name="author" content="VanLUG" />
+    <meta name="fediverse:creator" content="@vanlug@thecanadian.social" />
+    <meta
+      name="description"
+      content="VanLUG is a non-profit user group for Linux professionals, hobbyists, and curious newcomers in the Greater Vancouver area."
+    />
+    <meta
+      name="keywords"
+      content="VanLUG, Vancouver, Linux, Users Group, Open Source, Free Software, LUG, British Columbia, Meetup"
+    />
+    <meta name="copyright" content="© 2026 Vancouver Linux Users Group" />
+
+    <meta property="og:title" content="VanLUG: Vancouver Linux Users Group" />
+    <meta
+      property="og:description"
+      content="VanLUG is a non-profit user group for Linux professionals, hobbyists, and curious newcomers in the Greater Vancouver area."
+    />
+    <meta property="og:image" content="/assets/img/header.png" />
+    <meta property="og:url" content="https://vanlug.github.io/" />
+    <meta property="og:type" content="website" />
+    <meta property="og:site_name" content="VanLUG" />
+    <meta property="og:locale" content="en_CA" />
   </head>
 
   <body>

