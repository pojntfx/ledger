diff --git a/assets/js/mastodon-feed.js b/assets/js/mastodon-feed.js
index 14cfbdb0f69041450b705290c1364d5a8ca8ff2e..6b9842a81838fbb6b64ab5d41a2a253ab9c8aab8 100644
