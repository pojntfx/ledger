From 026610d7375bc8b221865cf20f3b58538c0a6a74 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 03 Jun 2026 00:18:11 -0700
Subject: [PATCH] docs: Bump language code and license etc. conventions

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/README.md b/README.md
index 71c41c67be59b9e7903593d41c832267b825892c..a11c1a54c533619e04e672477f9f29449ced1d74 100644
--- a/README.md
+++ b/README.md
@@ -75,4 +75,4 @@ ## License
 
 vanlug.ca (c) 2026 Felicitas Pojtinger and contributors
 
-SPDX-License-Identifier: AGPL-3.0
+SPDX-License-Identifier: AGPL-3.0-or-later
diff --git a/data/site.yaml b/data/site.yaml
index d7fcc6e212732bb76f4986a7ca733ef833e0618f..eba57a038e76accfd069ed08b3e693814b5f25f5 100644
--- a/data/site.yaml
+++ b/data/site.yaml
@@ -11,3 +11,4 @@   - LUG
   - British Columbia
   - Meetup
 source: https://github.com/vanlug/vanlug.github.io
+license: AGPL-3.0-or-later
diff --git a/layouts/_partials/footer.html b/layouts/_partials/footer.html
index 6c2e8cfe587409d43b3a04e09e5f826993daed3f..8c90ada11a582ac92fab72ab8ed538a0f8271af6 100644
--- a/layouts/_partials/footer.html
+++ b/layouts/_partials/footer.html
@@ -59,7 +59,7 @@               <a
                 href="{{ .Site.Data.site.source }}/blob/main/LICENSE"
                 target="_blank"
                 rel="noopener"
-                >AGPL-3.0-or-later{{ partial "icon" "external" }}</a
+                >{{ .Site.Data.site.license }}{{ partial "icon" "external" }}</a
               >. See our <a href="{{ "/terms/" | relURL }}">terms</a> and
               <a href="{{ "/privacy/" | relURL }}">privacy policy</a>.</small
             >
diff --git a/layouts/baseof.html b/layouts/baseof.html
index 18df54718ea4b7b06da0f68f64b1e8354ca92949..aec471eef1695e4ae78be736f0c742f21f7c3751 100644
--- a/layouts/baseof.html
+++ b/layouts/baseof.html
@@ -49,7 +49,7 @@       content="{{ delimit .Site.Data.site.keywords `, ` }}"
     />
     <meta
       name="copyright"
-      content="© {{ now.Year }} Vancouver Linux Users Group"
+      content="© {{ now.Year }} {{ .Site.Data.site.author }} ({{ .Site.Data.site.license }})"
     />
 
     <meta property="og:title" content="{{ .Site.Title }}" />
@@ -61,11 +61,7 @@     <meta property="og:image" content="/design/header.png" />
     <meta property="og:url" content="{{ .Site.BaseURL }}" />
     <meta property="og:type" content="website" />
     <meta property="og:site_name" content="{{ .Site.Data.site.author }}" />
-    <meta property="og:locale" content="en_CA" />
-    <script>
-      if (matchMedia("(prefers-color-scheme: dark)").matches)
-        document.documentElement.classList.add("pf-v6-theme-dark");
-    </script>
+    <meta property="og:locale" content="{{ .Site.Language.LanguageCode }}" />
     {{ with resources.Get "js/head.js" }}
       {{ $opts := dict
         "minify" (not hugo.IsDevelopment)

