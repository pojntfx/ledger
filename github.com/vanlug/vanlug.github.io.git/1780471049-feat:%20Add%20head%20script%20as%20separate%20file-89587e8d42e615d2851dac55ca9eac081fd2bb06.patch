From 89587e8d42e615d2851dac55ca9eac081fd2bb06 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 03 Jun 2026 00:17:29 -0700
Subject: [PATCH] feat: Add head script as separate file

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/js/main.js b/assets/js/main.js
index de978aef574e064c1623745943af88c1f0340a70..cfb4bfdc1f46be583072ebd3000a4f5706a5d962 100644
--- a/assets/js/main.js
+++ b/assets/js/main.js
@@ -1,4 +1,3 @@
-import "./theme.js";
 import "./sidebar.js";
 import "./event-detail-modal.js";
 import "./luma-next-event.js";
diff --git a/assets/js/theme.js b/assets/js/head.js
rename from assets/js/theme.js
rename to assets/js/head.js
diff --git a/layouts/baseof.html b/layouts/baseof.html
index 4ddd1273179eb1ac24038a47387c99ad574f2181..18df54718ea4b7b06da0f68f64b1e8354ca92949 100644
--- a/layouts/baseof.html
+++ b/layouts/baseof.html
@@ -66,6 +66,21 @@     <script>
       if (matchMedia("(prefers-color-scheme: dark)").matches)
         document.documentElement.classList.add("pf-v6-theme-dark");
     </script>
+    {{ with resources.Get "js/head.js" }}
+      {{ $opts := dict
+        "minify" (not hugo.IsDevelopment)
+        "sourceMap" (cond hugo.IsDevelopment "linked" "none")
+      }}
+      {{ with . | js.Build $opts }}
+        {{ if hugo.IsDevelopment }}
+          <script src="{{ .RelPermalink }}"></script>
+        {{ else }}
+          {{ with . | fingerprint }}
+            <script src="{{ .RelPermalink }}" integrity="{{ .Data.Integrity }}" crossorigin="anonymous"></script>
+          {{ end }}
+        {{ end }}
+      {{ end }}
+    {{ end }}
     <noscript>
       {{ with resources.Get "scss/noscript.scss" | toCSS (dict "outputStyle" "compressed") }}
         {{ if hugo.IsDevelopment }}

