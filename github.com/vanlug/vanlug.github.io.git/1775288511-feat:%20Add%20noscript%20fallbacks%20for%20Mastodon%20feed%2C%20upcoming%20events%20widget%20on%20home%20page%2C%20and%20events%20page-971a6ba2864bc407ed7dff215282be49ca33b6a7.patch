From 971a6ba2864bc407ed7dff215282be49ca33b6a7 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Sat, 04 Apr 2026 00:41:51 -0700
Subject: [PATCH] feat: Add noscript fallbacks for Mastodon feed, upcoming events widget on home page, and events page

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/layouts/_partials/mastodon-feed.html b/layouts/_partials/mastodon-feed.html
index ef206418ce2da38d0877d148dec2231498b8d16b..6405a94282c5979c06f12bc4e990ad2434670dad 100644
--- a/layouts/_partials/mastodon-feed.html
+++ b/layouts/_partials/mastodon-feed.html
@@ -18,7 +18,7 @@     username="{{ .Site.Data.links.socials.mastodon.username }}"
     api="{{ .Site.Data.links.api }}"
     profile="{{ .Site.Data.links.socials.mastodon.url }}"
   >
-    <div class="pf-v6-l-flex pf-m-column pf-m-gap-sm">
+    <div class="pf-v6-l-flex pf-m-column pf-m-gap-sm js-only">
       {{ range (seq 3) }}
         <div>
           <div class="pf-v6-c-skeleton pf-m-text-sm pf-v6-u-mb-sm"></div>
@@ -26,6 +26,20 @@           <div class="pf-v6-c-skeleton pf-m-text-sm pf-m-width-75"></div>
           <div class="pf-v6-c-skeleton pf-m-text-xs pf-m-width-50 pf-v6-u-mt-sm"></div>
         </div>
       {{ end }}
+    </div>
+    <div class="noscript-only">
+      <div class="pf-v6-c-empty-state pf-m-xs">
+        <div class="pf-v6-c-empty-state__content">
+          <div class="pf-v6-c-empty-state__header">
+            <div class="pf-v6-c-empty-state__icon pf-v6-u-font-size-xl pf-v6-u-mb-sm">
+              <i class="fa-brands fa-mastodon" aria-hidden="true"></i>
+            </div>
+            <div class="pf-v6-c-empty-state__title">
+              <p class="pf-v6-c-empty-state__title-text pf-v6-u-font-size-sm">JavaScript is required to load the feed.</p>
+            </div>
+          </div>
+        </div>
+      </div>
     </div>
   </mastodon-feed>
   <div class="pf-v6-c-content pf-v6-u-font-size-sm pf-v6-u-text-align-center pf-v6-u-pb-sm">
diff --git a/layouts/_partials/section-events.html b/layouts/_partials/section-events.html
index 50205cee209aa27a0ed65e4030773ef16300144c..dfa1bd41caf4df968413091921aa3f9aeac448a7 100644
--- a/layouts/_partials/section-events.html
+++ b/layouts/_partials/section-events.html
@@ -62,7 +62,7 @@             api="{{ .Site.Data.links.api }}"
             luma="{{ .Site.Data.links.luma.url }}"
           >
             <table
-              class="pf-v6-c-table pf-m-grid-md pf-m-compact"
+              class="pf-v6-c-table pf-m-grid-md pf-m-compact js-only"
               role="grid"
               aria-label="Upcoming events"
             >
@@ -87,6 +87,24 @@                   </tr>
                 {{ end }}
               </tbody>
             </table>
+            <div class="noscript-only">
+              <div class="pf-v6-c-empty-state pf-m-xs">
+                <div class="pf-v6-c-empty-state__content">
+                  <div class="pf-v6-c-empty-state__header">
+                    <div class="pf-v6-c-empty-state__icon pf-v6-u-font-size-xl pf-v6-u-mb-sm">
+                      <i class="fas fa-calendar" aria-hidden="true"></i>
+                    </div>
+                    <div class="pf-v6-c-empty-state__title">
+                      <p class="pf-v6-c-empty-state__title-text pf-v6-u-font-size-sm">JavaScript is required to load the events list.</p>
+                    </div>
+                  </div>
+                  <div class="pf-v6-c-empty-state__body pf-v6-u-font-size-sm">
+                    View upcoming events on
+                    <a href="{{ .Site.Data.links.luma.url }}" target="_blank" rel="noopener">Luma</a>.
+                  </div>
+                </div>
+              </div>
+            </div>
           </luma-upcoming-events>
         </div>
       </section>
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index c9aed52e9536f7e167a6305b46d880efcc2ae3ac..2854fb67e37a2eac8893a93389370d1c51a3072b 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -64,7 +64,7 @@       <luma-next-event
         calendar="{{ .Site.Data.links.luma.calendar }}"
         api="{{ .Site.Data.links.api }}"
       >
-        <div class="pf-v6-c-card pf-m-compact pf-m-flat">
+        <div class="pf-v6-c-card pf-m-compact pf-m-flat js-only">
           <div class="pf-v6-c-card__header">
             <div class="pf-v6-c-card__header-main">
               <div
@@ -89,6 +89,24 @@                   <div
                     class="pf-v6-c-skeleton pf-m-text-sm pf-m-width-75"
                   ></div>
                 </div>
+              </div>
+            </div>
+          </div>
+        </div>
+        <div class="noscript-only">
+          <div class="pf-v6-c-empty-state pf-m-xs">
+            <div class="pf-v6-c-empty-state__content">
+              <div class="pf-v6-c-empty-state__header">
+                <div class="pf-v6-c-empty-state__icon pf-v6-u-font-size-xl pf-v6-u-mb-sm">
+                  <i class="fas fa-calendar" aria-hidden="true"></i>
+                </div>
+                <div class="pf-v6-c-empty-state__title">
+                  <p class="pf-v6-c-empty-state__title-text pf-v6-u-font-size-sm">JavaScript is required to load event details.</p>
+                </div>
+              </div>
+              <div class="pf-v6-c-empty-state__body pf-v6-u-font-size-sm">
+                View our next event on
+                <a href="{{ .Site.Data.links.luma.url }}" target="_blank" rel="noopener">Luma</a>.
               </div>
             </div>
           </div>
diff --git a/layouts/baseof.html b/layouts/baseof.html
index 23390f491b681be19a3e06b5708c7f64f13af074..4993c9fb787e337a218c461769286ff763334895 100644
--- a/layouts/baseof.html
+++ b/layouts/baseof.html
@@ -63,6 +63,17 @@     <script>
       if (matchMedia("(prefers-color-scheme: dark)").matches)
         document.documentElement.classList.add("pf-v6-theme-dark");
     </script>
+    <noscript>
+      {{ with resources.Get "scss/noscript.scss" | toCSS (dict "outputStyle" "compressed") }}
+        {{ if hugo.IsDevelopment }}
+          <link rel="stylesheet" href="{{ .RelPermalink }}" />
+        {{ else }}
+          {{ with . | fingerprint }}
+            <link rel="stylesheet" href="{{ .RelPermalink }}" integrity="{{ .Data.Integrity }}" crossorigin="anonymous" />
+          {{ end }}
+        {{ end }}
+      {{ end }}
+    </noscript>
   </head>
 
   <body>

