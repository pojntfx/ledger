 	for _, entry := range lr.Entries {
 		evt := entry.Event
 
@@ -82,7 +83,7 @@ 				loc = evt.GeoAddr.ShortAddress
 			}
 		}
 
-		output.Entries = append(output.Entries, EventItem{
+		items = append(items, EventItem{
 			Name:     evt.Name,
 			StartAt:  evt.StartAt,
 			URL:      evt.URL,
@@ -91,7 +92,18 @@ 			CoverURL: evt.CoverURL,
 		})
