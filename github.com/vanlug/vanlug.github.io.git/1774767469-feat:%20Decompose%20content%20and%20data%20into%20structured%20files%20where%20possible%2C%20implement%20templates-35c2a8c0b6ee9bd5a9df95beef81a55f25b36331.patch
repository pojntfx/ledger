+              <ul>
+                {{ range .Site.Data.resources.learning.intermediate }}
+                  <li>
+                    <a
+                      href="{{ .url }}"
+                      target="_blank"
+                      rel="noopener"
+                      >{{ .title }}<icon-external
+                      ></icon-external
+                    ></a>
+                    {{ with .note }}({{ . }}){{ end }}
+                  </li>
+                {{ end }}
+              </ul>
+            </div>
+          </div>
+        </div>
+        <div
+          class="pf-v6-c-card pf-m-compact pf-v6-u-flex-1"
+          style="min-width: 15rem"
+        >
+          <div class="pf-v6-c-card__title">
+            <div class="pf-v6-c-card__title-text">
+              Distros &amp; video guides
+            </div>
+          </div>
+          <div class="pf-v6-c-card__body">
+            <div class="pf-v6-c-content">
+              <ul>
+                {{ range .Site.Data.resources.learning.distros }}
+                  <li>
+                    <a
+                      href="{{ .url }}"
+                      target="_blank"
+                      rel="noopener"
+                      >{{ .title }}<icon-external
