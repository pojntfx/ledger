diff --git a/layouts/_partials/section-about.html b/layouts/_partials/section-about.html
new file mode 100644
index 0000000000000000000000000000000000000000..a44de731af97e3c59cb18fce642cdd238e832fe1
--- /dev/null
+++ b/layouts/_partials/section-about.html
@@ -0,0 +1,77 @@
+{{ $c := .Site.Data.content.about }}
+  <section
+    class="pf-v6-c-page__main-section pf-m-limit-width pf-m-align-center"
+  >
+    <div
+      class="pf-v6-c-page__main-body pf-v6-l-flex pf-m-column pf-m-gap-md"
+    >
+      <div class="pf-v6-c-content">
+        <h1>{{ .Title }}</h1>
+        {{ .Content }}
+      </div>
+      <div class="pf-v6-l-gallery pf-m-gutter">
+        {{ range $c.images }}
+          <img
+            src="{{ .src | relURL }}"
+            alt="{{ .alt }}"
+            style="
+              border-radius: var(
+                --pf-t--global--border--radius--medium
+              );
+            "
+          />
+        {{ end }}
+      </div>
+      <div class="pf-v6-c-content">
+        <h3>{{ .Site.Data.content.about.purpose.title | default "Our purpose" }}</h3>
+        <p>{{ .Site.Data.content.about.purpose.preamble | default "We exist to fulfil the following mandates:" }}</p>
+        <ol type="a">
+          {{ range .Site.Data.content.about.purpose.mandates }}
+            <li>{{ . }}</li>
+          {{ end }}
+        </ol>
+      </div>
+    </div>
+  </section>
+
+  <section
+    class="pf-v6-c-page__main-section pf-m-limit-width pf-m-align-center"
+  >
+    <div
+      class="pf-v6-c-page__main-body pf-v6-l-flex pf-m-column pf-m-gap-md"
+    >
+      <div class="pf-v6-c-content">
+        <h3>{{ .Site.Data.board.year }} Board of Directors</h3>
+        <p>
+          {{ .Site.Data.content.about.board.preamble | default "As a registered non-profit society in British Columbia, VanLUG is governed by a volunteer Board of Directors. Elections are held annually at our AGM. New volunteers are always welcome." }}
+          <a href="{{ .Site.Data.links.socials.email.url }}"
+            >Get in touch<icon-email></icon-email
+          ></a>
+          if you'd like to help.
+        </p>
+      </div>
+      <dl class="pf-v6-c-description-list pf-m-horizontal">
+        {{ range .Site.Data.board.members }}
+          <div class="pf-v6-c-description-list__group">
+            <dt class="pf-v6-c-description-list__term">
+              <span class="pf-v6-c-description-list__text"
+                >{{ .role }}</span
+              >
+            </dt>
+            <dd class="pf-v6-c-description-list__description">
+              <div class="pf-v6-c-description-list__text">
+                {{ .name }}
+              </div>
+            </dd>
+          </div>
+        {{ end }}
+      </dl>
+      <div class="pf-v6-c-content">
+        <p>
+          See our
+          <a href="{{ "/resources/" | relURL }}">Design System</a> on the Resources page
+          for VanLUG's icon, logo, fonts, colours, and design assets.
+        </p>
+      </div>
+    </div>
+  </section>
diff --git a/layouts/_partials/section-events.html b/layouts/_partials/section-events.html
new file mode 100644
index 0000000000000000000000000000000000000000..ea2e4b4c2280ebccf68641d09d2c2092cd0e7039
--- /dev/null
+++ b/layouts/_partials/section-events.html
@@ -0,0 +1,145 @@
+{{ $c := .Site.Data.content.events }}
+  <section
+    class="pf-v6-c-page__main-section pf-m-limit-width pf-m-align-center"
+  >
+    <div
+      class="pf-v6-c-page__main-body pf-v6-l-flex pf-m-column pf-m-gap-md"
+    >
+      <div class="pf-v6-c-content">
+        <h1>{{ .Title }}</h1>
+        {{ .Content }}
+      </div>
+    </div>
+  </section>
+
+  <section
+    class="pf-v6-c-page__main-section pf-m-limit-width pf-m-align-center"
+  >
+    <div
+      class="pf-v6-c-page__main-body pf-v6-l-flex pf-m-column pf-m-gap-md"
+    >
+      <div class="pf-v6-c-content">
+        <h3>Upcoming</h3>
+        <p>
+          All upcoming events are listed on our
+          <a
+            href="{{ .Site.Data.links.luma.url }}"
+            target="_blank"
+            rel="noopener"
+            >Luma calendar<icon-external></icon-external></a
+          >. RSVP there to get reminders.
+        </p>
+      </div>
+      <luma-embed calendar="{{ .Site.Data.links.luma.calendar }}">
+        <div class="pf-v6-c-empty-state">
+          <div class="pf-v6-c-empty-state__content">
+            <div class="pf-v6-c-empty-state__icon">
+              <i class="fas fa-shield-alt" aria-hidden="true"></i>
+            </div>
+            <div class="pf-v6-c-empty-state__title-text">
+              External content
+            </div>
+            <div class="pf-v6-c-empty-state__body">
+              The event calendar is hosted by Luma. Loading it will
+              connect your browser to their servers. See Luma's
+              <a
+                href="https://luma.com/privacy-policy"
+                target="_blank"
+                rel="noopener"
+                >privacy policy<icon-external></icon-external></a
+              >.
+            </div>
+            <div class="pf-v6-c-empty-state__footer">
+              <div class="pf-v6-c-empty-state__actions">
+                <button
+                  class="pf-v6-c-button pf-m-primary"
+                  type="button"
+                  data-slot="load"
+                >
+                  Load events from Luma
+                </button>
+              </div>
+              <a
+                href="{{ .Site.Data.links.luma.url }}"
+                target="_blank"
+                rel="noopener"
+                class="pf-v6-c-button pf-m-link"
+                ><span class="pf-v6-c-button__text"
+                  >Open on Luma instead</span
+                ><span class="pf-v6-c-button__icon pf-m-end"
+                  ><icon-external></icon-external></span
+              ></a>
+            </div>
+          </div>
+        </div>
+      </luma-embed>
+    </div>
+  </section>
+
+  <section
+    class="pf-v6-c-page__main-section pf-m-limit-width pf-m-align-center"
+  >
+    <div
+      class="pf-v6-c-page__main-body pf-v6-l-flex pf-m-column pf-m-gap-md"
+    >
+      <div class="pf-v6-c-content">
+        <h3>Past events</h3>
+        <p>
+          Full event history is available on
+          <a
+            href="{{ .Site.Data.links.luma.url }}"
+            target="_blank"
+            rel="noopener"
+            >Luma<icon-external></icon-external></a
+          >,
+          <a
+            href="{{ .Site.Data.links.meetup.url }}"
+            target="_blank"
+            rel="noopener"
+            >Meetup<icon-external></icon-external
+          ></a>
+          and the Web Archive ({{ range $i, $link := $c.past.archive_links }}{{ if $i }}, {{ end }}<a
+            href="{{ $link.url }}"
+            target="_blank"
+            rel="noopener"
+            >{{ $link.title }}<icon-external></icon-external></a
+          >{{ end }}). Slides and materials from past talks are on our
+          <a href="{{ "/resources/" | relURL }}">Resources</a> page.
+        </p>
+      </div>
+      <table
+        class="pf-v6-c-table pf-m-grid-md pf-m-compact"
+        role="grid"
+        aria-label="Past events"
+      >
+        <thead class="pf-v6-c-table__thead">
+          <tr class="pf-v6-c-table__tr" role="row">
+            <th class="pf-v6-c-table__th" role="columnheader" scope="col">Date</th>
+            <th class="pf-v6-c-table__th" role="columnheader" scope="col">Event</th>
+            <th class="pf-v6-c-table__th" role="columnheader" scope="col">Location</th>
+            <th class="pf-v6-c-table__th" role="columnheader" scope="col"></th>
+          </tr>
+        </thead>
+        <tbody class="pf-v6-c-table__tbody" role="rowgroup">
+          {{ range .Site.Data.events.past }}
+            <tr class="pf-v6-c-table__tr" role="row">
+              <td class="pf-v6-c-table__td" role="cell" data-label="Date">{{ .date }}</td>
+              <td class="pf-v6-c-table__td" role="cell" data-label="Event">{{ .name }}</td>
+              <td class="pf-v6-c-table__td" role="cell" data-label="Location">{{ .location }}</td>
+              <td class="pf-v6-c-table__td" role="cell">
+                {{ range .links }}
+                  <a
+                    href="{{ .url }}"
+                    target="_blank"
+                    rel="noopener"
+                    class="pf-v6-c-button pf-m-link pf-m-inline pf-m-small"
+                    >{{ .title }}<icon-external></icon-external
+                  ></a>
+                {{ end }}
+              </td>
+            </tr>
+          {{ end }}
+        </tbody>
+      </table>
+    </div>
+  </section>
