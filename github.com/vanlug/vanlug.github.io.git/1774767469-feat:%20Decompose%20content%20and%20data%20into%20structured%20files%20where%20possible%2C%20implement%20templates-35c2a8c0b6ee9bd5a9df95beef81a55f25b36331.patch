+              <span
+                class="pf-v6-c-label pf-m-compact pf-m-custom"
+                style="
+                  --pf-v6-c-label--BackgroundColor: {{ .Site.Data.resources.design.colours.light }};
+                  --pf-v6-c-label--Color: #fff;
+                "
+              >
+                <span class="pf-v6-c-label__content">{{ .Site.Data.resources.design.colours.light }}</span>
+              </span>
+            </div>
+          </dd>
+        </div>
+        <div class="pf-v6-c-description-list__group">
+          <dt class="pf-v6-c-description-list__term">
+            <span class="pf-v6-c-description-list__text"
+              >Dark mode</span
+            >
+          </dt>
+          <dd class="pf-v6-c-description-list__description">
+            <div class="pf-v6-c-description-list__text">
+              <span
+                class="pf-v6-c-label pf-m-compact pf-m-custom"
+                style="
+                  --pf-v6-c-label--BackgroundColor: {{ .Site.Data.resources.design.colours.dark }};
+                  --pf-v6-c-label--Color: #fff;
+                "
+              >
+                <span class="pf-v6-c-label__content">{{ .Site.Data.resources.design.colours.dark }}</span>
+              </span>
+            </div>
+          </dd>
+        </div>
+      </dl>
+
+      <div class="pf-v6-c-content">
+        <h4>Assets</h4>
+        <p>
+          All assets are created and maintained with
+          <a
+            href="https://inkscape.org/"
+            target="_blank"
+            rel="noopener"
+            >Inkscape<icon-external></icon-external></a
+          >. All files are in
+          <a
+            href="{{ .Site.Data.site.source }}/tree/main/static/design"
+            target="_blank"
+            rel="noopener"
+            >static/design/<icon-external></icon-external></a
+          >. Cards and headers use background photos from
+          <a
+            href="https://unsplash.com/"
+            target="_blank"
+            rel="noopener"
+            >Unsplash<icon-external></icon-external></a
+          >:
+        </p>
+      </div>
+
+      <table
+        class="pf-v6-c-table pf-m-compact pf-m-grid-md"
+        role="grid"
+      >
+        <thead class="pf-v6-c-table__thead">
+          <tr class="pf-v6-c-table__tr" role="row">
+            <th
+              class="pf-v6-c-table__th"
+              role="columnheader"
+              scope="col"
+            >
+              Asset
+            </th>
+            <th
+              class="pf-v6-c-table__th"
+              role="columnheader"
+              scope="col"
+            >
+              Description
+            </th>
+            <th
+              class="pf-v6-c-table__th"
+              role="columnheader"
+              scope="col"
+            >
+              Background photo
+            </th>
+          </tr>
+        </thead>
+        <tbody class="pf-v6-c-table__tbody">
+          {{ range .Site.Data.resources.design.assets }}
+            <tr class="pf-v6-c-table__tr" role="row">
+              <td class="pf-v6-c-table__td" role="cell">
+                <a href="{{ printf "design/%s.svg" .name | relURL }}" target="_blank">{{ .name }}.svg</a>/<a href="{{ printf "design/%s.png" .name | relURL }}" target="_blank">{{ .name }}.png</a>
+              </td>
+              <td class="pf-v6-c-table__td" role="cell">
+                {{ .description }}
+              </td>
+              <td class="pf-v6-c-table__td" role="cell">
+                {{ with .photo }}
+                  <a
+                    href="{{ .url }}"
+                    target="_blank"
+                    rel="noopener"
+                    >{{ .credit }}<icon-external></icon-external
+                  ></a>
+                  (<a
+                    href="{{ .source | relURL }}"
+                    target="_blank"
+                    >source</a
+                  >)
+                {{ else }}
+                  &mdash;
+                {{ end }}
+              </td>
+            </tr>
+          {{ end }}
+        </tbody>
+      </table>
+    </div>
+  </section>
diff --git a/layouts/_partials/sidebar.html b/layouts/_partials/sidebar.html
new file mode 100644
index 0000000000000000000000000000000000000000..b52b25abbf3757fcf2189729c0ad6c756af470f4
--- /dev/null
+++ b/layouts/_partials/sidebar.html
@@ -0,0 +1,36 @@
+<aside class="pf-v6-c-page__sidebar pf-m-expanded" id="page-sidebar">
+  <div class="pf-v6-c-page__sidebar-body">
+    <nav class="pf-v6-c-nav" aria-label="Global navigation">
+      <ul class="pf-v6-c-nav__list" role="list">
+        {{ $current := $.RelPermalink }}
+        {{ range .Site.Data.links.sidebar }}
+          {{ if .separator }}
+            <li class="pf-v6-c-divider" role="separator"></li>
+          {{ else if .url }}
+            <li class="pf-v6-c-nav__item">
+              <a
+                class="pf-v6-c-nav__link"
+                href="{{ .url }}"
+                target="_blank"
+                rel="{{ with .rel }}{{ . }}{{ else }}noopener{{ end }}"
+                ><span
+                  >{{ .title }}{{ partial "icon" .icon }}<br /><small
+                    class="pf-v6-u-font-size-xs pf-v6-u-text-color-subtle"
+                    >{{ .description }}</small
+                  ></span
+                ></a
+              >
+            </li>
+          {{ else if .page }}
+            <li class="pf-v6-c-nav__item">
+              <a class="pf-v6-c-nav__link{{ if eq $current .page }} pf-m-current{{ end }}" href="{{ .page | relURL }}"
+                {{ if eq $current .page }}aria-current="page"{{ end }}
+                >{{ .title }}</a
+              >
+            </li>
+          {{ end }}
+        {{ end }}
+      </ul>
+    </nav>
+  </div>
+</aside>
