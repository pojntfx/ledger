diff --git a/layouts/_partials/masthead.html b/layouts/_partials/masthead.html
new file mode 100644
index 0000000000000000000000000000000000000000..5021c65d921cf058e6bb334b1ec345ab7ac0d72c
--- /dev/null
+++ b/layouts/_partials/masthead.html
@@ -0,0 +1,90 @@
+<header
+  class="pf-v6-c-masthead pf-m-display-stack pf-m-display-inline-on-xl"
+  id="masthead"
+>
+  <div class="pf-v6-c-masthead__main">
+    <span class="pf-v6-c-masthead__toggle pf-v6-u-align-self-center">
+      <button
+        class="pf-v6-c-button pf-m-plain"
+        type="button"
+        aria-label="Global navigation"
+        id="nav-toggle"
+        aria-expanded="true"
+      >
+        <i class="fas fa-bars" aria-hidden="true"></i>
+      </button>
+    </span>
+    <a
+      class="pf-v6-c-masthead__brand pf-v6-u-text-color-regular"
+      href="{{ "/" | relURL }}"
+      style="text-decoration: none"
+    >
+      <div
+        class="pf-v6-c-masthead__logo"
+        style="
+          display: flex;
+          align-items: center;
+          gap: var(--pf-t--global--spacer--sm);
+          width: auto;
+        "
+      >
+        <img
+          class="pf-v6-c-brand"
+          src="{{ "design/icon.svg" | relURL }}"
+          alt="VanLUG icon: Tux with Vancouver flag stripes"
+          style="height: var(--pf-v6-c-masthead__logo--MaxHeight)"
+        />
+        <span style="line-height: 1.1"
+          ><span class="pf-v6-u-font-weight-bold">VanLUG</span><br /><span
+            class="pf-v6-u-font-size-xs"
+            >Vancouver Linux User Group</span
+          ></span
+        >
+      </div>
+    </a>
+  </div>
+  <div class="pf-v6-c-masthead__content">
+    <div class="pf-v6-c-toolbar pf-m-static">
+      <div class="pf-v6-c-toolbar__content">
+        <div
+          class="pf-v6-c-toolbar__content-section pf-m-align-items-center"
+        >
+          <div
+            class="pf-v6-c-toolbar__item pf-m-overflow-container pf-m-align-end"
+          >
+            <nav
+              class="pf-v6-c-nav pf-m-horizontal"
+              aria-label="Main navigation"
+            >
+              <ul class="pf-v6-c-nav__list" role="list">
+                {{ $current := $.RelPermalink }}
+                {{ range .Site.Data.links.navbar }}
+                  <li class="pf-v6-c-nav__item">
+                    <a
+                      class="pf-v6-c-nav__link{{ if eq $current .page }} pf-m-current{{ end }}"
+                      href="{{ .page | relURL }}"
+                      {{ if eq $current .page }}aria-current="page"{{ end }}
+                      ><span class="pf-v6-c-nav__link-text">{{ .title }}</span></a
+                    >
+                  </li>
+                {{ end }}
+              </ul>
+            </nav>
+          </div>
+          <div class="pf-v6-c-toolbar__item">
+            <a
+              href="{{ .Site.Data.links.cta.page | relURL }}"
+              class="pf-v6-c-button pf-m-primary pf-m-small"
+              ><span
+                class="pf-v6-u-display-none pf-v6-u-display-inline-on-md"
+                >{{ .Site.Data.links.cta.title }}</span
+              ><span class="pf-v6-u-display-none-on-md"
+                >{{ .Site.Data.links.cta.titleShort }}</span
+              ></a
+            >
+          </div>
+        </div>
+      </div>
+    </div>
+  </div>
+</header>
