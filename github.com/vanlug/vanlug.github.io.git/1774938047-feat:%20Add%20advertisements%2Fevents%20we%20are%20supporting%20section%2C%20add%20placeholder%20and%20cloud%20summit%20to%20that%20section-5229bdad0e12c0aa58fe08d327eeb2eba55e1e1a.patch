From 5229bdad0e12c0aa58fe08d327eeb2eba55e1e1a Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Mon, 30 Mar 2026 23:20:47 -0700
Subject: [PATCH] feat: Add advertisements/events we are supporting section, add placeholder and cloud summit to that section

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/data/content.yaml b/data/content.yaml
index ba646bed627dc96dc7eee142c33646940d17c990..5235ea20b99d27fb3210134551a7e0577ae00a5f 100644
--- a/data/content.yaml
+++ b/data/content.yaml
@@ -25,6 +25,18 @@         body: "Bring your laptop. We help people install Linux, troubleshoot problems, and get comfortable with the command line."
       - title: Community year-round
         body_key: community_year_round
 
+  supporters:
+    title: Events we're supporting
+    placeholder: "More to come!"
+    empty: "Nothing right now. Check back soon!"
+    events:
+      - title: 2026 Cloud Summit
+        date: May 1, 2026
+        url: https://cloudsummit.ca
+        image:
+          src: img/cloudsummit-2026.jpg
+          alt: 2026 Cloud Summit venue in Vancouver
+
 events:
   past:
     archive_links:
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index affa44e77ba3b032bfad56f572af6f807b1545b8..8aafc5f6971e58e0d3d9ccbe14fdcad63a92adbd 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -174,3 +174,83 @@         </p>
       </div>
     </div>
   </section>
+
+  {{ with $c.supporters }}
+    <section
+      class="pf-v6-c-page__main-section pf-m-limit-width pf-m-align-center"
+    >
+      <div
+        class="pf-v6-c-page__main-body pf-v6-l-flex pf-m-column pf-m-gap-md"
+      >
+        <div class="pf-v6-c-content">
+          <h3>{{ .title }}</h3>
+        </div>
+        {{ if .events }}
+          <div class="pf-v6-l-gallery pf-m-gutter">
+            {{ range .events }}
+              <div
+                class="pf-v6-c-card pf-m-compact"
+                style="
+                  background-image: url('{{ .image.src | relURL }}');
+                  background-size: cover;
+                  background-position: center;
+                "
+                role="img"
+                aria-label="{{ .image.alt }}"
+              >
+                <div class="pf-v6-c-card__body pf-v6-l-flex pf-m-column pf-m-justify-content-flex-end pf-m-gap-sm" style="
+                  background: linear-gradient(color-mix(in srgb, var(--pf-t--global--background--color--primary--default) 40%, transparent) 0%, color-mix(in srgb, var(--pf-t--global--background--color--primary--default) 80%, transparent) 50%, var(--pf-t--global--background--color--primary--default) 100%);
+                  border-radius: inherit;
+                ">
+                  <div class="pf-v6-c-content">
+                    <h4>{{ .title }}</h4>
+                    <p><small>{{ .date }}</small></p>
+                  </div>
+                  <a
+                    href="{{ .url }}"
+                    target="_blank"
+                    rel="noopener"
+                    class="pf-v6-c-button pf-m-link pf-m-inline"
+                    ><span class="pf-v6-c-button__text">Visit website</span
+                    ><span class="pf-v6-c-button__icon pf-m-end"
+                      ><icon-external></icon-external></span
+                  ></a>
+                </div>
+              </div>
+            {{ end }}
+            {{ if lt (len .events) 3 }}
+              <div class="pf-v6-c-card pf-m-compact pf-m-plain">
+                <div class="pf-v6-c-card__body" style="flex: 1; display: flex; align-items: center; justify-content: center;">
+                  <div class="pf-v6-c-empty-state pf-m-xs">
+                    <div class="pf-v6-c-empty-state__content">
+                      <div class="pf-v6-c-empty-state__header">
+                        <div class="pf-v6-c-empty-state__icon pf-v6-u-font-size-xl pf-v6-u-mb-sm">
+                          <i class="fas fa-calendar-plus" aria-hidden="true"></i>
+                        </div>
+                        <div class="pf-v6-c-empty-state__title">
+                          <p class="pf-v6-c-empty-state__title-text pf-v6-u-font-size-sm">{{ .placeholder }}</p>
+                        </div>
+                      </div>
+                    </div>
+                  </div>
+                </div>
+              </div>
+            {{ end }}
+          </div>
+        {{ else }}
+          <div class="pf-v6-c-empty-state pf-m-xs">
+            <div class="pf-v6-c-empty-state__content">
+              <div class="pf-v6-c-empty-state__header">
+                <div class="pf-v6-c-empty-state__icon pf-v6-u-font-size-xl pf-v6-u-mb-sm">
+                  <i class="fas fa-calendar" aria-hidden="true"></i>
+                </div>
+                <div class="pf-v6-c-empty-state__title">
+                  <p class="pf-v6-c-empty-state__title-text pf-v6-u-font-size-sm">{{ .empty }}</p>
+                </div>
+              </div>
+            </div>
+          </div>
+        {{ end }}
+      </div>
+    </section>
+  {{ end }}
diff --git a/static/img/cloudsummit-2026.jpg b/static/img/cloudsummit-2026.jpg
new file mode 100644
index 0000000000000000000000000000000000000000..0915874319a11ed49349b74b5b8ef4a3a55d5a48
Binary files /dev/null and b/static/img/cloudsummit-2026.jpg differ

