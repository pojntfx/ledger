From 76d9e4a7c545a683f66e8dddeb2a53552ccb73c3 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Thu, 09 Jul 2026 20:13:41 -0700
Subject: [PATCH] feat: Hide the masthead button if there is no CTA configured

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/layouts/_partials/masthead.html b/layouts/_partials/masthead.html
index 7a82802265c4d287031b268aaef29b39e263f1b3..06d03abb0f082d082389403f255bd6c398f689f2 100644
--- a/layouts/_partials/masthead.html
+++ b/layouts/_partials/masthead.html
@@ -71,19 +71,22 @@                 {{ end }}
               </ul>
             </nav>
           </div>
-            <!-- TODO: Re-enable the membership CTA once the membership rules have been reworked -->
-            <!-- <div class="pf-v6-c-toolbar__item">
-            <a
-              href="{{ .Site.Data.links.cta.page | relURL }}"
-              class="pf-v6-c-button pf-m-primary pf-m-small"
-              ><span
-                class="pf-v6-u-display-none pf-v6-u-display-inline-on-md"
-                >{{ .Site.Data.links.cta.title }}</span
-              ><span class="pf-v6-u-display-none-on-md"
-                >{{ .Site.Data.links.cta.titleShort }}</span
-              ></a
-            > -->
-          </div>
+          {{ with .Site.Data.links.cta }}
+            {{ if and .title .titleShort }}
+              <div class="pf-v6-c-toolbar__item">
+                <a
+                  href="{{ .page | relURL }}"
+                  class="pf-v6-c-button pf-m-primary pf-m-small"
+                  ><span
+                    class="pf-v6-u-display-none pf-v6-u-display-inline-on-md"
+                    >{{ .title }}</span
+                  ><span class="pf-v6-u-display-none-on-md"
+                    >{{ .titleShort }}</span
+                  ></a
+                >
+              </div>
+            {{ end }}
+          {{ end }}
         </div>
       </div>
     </div>

