From 44bcc5e416229fbe299c44aea8a90973b9735dae Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 01 Apr 2026 00:01:16 -0700
Subject: [PATCH] feat: Add separators for posts and events RSS to sidebar

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/data/links.yaml b/data/links.yaml
index dd0e17af4f06382f17775df7b87b2dab4aded28a..894ca06fb18cb9c446c0a42a2ce67aeb599475c9 100644
--- a/data/links.yaml
+++ b/data/links.yaml
@@ -30,14 +30,6 @@   - title: Mastodon
     url: https://thecanadian.social/@vanlug
     icon: fa-brands fa-mastodon
     description: Follow us on the fediverse
-  - title: Posts RSS
-    url: https://thecanadian.social/@vanlug.rss
-    icon: fa-solid fa-rss
-    description: Subscribe to our Mastodon posts
-  - title: Events RSS
-    icon: fa-solid fa-rss
-    description: Subscribe to upcoming events
-    eventsFeed: true
   - title: Bluesky
     url: https://bsky.app/profile/vanlug.thecanadian.social.ap.brid.gy
     icon: fa-brands fa-bluesky
@@ -46,6 +38,16 @@   - title: LinkedIn
     url: https://www.linkedin.com/groups/1895787/
     icon: fa-brands fa-linkedin
     description: Our professional network group
+  - separator: true
+  - title: Posts RSS
+    url: https://thecanadian.social/@vanlug.rss
+    icon: fa-solid fa-rss
+    description: Subscribe to our Mastodon posts
+  - title: Events RSS
+    icon: fa-solid fa-rss
+    description: Subscribe to upcoming events
+    eventsFeed: true
+  - separator: true
   - title: Email the board
     url: mailto:contact@vanlug.ca
     icon: fa-solid fa-envelope

