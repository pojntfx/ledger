From dd2b1780ec3f0272f349de0f0e1252513a5d2587 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Tue, 12 May 2026 00:21:24 -0700
Subject: [PATCH] fix: Make sure that footer is sticky to bottom even if page is less tall than screen

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/layouts/_partials/footer.html b/layouts/_partials/footer.html
index 362612051319c5b13c3b504d7ae2b99bfe254ffd..6c2e8cfe587409d43b3a04e09e5f826993daed3f 100644
--- a/layouts/_partials/footer.html
+++ b/layouts/_partials/footer.html
@@ -1,7 +1,7 @@
 {{ $f := .Site.Data.content.footer }}
 {{ $isHome := .IsHome }}
 <footer
-  class="pf-v6-c-page__main-section pf-m-no-fill pf-m-limit-width pf-m-align-center"
+  class="pf-v6-c-page__main-section pf-m-no-fill pf-m-limit-width pf-m-align-center{{ if not $isHome }} pf-v6-u-mt-auto{{ end }}"
   style="
     {{ if $isHome }}
       --pf-v6-c-page__main-section--BackgroundColor: var(--pf-t--global--background--color--secondary--default);
diff --git a/layouts/baseof.html b/layouts/baseof.html
index 44cd988e74986a57cf7e5720bd24115875782ea3..4ddd1273179eb1ac24038a47387c99ad574f2181 100644
--- a/layouts/baseof.html
+++ b/layouts/baseof.html
@@ -115,8 +115,8 @@             </div>
           </div>
         </div>
       {{ else }}
-        <div class="pf-v6-c-page__main-container">
-          <main class="pf-v6-c-page__main" id="main-content">
+        <div class="pf-v6-c-page__main-container pf-v6-u-display-flex pf-v6-u-flex-direction-column">
+          <main class="pf-v6-c-page__main pf-v6-u-display-flex pf-v6-u-flex-direction-column pf-v6-u-flex-fill" id="main-content">
             {{ block "main" . }}{{ end }}
           </main>
         </div>

