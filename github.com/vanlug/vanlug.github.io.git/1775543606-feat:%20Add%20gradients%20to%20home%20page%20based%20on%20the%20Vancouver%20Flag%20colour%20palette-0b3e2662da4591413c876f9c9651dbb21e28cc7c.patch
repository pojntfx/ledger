+++ b/layouts/_partials/footer.html
@@ -1,10 +1,13 @@
 {{ $f := .Site.Data.content.footer }}
+{{ $isHome := .IsHome }}
 <footer
   class="pf-v6-c-page__main-section pf-m-no-fill pf-m-limit-width pf-m-align-center"
   style="
-    --pf-v6-c-page__main-section--BackgroundColor: var(
