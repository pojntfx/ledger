From 0531960a95fd7776c2398858f21fa5fbf7699a4d Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 27 May 2026 00:11:52 -0700
Subject: [PATCH] refactor: Drop banner from home page in favour of extending the hero text

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/data/content.yaml b/data/content.yaml
index faaf25680878b6b84446ff831090994f44fc2980..e5bf3c5dcbce544f37f15e1690c370626b11f4c5 100644
--- a/data/content.yaml
+++ b/data/content.yaml
@@ -1,8 +1,8 @@
 home:
-  badge: "Since 1999 &middot; 2,200+ members"
+  badge: ""
   title: "Vancouver's Linux community"
   subtitle: "Come get free help - stay for the friendly chats"
-  body: "Since 1999, we've been promoting Linux and free, open-source software through monthly talks, drop-in help sessions, and community events, all free and all volunteer-run, for every level of proficiency."
+  body: "Since 1999, our more than 2000 members have been promoting Linux and free, open-source software through monthly talks, drop-in help sessions, and community events, all free and all volunteer-run, for every level of proficiency."
   cta_primary:
     title: See upcoming events
     page: /events/
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index 60dcdb07f0163c4e6d3caf162ccd79fa051b8b51..a383c5b76a2f5fb96e88db998aaa50f388d9bb6f 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -10,16 +10,6 @@     <div
       class="pf-v6-c-page__main-body pf-v6-l-flex pf-m-column pf-m-gap-lg"
     >
       <div class="pf-v6-c-content">
-        <span
-          class="pf-v6-u-font-size-sm pf-v6-u-font-weight-bold"
-          style="
-            color: var(--pf-t--global--text--color--brand--default);
-            letter-spacing: 0.05em;
-            text-transform: uppercase;
-          "
-        >
-          {{ $c.badge | safeHTML }}
-        </span>
         <h1 class="pf-v6-u-font-size-4xl">
           {{ $c.title }}
         </h1>
@@ -289,4 +279,4 @@   >
     <div class="pf-v6-c-page__main-body">
       {{ partial "mastodon-feed" . }}
     </div>
-  </section>
+  </section>
\ No newline at end of file

