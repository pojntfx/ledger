@@ -0,0 +1,135 @@
+package usernotifications
+
+import (
+	"unsafe"
+
+	"github.com/progrium/darwinkit/objc"
+)
+
+// AuthorizationOptions mirrors UNAuthorizationOptions.
+type AuthorizationOptions uint
+
+const (
+	AuthorizationOptionBadge    AuthorizationOptions = 1 << 0
+	AuthorizationOptionSound    AuthorizationOptions = 1 << 1
+	AuthorizationOptionAlert    AuthorizationOptions = 1 << 2
+	AuthorizationOptionCarPlay  AuthorizationOptions = 1 << 3
+	AuthorizationOptionProvides AuthorizationOptions = 1 << 4 // provisional
+)
+
+// UserNotificationCenter wraps UNUserNotificationCenter.
+var UserNotificationCenterClass = _UserNotificationCenterClass{objc.GetClass("UNUserNotificationCenter")}
+
+type _UserNotificationCenterClass struct{ objc.Class }
+
+type UserNotificationCenter struct{ objc.Object }
+
+func UserNotificationCenterFrom(ptr unsafe.Pointer) UserNotificationCenter {
+	return UserNotificationCenter{Object: objc.ObjectFrom(ptr)}
+}
+
+// CurrentNotificationCenter returns the shared notification center.
+func (c _UserNotificationCenterClass) CurrentNotificationCenter() UserNotificationCenter {
+	return objc.Call[UserNotificationCenter](c, objc.Sel("currentNotificationCenter"))
+}
+
+func UserNotificationCenter_CurrentNotificationCenter() UserNotificationCenter {
+	return UserNotificationCenterClass.CurrentNotificationCenter()
+}
+
+// RequestAuthorization asks the user for permission. Fire-and-forget: the
+// system decision is delivered asynchronously; UN will silently refuse to
+// deliver requests if the user says no.
+func (c UserNotificationCenter) RequestAuthorization(options AuthorizationOptions) {
+	// nil completion block (UN accepts a nil handler here).
+	objc.Call[objc.Void](c, objc.Sel("requestAuthorizationWithOptions:completionHandler:"),
+		options, objc.Object{})
+}
+
+// RequestAuthorizationWithCompletion is the variant that runs a Go callback
+// when the authorization decision arrives. granted reports the user choice;
+// err is non-nil NSError on failure.
+func (c UserNotificationCenter) RequestAuthorizationWithCompletion(options AuthorizationOptions, completion func(granted bool, err objc.Object)) {
+	objc.Call[objc.Void](c, objc.Sel("requestAuthorizationWithOptions:completionHandler:"),
+		options, completion)
+}
+
+// AddNotificationRequest schedules the request. Fire-and-forget.
+func (c UserNotificationCenter) AddNotificationRequest(req NotificationRequest) {
+	objc.Call[objc.Void](c, objc.Sel("addNotificationRequest:withCompletionHandler:"),
+		req, objc.Object{})
+}
+
+// AddNotificationRequestWithCompletion runs the Go callback when UN has
+// handed the request off for delivery (or rejected it).
+func (c UserNotificationCenter) AddNotificationRequestWithCompletion(req NotificationRequest, completion func(err objc.Object)) {
+	objc.Call[objc.Void](c, objc.Sel("addNotificationRequest:withCompletionHandler:"),
+		req, completion)
+}
+
+// MutableNotificationContent wraps UNMutableNotificationContent.
+var MutableNotificationContentClass = _MutableNotificationContentClass{objc.GetClass("UNMutableNotificationContent")}
+
+type _MutableNotificationContentClass struct{ objc.Class }
+
+type MutableNotificationContent struct{ objc.Object }
+
+func MutableNotificationContentFrom(ptr unsafe.Pointer) MutableNotificationContent {
+	return MutableNotificationContent{Object: objc.ObjectFrom(ptr)}
+}
+
+func (c _MutableNotificationContentClass) New() MutableNotificationContent {
+	return objc.Call[MutableNotificationContent](c, objc.Sel("new"))
+}
+
+func NewMutableNotificationContent() MutableNotificationContent {
+	return MutableNotificationContentClass.New()
+}
+
+func (n MutableNotificationContent) SetTitle(s string)    { objc.Call[objc.Void](n, objc.Sel("setTitle:"), s) }
+func (n MutableNotificationContent) SetSubtitle(s string) { objc.Call[objc.Void](n, objc.Sel("setSubtitle:"), s) }
+func (n MutableNotificationContent) SetBody(s string)     { objc.Call[objc.Void](n, objc.Sel("setBody:"), s) }
+func (n MutableNotificationContent) SetSound(s NotificationSound) {
+	objc.Call[objc.Void](n, objc.Sel("setSound:"), s)
+}
+
+// NotificationSound wraps UNNotificationSound.
+var NotificationSoundClass = _NotificationSoundClass{objc.GetClass("UNNotificationSound")}
+
+type _NotificationSoundClass struct{ objc.Class }
+
+type NotificationSound struct{ objc.Object }
+
+func NotificationSoundFrom(ptr unsafe.Pointer) NotificationSound {
+	return NotificationSound{Object: objc.ObjectFrom(ptr)}
+}
+
+// DefaultSound returns +[UNNotificationSound defaultSound].
+func (c _NotificationSoundClass) DefaultSound() NotificationSound {
+	return objc.Call[NotificationSound](c, objc.Sel("defaultSound"))
+}
+
+func NotificationSound_DefaultSound() NotificationSound {
+	return NotificationSoundClass.DefaultSound()
+}
+
+// NotificationRequest wraps UNNotificationRequest.
+var NotificationRequestClass = _NotificationRequestClass{objc.GetClass("UNNotificationRequest")}
+
+type _NotificationRequestClass struct{ objc.Class }
+
+type NotificationRequest struct{ objc.Object }
+
+func NotificationRequestFrom(ptr unsafe.Pointer) NotificationRequest {
+	return NotificationRequest{Object: objc.ObjectFrom(ptr)}
+}
+
+// RequestWithIdentifier builds an immediate (trigger=nil) request.
+func (c _NotificationRequestClass) RequestWithIdentifier(identifier string, content MutableNotificationContent) NotificationRequest {
+	return objc.Call[NotificationRequest](c, objc.Sel("requestWithIdentifier:content:trigger:"),
+		identifier, content, objc.Object{})
+}
+
+func NotificationRequest_RequestWithIdentifier(identifier string, content MutableNotificationContent) NotificationRequest {
+	return NotificationRequestClass.RequestWithIdentifier(identifier, content)
+}
