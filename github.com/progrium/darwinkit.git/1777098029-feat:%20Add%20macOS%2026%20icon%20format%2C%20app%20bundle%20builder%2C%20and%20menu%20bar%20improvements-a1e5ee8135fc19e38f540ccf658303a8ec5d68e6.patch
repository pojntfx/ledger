+// Package usernotifications exposes a small subset of the macOS
+// UserNotifications framework (UNUserNotificationCenter and friends).
+// darwinkit's generator doesn't yet emit bindings for this framework, so we
+// hand-roll just what's needed to post a local banner from a bundled app.
+//
+// These bindings only work from processes that live in a signed .app bundle
+// with a valid CFBundleIdentifier; otherwise UN refuses to schedule the
+// request and returns silently.
+package usernotifications
+
+// #cgo CFLAGS: -x objective-c
+// #cgo LDFLAGS: -framework UserNotifications
+import "C"

