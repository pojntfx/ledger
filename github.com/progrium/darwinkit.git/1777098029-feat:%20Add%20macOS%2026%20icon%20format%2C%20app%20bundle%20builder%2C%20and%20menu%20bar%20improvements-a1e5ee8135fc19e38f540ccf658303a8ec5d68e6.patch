 #!/usr/bin/env bash
+set -euo pipefail
+cd "$(dirname "$0")"
 
-go run -gcflags "all=-N" -x .
+# UserNotifications requires the process to live in a signed .app bundle with
+# a valid CFBundleIdentifier. Build one here, ad-hoc sign it, and launch it
+# via `open` so Launch Services registers the bundle ID.
+
+APP_NAME="Sessions"
+BUNDLE_ID="com.pojtinger.felicitas.Sessions"
+VERSION_SHORT="0.1.17"
+VERSION_BUILD="17"
+OUT_DIR="./build"
+APP_DIR="${OUT_DIR}/${APP_NAME}.app"
+BIN_DIR="${APP_DIR}/Contents/MacOS"
+RES_DIR="${APP_DIR}/Contents/Resources"
+
+# Start from a clean Resources dir so stale artifacts (old AppIcon.icns,
+# Assets.car) from earlier pipelines don't linger.
+rm -rf "${APP_DIR}"
+mkdir -p "${BIN_DIR}" "${RES_DIR}"
+
+# The Liquid Glass + visual-effect APIs require -gcflags "all=-N" on macOS 26
+# (see notes in main.go's history).
+go build -gcflags "all=-N" -o "${BIN_DIR}/${APP_NAME}" .
+
+# --- App icon: Liquid Glass .icon bundle compiled via actool ------------
+#
+# macOS 26 (Tahoe) switched to a new layered .icon format with foreground
+# + background vector layers and a JSON manifest that declares appearance
+# variants (Default/Dark/Clear/Tinted), specular highlights, and shadows.
+# actool compiles the bundle into Assets.car, which the OS reads to render
+# the app icon with full Liquid Glass treatment. The schema follows
+# https://github.com/jimeh/emacs-liquid-glass-icons. The Sessions.icon
+# folder next to main.sh is the source of truth.
+xcrun actool "Sessions.icon" \
+    --compile "${RES_DIR}" \
+    --platform macosx \
+    --minimum-deployment-target 11.0 \
+    --app-icon Sessions \
+    --include-all-app-icons \
+    --enable-on-demand-resources NO \
+    --enable-icon-stack-fallback-generation NO \
+    --development-region en \
+    --target-device mac \
+    --output-partial-info-plist "${OUT_DIR}/actool.plist" \
+    --output-format human-readable-text >/dev/null
+
+# --- Info.plist ----------------------------------------------------------
+
+cat > "${APP_DIR}/Contents/Info.plist" <<PLIST
+<?xml version="1.0" encoding="UTF-8"?>
+<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
+<plist version="1.0">
+<dict>
+    <key>CFBundleExecutable</key><string>${APP_NAME}</string>
+    <key>CFBundleIdentifier</key><string>${BUNDLE_ID}</string>
+    <key>CFBundleName</key><string>${APP_NAME}</string>
+    <key>CFBundleDisplayName</key><string>${APP_NAME}</string>
+    <key>CFBundleGetInfoString</key><string>${APP_NAME} ${VERSION_SHORT} — Focus with timed work intervals</string>
+    <key>CFBundlePackageType</key><string>APPL</string>
+    <key>CFBundleShortVersionString</key><string>${VERSION_SHORT}</string>
+    <key>CFBundleVersion</key><string>${VERSION_BUILD}</string>
+    <key>CFBundleInfoDictionaryVersion</key><string>6.0</string>
+    <key>CFBundleIconName</key><string>Sessions</string>
+    <key>LSApplicationCategoryType</key><string>public.app-category.productivity</string>
+    <key>LSMinimumSystemVersion</key><string>11.0</string>
+    <key>NSHighResolutionCapable</key><true/>
+    <key>NSPrincipalClass</key><string>NSApplication</string>
+    <key>NSHumanReadableCopyright</key><string>Copyright © Felicitas Pojtinger. AGPL-3.0-or-later.</string>
+    <key>NSSupportsAutomaticGraphicsSwitching</key><true/>
+</dict>
+</plist>
+PLIST
+
+# Ad-hoc codesign so UNUserNotificationCenter treats this as a valid bundle.
+codesign --force --deep --sign - "${APP_DIR}" >/dev/null
