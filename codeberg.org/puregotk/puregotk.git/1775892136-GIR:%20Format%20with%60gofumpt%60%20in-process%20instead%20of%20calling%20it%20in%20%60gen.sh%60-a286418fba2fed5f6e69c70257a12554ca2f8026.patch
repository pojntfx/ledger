From a286418fba2fed5f6e69c70257a12554ca2f8026 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Sat, 11 Apr 2026 00:22:16 -0700
Subject: [PATCH] GIR: Format with`gofumpt` in-process instead of calling it in `gen.sh`

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/examples/mylib-gtk-meson-go/gen.sh b/examples/mylib-gtk-meson-go/gen.sh
index 827d394cac92a3e529c2ff62a9d5726c6c6eb360..d9d8960a9807d14b4d1c2aae693a13d2702c82fc 100755
--- a/examples/mylib-gtk-meson-go/gen.sh
+++ b/examples/mylib-gtk-meson-go/gen.sh
@@ -11,9 +11,6 @@ echo "making sure imports are correct..."
 GOPATH="$tmp" goimports --srcdir . -w . || { rm -r "$tmp"; exit 1; }
 rm -r "$tmp"
 
-echo "formatting files..."
-go fmt "./..."
-
 echo "running a second pass for goimports..."
 goimports -w .
 
diff --git a/gen.sh b/gen.sh
index ea455cfb47f7f1930dfa32b6837cd3597ca42270..a2c0617626c09d33994351364cde493f36c53ab6 100755
--- a/gen.sh
+++ b/gen.sh
@@ -11,9 +11,6 @@ echo "making sure imports are correct..."
 GOPATH="$tmp" goimports --srcdir . -w v4 || { rm -r "$tmp"; exit 1; }
 rm -r "$tmp"
 
-echo "formatting files..."
-gofumpt -w v4 || go fmt "codeberg.org/puregotk/puregotk/v4/..."
-
 echo "running a second pass for goimports..."
 goimports -w v4
 
diff --git a/go.mod b/go.mod
index 6998951bae5f054fa86157134f376ae544b06cff..728696bfc209003c845acdea870b8fb599fcdad0 100644
--- a/go.mod
+++ b/go.mod
@@ -1,7 +1,15 @@
 module codeberg.org/puregotk/puregotk
 
-go 1.23.0
+go 1.24.0
 
 toolchain go1.24.5
 
-require codeberg.org/puregotk/purego v0.0.0-20260224095105-2513c838cb80
+require (
+	codeberg.org/puregotk/purego v0.0.0-20260224095105-2513c838cb80
+	mvdan.cc/gofumpt v0.9.2
+)
+
+require (
+	github.com/google/go-cmp v0.7.0 // indirect
+	golang.org/x/tools v0.38.0 // indirect
+)
