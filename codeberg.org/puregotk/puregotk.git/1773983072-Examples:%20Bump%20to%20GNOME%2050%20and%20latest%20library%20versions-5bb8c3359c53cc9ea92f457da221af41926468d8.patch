--- a/examples/myapp-gnome-gomod/page.codeberg.puregotk.MyAppGnomeGomod.json
+++ b/examples/myapp-gnome-gomod/page.codeberg.puregotk.MyAppGnomeGomod.json
@@ -1,7 +1,7 @@
 {
   "id": "page.codeberg.puregotk.MyAppGnomeGomod",
   "runtime": "org.gnome.Platform",
-  "runtime-version": "49",
+  "runtime-version": "50",
   "sdk": "org.gnome.Sdk",
   "sdk-extensions": ["org.freedesktop.Sdk.Extension.golang"],
   "command": "myapp-gnome-gomod",
diff --git a/examples/myapp-gnome-meson/page.codeberg.puregotk.MyAppGnomeMeson.json b/examples/myapp-gnome-meson/page.codeberg.puregotk.MyAppGnomeMeson.json
