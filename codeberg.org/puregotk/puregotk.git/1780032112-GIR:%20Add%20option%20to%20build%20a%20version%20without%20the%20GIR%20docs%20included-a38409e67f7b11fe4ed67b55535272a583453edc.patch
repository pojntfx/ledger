From a38409e67f7b11fe4ed67b55535272a583453edc Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Thu, 28 May 2026 22:21:52 -0700
Subject: [PATCH] GIR: Add option to build a version without the GIR docs included

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/gen.go b/gen.go
index 230f2680e4287441688a3c31b515ebaf773c7f30..6dd416ba6d6eea4a312ab3359156f207e405f22b 100644
--- a/gen.go
+++ b/gen.go
@@ -8,6 +8,7 @@ 	"text/template"
 
 	"codeberg.org/puregotk/puregotk/pkg/gir/pass"
 	"codeberg.org/puregotk/puregotk/pkg/gir/util"
+	"golang.org/x/sync/errgroup"
 )
 
 //go:generate go run gen.go
@@ -49,7 +50,20 @@ 		panic(err)
 	}
 
 	// Write go files by making the second pass
-	p.Second(dir, gotemp)
+	g := new(errgroup.Group)
+	g.Go(func() error {
+		p.Second(dir, gotemp, true) // With GIR docs (LGPL-3)
+
+		return nil
+	})
+	g.Go(func() error {
+		p.Second(dir, gotemp, false) // Without GIR docs (MIT)
+
+		return nil
+	})
+	if err := g.Wait(); err != nil {
+		panic(err)
+	}
 
 	// Finally copy some extra code that we want in the API
 	data, err := os.ReadFile("templates/gobject")
