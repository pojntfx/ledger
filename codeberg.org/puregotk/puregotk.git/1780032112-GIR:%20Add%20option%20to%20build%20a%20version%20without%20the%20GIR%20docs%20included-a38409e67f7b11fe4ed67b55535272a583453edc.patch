+func GetInterfaceFuncs(ns string, name string, implemented map[string]bool, kinds KindMap, imps *ImportSet, includeGIRDocs bool) InterfaceTemplate {
 	inter := kinds.MustInterface(ns, name)
 	parts := strings.Split(name, ".")
 	var ins string
 	if len(parts) > 1 {
 		ins = strings.ToLower(parts[0])
 	}
-	return ConvertInterface(ns, ins, inter, implemented, kinds, imps)
