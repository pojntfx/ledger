+++ b/examples/myapp-gnome-gomod/page.codeberg.puregotk.MyAppGnomeGomod.json
@@ -17,6 +17,7 @@       "name": "mylib-gtk-meson",
       "buildsystem": "meson",
       "build-options": {
         "prepend-path": "/usr/lib/sdk/golang/bin",
+        "build-args": ["--filesystem=home"],
         "env": {
           "GOROOT": "/usr/lib/sdk/golang",
           "GOPATH": "/run/build/mylib-gtk-meson/go"
@@ -35,6 +36,9 @@     },
     {
       "name": "myapp-gnome-gomod",
       "buildsystem": "simple",
+      "build-options": {
+        "build-args": ["--filesystem=home"]
+      },
       "build-commands": [
         "bash -c '. /usr/lib/sdk/golang/enable.sh && ([ -f vendor/modules.txt ] || go mod vendor) && cp modules.txt vendor/modules.txt'",
         "bash -c '. /usr/lib/sdk/golang/enable.sh && export GOBIN=\"/app/bin\" && go generate ./... && go build -o /app/bin/myapp-gnome-gomod -v -mod=vendor -ldflags=\"-X main.LocaleDir=/app/share/locale\" ./src'",
