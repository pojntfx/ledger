@@ -66,6 +66,20 @@ 	x.GetProperty("test-button-sensitive", &v)
 	return v.GetBoolean()
 }
 
+// @cb must point to an addressable function variable that outlives the
+// connection — the binding keys its callback registry by &cb's address
+// and dereferences @cb on every emission, so a stack-allocated literal
+// would use-after-free once its scope returns. Callback arguments
+// (including the receiver) are borrowed for the call; copy or Ref what
+// you need to keep.
+//
+// The returned uint32 is a g_signal handler id. Use
+// (gobject.Object).DisconnectSignal to detach early; otherwise GObject
+// frees its closures when the emitting object is finalized. The Go-side
+// callback slot stays pinned until you call glib.UnrefCallback(@cb),
+// which is only worth doing when you connect-and-tear-down repeatedly
+// in a long-lived process (and is a no-op on Windows). For a typical
+// connect-once-at-startup pattern you don't need to clean up at all.
 func (x *MainApplicationWindow) ConnectButtonTestClicked(cb *func(MainApplicationWindow)) uint32 {
 	cbPtr := uintptr(unsafe.Pointer(cb))
 	if cbRefPtr, ok := glib.GetCallback(cbPtr); ok {
@@ -108,6 +122,8 @@
 // Emits the [signal@Gio.ActionGroup::action-state-changed] signal on @action_group.
 //
 // This function should only be called by [type@Gio.ActionGroup] implementations.
+//
+// The binding borrows @state for the duration of this call; your reference is unaffected. If the underlying C function takes a long-term reference it does so internally — your wrapper still owns its own ref and is responsible for Unref.
 func (x *MainApplicationWindow) ActionStateChanged(ActionNameVar string, StateVar *glib.Variant) {
 	gio.XGActionGroupActionStateChanged(x.GoPointer(), ActionNameVar, StateVar)
 }
@@ -145,6 +161,8 @@ // g_debug ("Application has been terminated. Exiting.");
 //
 // exit (0);
 // ```
+//
+// The binding borrows @parameter for the duration of this call; your reference is unaffected. If the underlying C function takes a long-term reference it does so internally — your wrapper still owns its own ref and is responsible for Unref.
 func (x *MainApplicationWindow) ActivateAction(ActionNameVar string, ParameterVar *glib.Variant) {
 	gio.XGActionGroupActivateAction(x.GoPointer(), ActionNameVar, ParameterVar)
 }
@@ -160,6 +178,8 @@ // its state or may change its state to something other than @value.
 // See [method@Gio.ActionGroup.get_action_state_hint].
 //
 // If the @value GVariant is floating, it is consumed.
+//
+// The binding borrows @value for the duration of this call; your reference is unaffected. If the underlying C function takes a long-term reference it does so internally — your wrapper still owns its own ref and is responsible for Unref.
 func (x *MainApplicationWindow) ChangeActionState(ActionNameVar string, ValueVar *glib.Variant) {
 	gio.XGActionGroupChangeActionState(x.GoPointer(), ActionNameVar, ValueVar)
 }
@@ -199,6 +219,8 @@ // given by [method@Gio.ActionGroup.get_action_state_type].
 //
 // The return value (if non-`NULL`) should be freed with
 // [method@GLib.Variant.unref] when it is no longer required.
+//
+// The caller owns the returned reference; release it with Unref when no longer needed (the binding has no Go finalizer, so dropping the wrapper without Unref leaks the C-side allocation).
 func (x *MainApplicationWindow) GetActionState(ActionNameVar string) *glib.Variant {
 	cret := gio.XGActionGroupGetActionState(x.GoPointer(), ActionNameVar)
 	return cret
@@ -222,6 +244,8 @@ // within the range may fail.
 //
 // The return value (if non-`NULL`) should be freed with
 // [method@GLib.Variant.unref] when it is no longer required.
+//
+// The caller owns the returned reference; release it with Unref when no longer needed (the binding has no Go finalizer, so dropping the wrapper without Unref leaks the C-side allocation).
 func (x *MainApplicationWindow) GetActionStateHint(ActionNameVar string) *glib.Variant {
 	cret := gio.XGActionGroupGetActionStateHint(x.GoPointer(), ActionNameVar)
 	return cret
@@ -290,6 +314,11 @@ // If the action exists, `TRUE` is returned and any of the requested
 // fields (as indicated by having a non-`NULL` reference passed in) are
 // filled.  If the action doesn’t exist, `FALSE` is returned and the
 // fields may or may not have been modified.
