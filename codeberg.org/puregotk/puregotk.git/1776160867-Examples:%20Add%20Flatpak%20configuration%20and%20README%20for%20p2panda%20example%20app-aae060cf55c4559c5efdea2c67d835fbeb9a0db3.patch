+++ b/examples/p2pandaapp-cli-gomod/page.codeberg.puregotk.P2PandaAppCLIGomod.json
@@ -0,0 +1,60 @@
+{
+  "id": "page.codeberg.puregotk.P2PandaAppCLIGomod",
+  "runtime": "org.freedesktop.Platform",
+  "runtime-version": "25.08",
+  "sdk": "org.freedesktop.Sdk",
+  "sdk-extensions": [
+    "org.freedesktop.Sdk.Extension.golang",
+    "org.freedesktop.Sdk.Extension.rust-stable"
+  ],
+  "command": "p2pandaapp-cli-gomod-chat",
+  "build-options": {
+    "append-path": "/usr/lib/sdk/golang/bin:/usr/lib/sdk/rust-stable/bin",
+    "build-args": ["--share=network", "--filesystem=home"],
+    "env": {
+      "CARGO_HOME": "/run/build/p2panda-gobject/cargo"
+    }
+  },
+  "finish-args": ["--share=network"],
+  "modules": [
+    {
+      "name": "p2panda-gobject",
+      "buildsystem": "meson",
+      "config-opts": [
+        "-Dvapi=false",
+        "-Dcapi_docs=false",
+        "-Dpython_tests=false"
+      ],
+      "sources": [
+        {
+          "type": "git",
+          "url": "https://github.com/pojntfx/p2panda-gobject.git",
+          "branch": "fix-bindings"
+        }
+      ]
+    },
+    {
+      "name": "p2pandaapp-cli-gomod",
+      "buildsystem": "simple",
+      "build-commands": [
+        "mkdir -p vendor && cp modules.txt vendor/modules.txt",
+        ". /usr/lib/sdk/golang/enable.sh && go build -o /app/bin/p2pandaapp-cli-gomod-chat -v -mod=vendor ./cmd/p2pandaapp-cli-gomod-chat",
+        ". /usr/lib/sdk/golang/enable.sh && go build -o /app/bin/p2pandaapp-cli-gomod-bootstrap -v -mod=vendor ./cmd/p2pandaapp-cli-gomod-bootstrap"
+      ],
+      "sources": [
+        { "type": "dir", "path": "." },
+        {
+          "type": "dir",
+          "path": "../..",
+          "dest": "vendor/codeberg.org/puregotk/puregotk"
+        },
+        {
+          "type": "dir",
+          "path": "../p2panda-gobject-go",
+          "dest": "vendor/codeberg.org/puregotk/puregotk/examples/p2panda-gobject-go"
+        },
+        "go.mod.json"
+      ]
+    }
+  ]
+}

