From ff6e1078003be4010ecdd200ce3067480bab5f61 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Mon, 16 Mar 2026 22:04:35 -0700
Subject: [PATCH] README: Use new integer widths in example

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/README.md b/README.md
index 1cd5f34dd6110c87e04fe1cff4e8f3738da33e29..91a4d67b1ddb81d1633629481ba7dcc9020a1130 100644
--- a/README.md
+++ b/README.md
@@ -78,8 +78,8 @@ 		activate(app)
 	}
 	app.ConnectActivate(&actcb)
 
-	if code := app.Run(len(os.Args), os.Args); code > 0 {
-		os.Exit(code)
+	if code := app.Run(int32(len(os.Args)), os.Args); code > 0 {
+		os.Exit(int(code))
 	}
 }
 

