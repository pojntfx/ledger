From 15c57d07856b52d8dcf6c91b8f0aa03f9a0b3e5e Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Thu, 28 May 2026 22:50:07 -0700
Subject: [PATCH] Examples: Use new pass options in `gen.go`

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/examples/mylib-gtk-meson-go/gen.go b/examples/mylib-gtk-meson-go/gen.go
index 7fc60b9e7437d858e16c79bcf6d9d435b7aa0604..d32944994fa348ef28c5ff0bd862a861afc4c6f8 100644
--- a/examples/mylib-gtk-meson-go/gen.go
+++ b/examples/mylib-gtk-meson-go/gen.go
@@ -41,7 +41,12 @@ 		}
 		return nil
 	})
 
-	p, err := pass.New(girs, "codeberg.org/puregotk/puregotk/examples/mylib-gtk-meson-go",
+	p, err := pass.New(
+		girs,
+		"codeberg.org/puregotk/puregotk/examples/mylib-gtk-meson-go",
+		// No need to generate a version with GIR docs and without GIR docs here,
+		// both the mylib-gtk-meson library and the GIR docs are MIT licensed
+		pass.Options{},
 		pass.Dependency{
 			Module: "codeberg.org/puregotk/puregotk/v4",
 			Files:  puregotkGirs,
diff --git a/examples/mylib-gtk-meson-go/go.mod b/examples/mylib-gtk-meson-go/go.mod
index 74776902ea2bfb8e6422378cf677628763b5d136..ba1915d166155ae9c9d6f4f69d45f11ba5b607a7 100644
--- a/examples/mylib-gtk-meson-go/go.mod
+++ b/examples/mylib-gtk-meson-go/go.mod
@@ -11,6 +11,7 @@ )
 
 require (
 	github.com/google/go-cmp v0.7.0 // indirect
+	golang.org/x/sync v0.17.0 // indirect
 	golang.org/x/tools v0.38.0 // indirect
 	mvdan.cc/gofumpt v0.9.2 // indirect
 )
