diff --git a/examples/myapp-gstreamer-meson/src/main.go b/examples/myapp-gstreamer-meson/src/main.go
new file mode 100644
index 0000000000000000000000000000000000000000..d41714719a627af39350449acf73fa2d7b627344
--- /dev/null
+++ b/examples/myapp-gstreamer-meson/src/main.go
@@ -0,0 +1,162 @@
+// Ported to Go from https://gitlab.freedesktop.org/gstreamer/gst-plugins-rs/-/blob/main/video/gtk4/examples/gtksink.py?ref_type=heads and https://gitlab.freedesktop.org/gstreamer/gst-plugins-rs/-/blob/main/video/gtk4/examples/gtksink.rs?ref_type=heads
+package main
+
+import (
+	"fmt"
+	"log"
+	"os"
+	"unsafe"
+
+	"codeberg.org/puregotk/puregotk/v4/gdk"
+	"codeberg.org/puregotk/puregotk/v4/gio"
+	"codeberg.org/puregotk/puregotk/v4/glib"
+	"codeberg.org/puregotk/puregotk/v4/gst"
+	"codeberg.org/puregotk/puregotk/v4/gtk"
+)
+
+//go:generate sh -c "if [ -z \"$FLATPAK_ID\" ]; then cd .. && GOWORK=off go tool github.com/dennwc/flatpak-go-mod --json .; fi"
+
+var createUI = func(app *gtk.Application) {
+	pipeline := gst.NewPipeline("")
+
+	overlay := gst.ElementFactoryMake("clockoverlay", "")
+	overlay.Set("font-desc", "Monospace 42")
+
+	gtksink := gst.ElementFactoryMake("gtk4paintablesink", "")
+
+	var paintablePtr uintptr
+	gtksink.Get("paintable", &paintablePtr)
+
+	paintable := &gdk.PaintableBase{
+		Ptr: paintablePtr,
+	}
+
+	var glContextPtr uintptr
+	gtksink.Get("gl-context", &glContextPtr)
+
+	var src, sink *gst.Element
+	if glContextPtr != 0 {
+		log.Println("Using GL")
+
+		src = gst.ElementFactoryMake("gltestsrc", "src")
+
+		sink = gst.ElementFactoryMake("glsinkbin", "sinkbin")
+		sink.Set("sink", gtksink)
+	} else {
+		log.Println("Not using GL")
+
+		src = gst.ElementFactoryMake("videotestsrc", "src")
+
+		bin := gst.NewBin("sinkbin")
+		convert := gst.ElementFactoryMake("videoconvert", "convert")
+
+		if !bin.Add(convert) {
+			panic("could not add videoconvert to bin")
+		}
+
+		if !bin.Add(gtksink) {
+			panic("could not add gtk4paintablesink to bin")
+		}
+
+		if !convert.Link(gtksink) {
+			panic("could not link videoconvert to gtk4paintablesink")
+		}
+
+		ghost := gst.NewGhostPad("sink", convert.GetStaticPad("sink"))
+		bin.AddPad(&ghost.Pad)
+
+		sink = &bin.Element
+	}
+
+	pipeline.Add(src)
+	pipeline.Add(overlay)
+	pipeline.Add(sink)
+
+	src.LinkFiltered(overlay, gst.CapsFromString("video/x-raw(ANY), width=640, height=480"))
+	overlay.Link(sink)
+
+	window := gtk.NewApplicationWindow(app)
+	window.SetDefaultSize(640, 480)
+
+	vbox := gtk.NewBox(gtk.OrientationVerticalValue, 0)
+
+	picture := gtk.NewPicture()
+	picture.SetPaintable(paintable)
+
+	vbox.Append(&picture.Widget)
+
+	label := gtk.NewLabel("Position: 00:00:00")
+	vbox.Append(&label.Widget)
+
+	window.SetChild(&vbox.Widget)
+	window.Present()
+
+	app.AddWindow(&window.Window)
+
+	var onTimeout glib.SourceFunc = func(u uintptr) bool {
+		var position int64
+		res := pipeline.QueryPosition(gst.FormatTimeValue, &position)
+		if !res || position == -1 {
+			label.SetText("Position: 00:00:00")
+		} else {
+			totalSeconds := int(position / 1000000000)
+			hours := totalSeconds / 3600
+			minutes := (totalSeconds / 60) % 60
+			seconds := totalSeconds % 60
+			label.SetText(fmt.Sprintf("Position: %02d:%02d:%02d", hours, minutes, seconds))
+		}
+
+		return true
+	}
+	glib.TimeoutAdd(500, &onTimeout, 0)
+
+	pipeline.SetState(gst.StatePlayingValue)
+
+	bus := pipeline.GetBus()
+	bus.AddSignalWatch()
+
+	onMessage := func(_ gst.Bus, msgPtr uintptr) {
+		msg := (*gst.Message)(unsafe.Pointer(msgPtr))
+		switch msg.Type {
+		case gst.MessageEosValue:
+			app.Quit()
+
+		case gst.MessageErrorValue:
+			var (
+				gerr  *glib.Error
+				debug string
+			)
+			msg.ParseError(&gerr, &debug)
+			defer gerr.Free()
+
+			srcPath := "<unknown>"
+			if msg.Src != nil {
+				srcPath = msg.Src.GetPathString()
+			}
+			log.Printf("Error from %s: %s (%s)", srcPath, gerr.MessageGo(), debug)
+
+			app.Quit()
+		}
+	}
+	bus.ConnectMessage(&onMessage)
+
+	onShutdown := func(gio.Application) {
+		window.Close()
+		pipeline.SetState(gst.StateNullValue)
+	}
+	app.ConnectShutdown(&onShutdown)
+}
+
+func main() {
+	gst.Init(0, nil)
+
+	app := gtk.NewApplication("page.codeberg.puregotk.MyAppGstreamerMeson", gio.GApplicationDefaultFlagsValue)
+	onActivate := func(gio.Application) {
+		createUI(app)
+	}
+	app.ConnectActivate(&onActivate)
+
+	defer gst.Deinit()
+
+	os.Exit(int(app.Run(int32(len(os.Args)), os.Args)))
+}
diff --git a/examples/myapp-gstreamer-meson/src/meson.build b/examples/myapp-gstreamer-meson/src/meson.build
