--- /dev/null
+++ b/examples/myapp-gstreamer-meson/src/meson.build
@@ -0,0 +1,25 @@
+myapp_gstreamer_meson_source_dir = meson.current_source_dir()
+
+myapp_gstreamer_meson_source_go_files = files('main.go')
+
+myapp_gstreamer_meson_deps = [
+    dependency('gtk4'),
+    dependency('gstreamer-1.0'),
+]
+
+custom_target(
+    'myapp-gstreamer-meson',
+    build_always_stale: true,  # Go caches internally
+    input: myapp_gstreamer_meson_source_go_files,
+    output: 'myapp-gstreamer-meson',
+    command: [
+        find_program('go').full_path(),
+        'build',
+        '-x',
+        '-o',
+        '@OUTPUT@',
+        myapp_gstreamer_meson_source_dir,
+    ],
+    install: true,
+    install_dir: get_option('prefix') / get_option('bindir'),
+)

