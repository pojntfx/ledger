diff --git a/internal/gir/types/imports.go b/internal/gir/types/imports.go
new file mode 100644
index 0000000000000000000000000000000000000000..0d1b104021cb60946e378906c6d6af01b6377a2b
--- /dev/null
+++ b/internal/gir/types/imports.go
@@ -0,0 +1,112 @@
+package types
+
+import (
+	"sort"
+	"strings"
+)
+
+// ImportConfig holds the module-level configuration for import resolution.
+// This allows the generator to work with any module path, not just puregotk.
+type ImportConfig struct {
+	// ModuleBase is the Go module path for generated packages
+	// (e.g., "codeberg.org/puregotk/puregotk" for the main project,
+	// or "codeberg.org/someone/mylib" for a custom library)
+	ModuleBase string
+	// PathPrefix is the subdirectory under ModuleBase for generated packages (e.g., "v4").
+	// Leave empty if packages are generated at the module root.
+	PathPrefix string
+	// CoreModule is the Go module path that provides pkg/core
+	// (e.g., "codeberg.org/puregotk/puregotk"). If empty, defaults to ModuleBase.
+	CoreModule string
+	// PuregoModule is the module path for purego (e.g., "codeberg.org/puregotk/purego")
+	PuregoModule string
+	// PackageImports maps lowercased GIR namespace names to their full Go import paths.
+	// Built automatically from parsed repositories in First(), but can also be
+	// pre-populated for namespaces from external dependencies that use a different
+	// module path (e.g., a custom library importing puregotk's v4 packages).
+	PackageImports map[string]string
+}
+
+// AddPackages registers import paths for namespaces under the given module base and path prefix.
+// This is useful for pre-populating imports from external dependencies.
+func (c *ImportConfig) AddPackages(moduleBase, pathPrefix string, namespaces []string) {
+	if c.PackageImports == nil {
+		c.PackageImports = make(map[string]string)
+	}
+	base := moduleBase
+	if pathPrefix != "" {
+		base += "/" + pathPrefix
+	}
+	for _, ns := range namespaces {
+		pkg := strings.ToLower(ns)
+		c.PackageImports[pkg] = base + "/" + pkg
+	}
+}
+
+type ImportSet struct {
+	PkgName string
+	config  *ImportConfig
+	imports map[string]bool
+}
+
+func NewImportSet(pkgName string, config *ImportConfig) *ImportSet {
+	return &ImportSet{PkgName: pkgName, config: config, imports: make(map[string]bool)}
+}
+
+func (s *ImportSet) Add(imp string) { s.imports[imp] = true }
+
+func (s *ImportSet) AddV4(pkg string) {
+	if pkg != s.PkgName {
+		if impPath, ok := s.config.PackageImports[pkg]; ok {
+			s.imports[impPath] = true
+		}
+	}
+}
+
+func (s *ImportSet) AddCore() {
+	base := s.config.CoreModule
+	if base == "" {
+		base = s.config.ModuleBase
+	}
+	s.imports[base+"/pkg/core"] = true
+}
+func (s *ImportSet) AddPurego() { s.imports[s.config.PuregoModule] = true }
+func (s *ImportSet) AddUnsafe()  { s.imports["unsafe"] = true }
+func (s *ImportSet) AddStructs() { s.imports["structs"] = true }
+func (s *ImportSet) AddTypes() {
+	if impPath, ok := s.config.PackageImports["gobject"]; ok {
+		s.imports[impPath+"/types"] = true
+	}
+}
+
+func (s *ImportSet) TrackGoType(goType string) {
+	if strings.Contains(goType, "types.GType") {
+		s.AddTypes()
+	}
+	for pkg := range s.config.PackageImports {
+		if pkg != s.PkgName && strings.Contains(goType, pkg+".") {
+			s.AddV4(pkg)
+		}
+	}
+}
+
+func (s *ImportSet) Sorted() []string {
+	var stdlib, thirdParty []string
+	for imp := range s.imports {
+		if !strings.Contains(imp, ".") {
+			stdlib = append(stdlib, imp)
+		} else {
+			thirdParty = append(thirdParty, imp)
+		}
+	}
+	sort.Strings(stdlib)
+	sort.Strings(thirdParty)
+
+	var result []string
+	result = append(result, stdlib...)
+	if len(stdlib) > 0 && len(thirdParty) > 0 {
+		result = append(result, "")
+	}
+	result = append(result, thirdParty...)
+	return result
+}
