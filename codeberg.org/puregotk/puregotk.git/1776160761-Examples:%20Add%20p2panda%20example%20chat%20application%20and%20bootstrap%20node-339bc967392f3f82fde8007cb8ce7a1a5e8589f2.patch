From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Tue, 14 Apr 2026 02:59:21 -0700
Subject: [PATCH] Examples: Add p2panda example chat application and bootstrap node

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/examples/p2pandaapp-cli-gomod/cmd/p2pandaapp-cli-gomod-bootstrap/main.go b/examples/p2pandaapp-cli-gomod/cmd/p2pandaapp-cli-gomod-bootstrap/main.go
new file mode 100644
index 0000000000000000000000000000000000000000..eadfaa9f2bbfed0077b6f3d48bf69f38076e5226
--- /dev/null
+++ b/examples/p2pandaapp-cli-gomod/cmd/p2pandaapp-cli-gomod-bootstrap/main.go
@@ -0,0 +1,80 @@
+package main
+
+import (
+	"encoding/hex"
+	"flag"
+	"fmt"
+	"log/slog"
+	"os"
+	"os/signal"
+	"syscall"
+	"unsafe"
+
+	"codeberg.org/puregotk/puregotk/examples/p2panda-gobject-go/p2panda"
+	"codeberg.org/puregotk/puregotk/v4/gio"
+	"codeberg.org/puregotk/puregotk/v4/glib"
+)
+
+func hexTo32(s string) [32]byte {
+	b, err := hex.DecodeString(s)
+	if err != nil {
+		panic(err)
+	}
+	var out [32]byte
+	copy(out[:], b)
+	return out
+}
+
+func main() {
+	relayFlag := flag.String("relay", "https://euc1-1.relay.n0.iroh-canary.iroh.link", "relay URL")
+	networkFlag := flag.String("network", "a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2", "network ID hex")
+
+	flag.Parse()
+
+	loop := glib.NewMainLoop(glib.MainContextDefault(), false)
+
+	relayURI, err := glib.UriParse(*relayFlag, glib.GUriFlagsNoneValue)
+	if err != nil {
+		panic(err)
+	}
+
+	networkID := p2panda.NewNetworkIdFromData(hexTo32(*networkFlag))
+	defer networkID.Free()
+
+	pk := p2panda.NewPrivateKey()
+	defer pk.Free()
+
+	pubKey := pk.GetPublicKey()
+	defer pubKey.Free()
+	pubHex := hex.EncodeToString(unsafe.Slice((*byte)(unsafe.Pointer(pubKey.GetData())), 32))
+
+	node := p2panda.NewNode(
+		pk,
+		"sqlite::memory:",
+		networkID,
+		relayURI,
+		nil,
+		p2panda.MdnsDiscoveryModeActiveValue,
+	)
+
+	var onSpawn gio.AsyncReadyCallback = func(_, resultPtr, _ uintptr) {
+		if _, err := node.SpawnFinish(&gio.AsyncResultBase{Ptr: resultPtr}); err != nil {
+			panic(err)
+		}
+
+		slog.Info("Bootstrap node running", "pubkey", pubHex)
+
+		fmt.Println(pubHex)
+	}
+	node.SpawnAsync(nil, &onSpawn, 0)
+
+	sig := make(chan os.Signal, 1)
+	signal.Notify(sig, os.Interrupt, syscall.SIGTERM)
+	go func() {
+		<-sig
+
+		loop.Quit()
+	}()
+
+	loop.Run()
+}
diff --git a/examples/p2pandaapp-cli-gomod/cmd/p2pandaapp-cli-gomod-chat/main.go b/examples/p2pandaapp-cli-gomod/cmd/p2pandaapp-cli-gomod-chat/main.go
new file mode 100644
index 0000000000000000000000000000000000000000..33f4ed5a2dd68a3102fb492c1bd6a73e55ae9e99
--- /dev/null
+++ b/examples/p2pandaapp-cli-gomod/cmd/p2pandaapp-cli-gomod-chat/main.go
@@ -0,0 +1,169 @@
+package main
+
+import (
+	"bufio"
+	"encoding/hex"
+	"flag"
+	"fmt"
+	"log/slog"
+	"os"
+	"os/signal"
+	"syscall"
+	"unsafe"
+
+	"codeberg.org/puregotk/puregotk/examples/p2panda-gobject-go/p2panda"
+	"codeberg.org/puregotk/puregotk/v4/gio"
+	"codeberg.org/puregotk/puregotk/v4/glib"
+)
+
+func hexTo32(s string) [32]byte {
+	b, err := hex.DecodeString(s)
+	if err != nil {
+		panic(err)
+	}
+	var out [32]byte
+	copy(out[:], b)
+	return out
+}
+
+func ptrHex(ptr uintptr, n int) string {
+	return hex.EncodeToString(unsafe.Slice((*byte)(unsafe.Pointer(ptr)), n))
+}
+
+func main() {
+	relayFlag := flag.String("relay", "https://euc1-1.relay.n0.iroh-canary.iroh.link", "relay URL")
+	networkFlag := flag.String("network", "a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2", "network ID hex")
+	topicFlag := flag.String("topic", "f0e1d2c3b4a5f6e7d8c9b0a1f2e3d4c5b6a7f8e9d0c1b2a3f4e5d6c7b8a9f0e1", "topic ID hex")
+	peerFlag := flag.String("peer", "", "node ID hex/pubkey of a peer to bootstrap from")
+
+	flag.Parse()
+
+	loop := glib.NewMainLoop(glib.MainContextDefault(), false)
+
+	relayURI, err := glib.UriParse(*relayFlag, glib.GUriFlagsNoneValue)
+	if err != nil {
+		panic(err)
+	}
+
+	networkID := p2panda.NewNetworkIdFromData(hexTo32(*networkFlag))
+	defer networkID.Free()
+
+	topicID := p2panda.NewTopicIdFromData(hexTo32(*topicFlag))
+	defer topicID.Free()
+
+	pk := p2panda.NewPrivateKey()
+	defer pk.Free()
+
+	ownPubKey := pk.GetPublicKey()
+	defer ownPubKey.Free()
+	ownHex := ptrHex(ownPubKey.GetData(), 32)
+
+	var bootstrap *p2panda.NodeId
+	if *peerFlag != "" {
+		b, err := p2panda.NewNodeIdFromData(hexTo32(*peerFlag), relayURI)
+		if err != nil {
+			panic(err)
+		}
+		bootstrap = b
+		defer bootstrap.Free()
+	}
+
+	node := p2panda.NewNode(
+		pk,
+		"sqlite::memory:",
+		networkID,
+		relayURI,
+		bootstrap,
+		p2panda.MdnsDiscoveryModeActiveValue,
+	)
+
+	var onNodeSpawn gio.AsyncReadyCallback = func(_, resultPtr, _ uintptr) {
+		if _, err := node.SpawnFinish(&gio.AsyncResultBase{Ptr: resultPtr}); err != nil {
+			panic(err)
+		}
+
+		slog.Info("Node ready", "pubkey", ownHex, "peer-flag", "--peer "+ownHex)
+
+		tp := p2panda.NewTopic(node, topicID, uint32(p2panda.TopicEphemeralValue|p2panda.TopicPersistentValue))
+
+		onMsg := func(_ p2panda.Topic, pkPtr, dtPtr, bPtr uintptr) bool {
+			from := ptrHex((*p2panda.PublicKey)(unsafe.Pointer(pkPtr)).GetData(), 32)
+			if from == ownHex {
+				return true
+			}
+
+			dt := (*glib.DateTime)(unsafe.Pointer(dtPtr))
+			msg := (*glib.Bytes)(unsafe.Pointer(bPtr))
+
+			var sz uint
+			fmt.Printf("[%s] %s: %s\n", dt.FormatIso8601(), from[:8], string(unsafe.Slice((*byte)(unsafe.Pointer(msg.GetData(&sz))), sz)))
+
+			return true
+		}
+		tp.ConnectMessage(&onMsg)
+
+		onEph := func(_ p2panda.Topic, pkPtr, dtPtr, bPtr uintptr) {
+			from := ptrHex((*p2panda.PublicKey)(unsafe.Pointer(pkPtr)).GetData(), 32)
+			if from == ownHex {
+				return
+			}
+
+			dt := (*glib.DateTime)(unsafe.Pointer(dtPtr))
+			msg := (*glib.Bytes)(unsafe.Pointer(bPtr))
+
+			var sz uint
+			fmt.Printf("[%s] %s: %s\n", dt.FormatIso8601(), from[:8], string(unsafe.Slice((*byte)(unsafe.Pointer(msg.GetData(&sz))), sz)))
+		}
+		tp.ConnectEphemeralMessage(&onEph)
+
+		var onTopicSpawn gio.AsyncReadyCallback = func(_, tpResultPtr, _ uintptr) {
+			if _, err := tp.SpawnFinish(&gio.AsyncResultBase{Ptr: tpResultPtr}); err != nil {
+				panic(err)
+			}
+
+			slog.Info("Topic ready, type messages and press enter to send")
+
+			go func() {
+				sc := bufio.NewScanner(os.Stdin)
+				for sc.Scan() {
+					if line := sc.Text(); line != "" {
+						m := line
+						var fn glib.SourceFunc = func(uintptr) bool {
+							d := glib.NewBytes([]byte(m), uint(len(m)))
+							var onPub gio.AsyncReadyCallback = func(_, pResultPtr, _ uintptr) {
+								if _, err := tp.PublishFinish(&gio.AsyncResultBase{Ptr: pResultPtr}); err != nil {
+									panic(err)
+								}
+							}
+
+							tp.PublishAsync(d, false, nil, &onPub, 0)
+
+							return false
+						}
+
+						glib.IdleAdd(&fn, 0)
+					}
+				}
+
+				if err := sc.Err(); err != nil {
+					panic(err)
+				}
+
+				var quit glib.SourceFunc = func(uintptr) bool { loop.Quit(); return false }
+				glib.IdleAdd(&quit, 0)
+			}()
+		}
+		tp.SpawnAsync(nil, &onTopicSpawn, 0)
+	}
+	node.SpawnAsync(nil, &onNodeSpawn, 0)
+
+	sig := make(chan os.Signal, 1)
+	signal.Notify(sig, os.Interrupt, syscall.SIGTERM)
+	go func() {
+		<-sig
+
+		loop.Quit()
+	}()
+
+	loop.Run()
+}
