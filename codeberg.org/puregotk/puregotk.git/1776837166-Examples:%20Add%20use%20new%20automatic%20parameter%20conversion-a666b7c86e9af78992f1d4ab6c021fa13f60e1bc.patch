+++ b/examples/myapp-gnome-gomod/src/application.go
@@ -29,16 +29,16 @@ 	return v
 }
 
 func init() {
-	var appClassInit gobject.ClassInitFunc = func(tc *gobject.TypeClass, u uintptr) {
-		objClass := (*gobject.ObjectClass)(unsafe.Pointer(tc))
+	var appClassInit gobject.ClassInitFunc = func(GClassVar *gobject.TypeClass, ClassDataVar uintptr) {
+		objClass := (*gobject.ObjectClass)(unsafe.Pointer(GClassVar))
 
-		objClass.OverrideConstructed(func(o *gobject.Object) {
-			parentObjClass := (*gobject.ObjectClass)(unsafe.Pointer(tc.PeekParent()))
+		objClass.OverrideConstructed(func(ObjectVar *gobject.Object) {
+			parentObjClass := (*gobject.ObjectClass)(unsafe.Pointer(GClassVar.PeekParent()))
 
-			parentObjClass.GetConstructed()(o)
+			parentObjClass.GetConstructed()(ObjectVar)
 
 			var parent adw.Application
-			o.Cast(&parent)
+			ObjectVar.Cast(&parent)
 
 			app := &Application{
 				Application: parent,
@@ -47,16 +47,16 @@
 			var pinner runtime.Pinner
 			pinner.Pin(app)
 
-			var cleanupCallback glib.DestroyNotify = func(data uintptr) {
+			var cleanupCallback glib.DestroyNotify = func(DataVar uintptr) {
 				pinner.Unpin()
 			}
-			o.SetDataFull(dataKeyGoInstance, uintptr(unsafe.Pointer(app)), &cleanupCallback)
+			ObjectVar.SetDataFull(dataKeyGoInstance, uintptr(unsafe.Pointer(app)), &cleanupCallback)
 		})
 
-		applicationClass := (*gio.ApplicationClass)(unsafe.Pointer(tc))
+		applicationClass := (*gio.ApplicationClass)(unsafe.Pointer(GClassVar))
 
-		applicationClass.OverrideActivate(func(a *gio.Application) {
-			myApp := (*Application)(unsafe.Pointer(a.GetData(dataKeyGoInstance)))
+		applicationClass.OverrideActivate(func(ApplicationVar *gio.Application) {
+			myApp := (*Application)(unsafe.Pointer(ApplicationVar.GetData(dataKeyGoInstance)))
 
 			if myApp.window != nil {
 				myApp.window.ApplicationWindow.Present()
@@ -64,7 +64,7 @@ 				return
 			}
 
 			var app gtk.Application
-			a.Cast(&app)
+			ApplicationVar.Cast(&app)
 
 			obj := NewWindow("application", app)
 
@@ -75,7 +75,7 @@ 			myApp.window.ApplicationWindow.Present()
 		})
 	}
 
-	var appInstanceInit gobject.InstanceInitFunc = func(ti *gobject.TypeInstance, tc *gobject.TypeClass) {}
+	var appInstanceInit gobject.InstanceInitFunc = func(InstanceVar *gobject.TypeInstance, GClassVar *gobject.TypeClass) {}
 
 	var appParentQuery gobject.TypeQuery
 	gobject.NewTypeQuery(adw.ApplicationGLibType(), &appParentQuery)
