diff --git a/examples/myapp-gnome-gomod/src/application.go b/examples/myapp-gnome-gomod/src/application.go
index d34f3a2a78f7fbdfd66ce0099c2c1485e5d69023..da7ba59d1bd9ade1b264b8f05dcf14c8f638e3fa 100644
