@@ -83,14 +83,14 @@
 				var libWindow mylibgtkmeson.MainApplicationWindow
 				obj.Cast(&libWindow)
 
-				onLibButtonTestClicked := func(sw mylibgtkmeson.MainApplicationWindow) {
