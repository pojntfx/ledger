 		impPackageImports: make(map[string]string),
@@ -116,6 +140,130 @@ func (p *Pass) First() {
 	for _, r := range p.Parsed {
 		p.collectTypes(r)
 	}
+	p.detectMiniObjectDerived()
+	p.detectFloatingRef()
+}
+
+// classKey is the lowercase "ns.name" key used by FloatingRef. It matches
+// the convention used by MiniObjectDerived so callers can compose the same
+// namespace-resolution rules.
+func classKey(ns, name string) string {
+	return strings.ToLower(ns) + "." + name
+}
+
+// detectFloatingRef walks every class in every parsed namespace and
+// classifies it as floating-ref if its parent chain reaches
+// GObject.InitiallyUnowned. We iterate to a fixpoint because parents are
+// expressed as bare names (when they live in the same namespace) or
+// "Other.Name" (when they cross namespaces) — reaching a transitive
+// answer means each pass propagates one inheritance step.
+func (p *Pass) detectFloatingRef() {
+	root := classKey("GObject", "InitiallyUnowned")
+	p.FloatingRef[root] = true
+
+	resolveParent := func(ns, parent string) string {
+		if parent == "" {
+			return ""
+		}
+		parts := strings.SplitN(parent, ".", 2)
+		if len(parts) == 2 {
+			return strings.ToLower(parts[0]) + "." + parts[1]
+		}
+		return strings.ToLower(ns) + "." + parent
+	}
+
+	for {
+		changed := false
+		for _, r := range p.Parsed {
+			ns := r.Namespaces[0].Name
+			for _, cls := range r.Namespaces[0].Classes {
+				key := classKey(ns, cls.Name)
+				if p.FloatingRef[key] {
+					continue
+				}
+				if p.FloatingRef[resolveParent(ns, cls.Parent)] {
+					p.FloatingRef[key] = true
+					changed = true
+				}
+			}
+		}
+		if !changed {
+			break
+		}
+	}
+}
+
+// recordKey builds the canonical lowercase "ns.name" key used by MiniObjectDerived.
+func recordKey(ns, name string) string {
+	return strings.ToLower(ns) + "." + name
+}
+
+// detectMiniObjectDerived walks every record in every parsed namespace and
+// classifies it as miniobject-derived if its first non-private field is (or
+// transitively derives from) Gst.MiniObject. GIR doesn't carry inheritance
+// for records, so we rely on the GStreamer convention that a subclass
+// embeds its parent miniobject as the first field. We iterate to a fixpoint
+// to handle multi-level chains (e.g. records that embed another
+// miniobject-derived record before MiniObject itself is reached).
+func (p *Pass) detectMiniObjectDerived() {
+	// Direct base case: Gst.MiniObject itself. The empty value just marks
+	// presence; MiniObject doesn't have its own embedded parent so there
+	// is no field name to record.
+	root := recordKey("Gst", "MiniObject")
+	p.MiniObjectDerived[root] = ""
+
+	// firstField inspects rec and returns the GIR field name and the
+	// lowercase "ns.name" of the first field's type, or ("", "") if none
+	// is suitable. We require an embedded-by-value field (no pointer in
+	// the C type) — pointer fields like StaticCaps.caps (*Caps) hold a
+	// reference but don't structurally inherit, so they must not count.
+	// Private fields count: GIR sometimes marks the embedded miniobject
+	// parent as private (e.g. GstSdp.MIKEYMessage), but the C struct still
+	// embeds it at offset 0, which is what miniobject derivation requires.
+	firstField := func(ns string, rec types.Record) (fieldName, refKey string) {
+		for _, f := range rec.Fields {
+			if f.Callback != nil || f.AnyType.Type == nil {
+				continue
+			}
+			if strings.Contains(f.AnyType.Type.CType, "*") {
+				return "", ""
+			}
+			refName := f.AnyType.Type.Name
+			if refName == "" {
+				continue
+			}
+			parts := strings.SplitN(refName, ".", 2)
+			if len(parts) == 2 {
+				return f.Name, strings.ToLower(parts[0]) + "." + parts[1]
+			}
+			return f.Name, strings.ToLower(ns) + "." + refName
+		}
+		return "", ""
+	}
+
+	for {
+		changed := false
+		for _, r := range p.Parsed {
+			ns := r.Namespaces[0].Name
+			for _, rec := range r.Namespaces[0].Records {
+				key := recordKey(ns, rec.Name)
+				if _, ok := p.MiniObjectDerived[key]; ok {
+					continue
+				}
+				fname, ref := firstField(ns, rec)
+				if ref == "" {
+					continue
+				}
+				if _, ok := p.MiniObjectDerived[ref]; ok {
+					p.MiniObjectDerived[key] = util.SnakeToCamel(fname)
+					changed = true
+				}
+			}
+		}
+		if !changed {
+			break
+		}
+	}
 }
 
