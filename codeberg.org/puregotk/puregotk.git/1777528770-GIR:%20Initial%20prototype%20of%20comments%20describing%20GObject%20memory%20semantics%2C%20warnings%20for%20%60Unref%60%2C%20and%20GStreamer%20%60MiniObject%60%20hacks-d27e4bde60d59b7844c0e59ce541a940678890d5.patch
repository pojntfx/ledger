+// docTextSinks returns true when the callable's doc text says the C
+// function takes ownership of (or sinks the floating ref of) the named
+// parameter. GIR carries no structural marker for "container takes a
+// long-term ref via g_object_ref_sink" parenting calls like
+// gtk_box_append or gst_bin_add, but the C-author-written prose in
+// the <doc> element often says "takes ownership of @element" or
+// "sinks the floating reference of @child". When that phrase is
+// present we can sharpen the doc note from the generic hedge.
+//
+// The match anchors on either the @<paramname> form (when the C
+// author bothered with GIR cross-references) or "the <paramname>"
+// (the more common natural-prose form, e.g. gst_bin_add says "takes
+// ownership of the element"). Anchoring keeps the false-positive
+// rate low — a method whose doc happens to contain "takes ownership"
+// in some unrelated sentence won't trigger unless the @paramname or
+// "the paramname" is also present.
+func (c *CallableAttrs) docTextSinks(paramName string) bool {
+	if c.Doc == nil || paramName == "" {
+		return false
+	}
+	doc := strings.ToLower(c.Doc.String)
+	at := "@" + strings.ToLower(paramName)
+	the := "the " + strings.ToLower(paramName)
+	for _, anchor := range []string{at, the} {
+		// Phrasings observed across GLib/GObject/GTK/GStreamer GIRs.
+		for _, phrase := range []string{
+			"takes ownership of " + anchor,
+			"sinks the floating reference of " + anchor,
+			"sinks " + anchor + "'s floating reference",
+			"sinks " + anchor + "'s floating ref",
+			"acquires ownership of " + anchor,
+			anchor + " is consumed by",
+			"consumes " + anchor,
+			anchor + " is now owned by",
+		} {
+			if strings.Contains(doc, phrase) {
+				return true
+			}
+		}
+	}
+	return false
+}
