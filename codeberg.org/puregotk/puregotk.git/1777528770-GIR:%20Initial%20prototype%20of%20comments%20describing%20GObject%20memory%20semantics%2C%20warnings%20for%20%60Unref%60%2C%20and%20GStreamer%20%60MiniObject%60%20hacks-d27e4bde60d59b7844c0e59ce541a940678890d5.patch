From d27e4bde60d59b7844c0e59ce541a940678890d5 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 29 Apr 2026 22:59:30 -0700
Subject: [PATCH] GIR: Initial prototype of comments describing GObject memory semantics, warnings for `Unref`, and GStreamer `MiniObject` hacks

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/internal/gir/pass/pass.go b/internal/gir/pass/pass.go
index d8130717715872e4b41edb02a1303c95d863384e..139e3c0522d905beaf476b159bfc0654a6a6c76b 100644
--- a/internal/gir/pass/pass.go
+++ b/internal/gir/pass/pass.go
@@ -26,6 +26,28 @@ type Pass struct {
 	Parsed []types.Repository
 	Types  types.KindMap
 
+	// MiniObjectDerived holds records that derive from Gst.MiniObject
+	// (transitively). Keys are lowercase "namespace.name" (e.g.
+	// "gst.buffer"). Values are the Go (CamelCase) field name of the
+	// embedded miniobject parent on that record — varies per record
+	// because GIR uses "mini_object" on Buffer/Caps but "parent" on
+	// Promise/Event/Message. MiniObject itself is also keyed here with
+	// an empty value so the lookup map covers the whole hierarchy.
+	// The detection rule is structural: a record's first concrete field
+	// is embedded by value (not as a pointer) and has type Gst.MiniObject
+	// or another miniobject-derived record.
+	MiniObjectDerived map[string]string
+
+	// FloatingRef holds the set of classes that derive (transitively)
+	// from GObject.InitiallyUnowned. Keys are lowercase "namespace.name".
+	// Membership means instances of the type are created with a floating
+	// reference: passing one to a "container" function (Box.Append,
+	// Window.SetChild, Bin.Add, …) sinks the floating ref instead of
+	// borrowing it, even though GIR labels the parameter
+	// transfer-ownership="none". The doc-comment generator uses this
+	// map to swap the generic borrow note for a sink-aware one.
+	FloatingRef map[string]bool
+
 	impModule         string
 	impPackageImports map[string]string
 }
@@ -44,8 +66,10 @@ 		}
