+// classIsFloating resolves typeName (which may be bare like "Widget"
+// or namespaced like "GObject.InitiallyUnowned") into the lowercase
+// "ns.name" key used by Pass.FloatingRef and reports whether it's a
+// known floating-ref class. Bare names default to currentNs.
+func classIsFloating(currentNs, typeName string, floats map[string]bool) bool {
+	if typeName == "" || floats == nil {
+		return false
+	}
+	parts := strings.SplitN(typeName, ".", 2)
+	var key string
+	if len(parts) == 2 {
+		key = strings.ToLower(parts[0]) + "." + parts[1]
+	} else {
+		key = strings.ToLower(currentNs) + "." + parts[0]
+	}
+	return floats[key]
+}
