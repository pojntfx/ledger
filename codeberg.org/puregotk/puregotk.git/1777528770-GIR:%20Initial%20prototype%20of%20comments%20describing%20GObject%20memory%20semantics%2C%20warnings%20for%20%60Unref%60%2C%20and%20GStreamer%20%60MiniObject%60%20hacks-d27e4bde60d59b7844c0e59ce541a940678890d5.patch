+		// parent chain — Object has both, so any GObject descendant
+		// reaches "RefSink" eventually. Use IncreaseRef as a safe
+		// fallback for the rare class with no ref methods declared.
+		// Track curNs so unqualified parent names ("Object" inside
+		// GObject) resolve in the right namespace as we ascend.
+		parent := cls.Parent
+		curNs := ns
