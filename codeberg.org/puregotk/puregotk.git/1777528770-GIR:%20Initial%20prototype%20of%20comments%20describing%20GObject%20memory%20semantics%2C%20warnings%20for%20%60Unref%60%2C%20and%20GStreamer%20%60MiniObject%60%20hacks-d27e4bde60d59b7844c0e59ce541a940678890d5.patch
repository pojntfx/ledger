-	RefSink bool
+	// RefSink, when non-empty, names the auto-Ref strategy applied
+	// after wrapper construction. Possible values:
+	//   "IncreaseRef" — call gobject.IncreaseRef(cret), used for
+	//     GObject interfaces (XBase wrappers don't carry a RefSink
+	//     method). Equivalent to g_object_ref_sink for floating
+	//     objects, plain ref for non-floating.
+	//   "RefSink"     — call cls.RefSink(), used for GObject classes
+	//     and other types whose wrapper exposes a RefSink method.
+	//   "Ref"         — call cls.Ref(), used for fundamental types
+	//     that aren't floating (Gsk.RenderNode, Gdk.Event,
+	//     Gtk.Expression). Their wrappers don't have RefSink.
+	//   ""            — no auto-Ref; the caller already owns the ref
+	//     (transfer="full") or there's nothing to ref (boxed types
+	//     without a generated Ref method).
+	// Picking the right strategy at generation time avoids calling
+	// g_object_ref_sink on non-GObject types like RenderNode, which
+	// the previous generic IncreaseRef path did incorrectly.
+	RefSink string
+	// RecordRef, when non-empty, is a Go expression appended after
+	// "cret." to ref a record return whose transfer="none" gives the
+	// caller a borrowed reference the binding wants to upgrade to a
+	// strong one. It covers two patterns:
+	//   - miniobject-derived records: the field+method path through
+	//     the embedded parent, e.g. "MiniObject.Ref()" or
+	//     "Parent.Ref()". Working through the parent handles records
+	//     like GstSdp.MIKEYPayload that don't surface their own ref
+	//     method in GIR.
+	//   - other refcounted records (Variant, etc.): a direct method
+	//     call like "RefSink()" or "Ref()" on the wrapper itself.
+	// The template emits `if cret != nil { cret.<RecordRef> }`.
+	RecordRef string
 	// Throws indicates whether or not this function throws
 	Throws bool
 }
