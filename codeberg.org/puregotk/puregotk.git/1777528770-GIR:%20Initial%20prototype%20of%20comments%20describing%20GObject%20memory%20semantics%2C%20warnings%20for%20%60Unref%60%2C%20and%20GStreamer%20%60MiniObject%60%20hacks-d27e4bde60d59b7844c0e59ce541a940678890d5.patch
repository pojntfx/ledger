+// refSinkMethod returns the auto-Ref strategy to apply to a returned
+// value of (kind, typeName) at namespace ns. The result is one of
+// "IncreaseRef", "RefSink", "Ref", or "" (no ref). It exists so that
+// types like Gsk.RenderNode (a fundamental, but not a GObject) get a
+// type-correct ref instead of going through gobject.IncreaseRef
+// (which calls g_object_ref_sink and is undefined behavior on a
+// non-GObject pointer).
+//
+// Strategy:
+//   - Interfaces always go through IncreaseRef — XBase wrappers don't
+//     carry generated Ref/RefSink methods.
+//   - Records and classes prefer RefSink when GIR exposes a
+//     <method name="ref_sink">; otherwise fall back to Ref when
+//     <method name="ref"> exists. RefSink is preferred because for
+//     floating-ref types (GObject, ParamSpec, Variant) it's the
+//     correct primitive, and on already-sunk objects it degenerates
+//     to a plain ref.
+//   - When neither method exists we return ""; the value isn't
+//     refcounted in a way the wrapper can name.
+func (km KindMap) refSinkMethod(ns, typeName string) string {
+	if typeName == "" {
+		return ""
+	}
+	pair, ok := km[km.key(ns, typeName)]
+	if !ok {
+		return ""
+	}
+	switch pair.K {
+	case InterfacesType:
+		return "IncreaseRef"
+	case ClassesType:
+		cls, ok := pair.Value.(Class)
+		if !ok {
+			return "IncreaseRef"
+		}
+		hasRefSink, hasRef := false, false
+		for _, m := range cls.Methods {
+			switch m.Name {
+			case "ref_sink":
+				hasRefSink = true
+			case "ref":
+				hasRef = true
+			}
+		}
+		if hasRefSink {
+			return "RefSink"
+		}
+		if hasRef {
+			return "Ref"
+		}
