+			pNs := curNs
+			pName := parent
+			if parts := strings.SplitN(parent, ".", 2); len(parts) == 2 {
+				pNs = parts[0]
+				pName = parts[1]
+			}
+			parentPair, ok := km[km.key(pNs, pName)]
+			if !ok {
+				break
+			}
+			parentCls, ok := parentPair.Value.(Class)
+			if !ok {
+				break
+			}
+			for _, m := range parentCls.Methods {
+				switch m.Name {
+				case "ref_sink":
+					hasRefSink = true
+				case "ref":
+					hasRef = true
+				}
+			}
+			if hasRefSink {
+				return "RefSink"
+			}
+			if hasRef {
+				return "Ref"
+			}
+			parent = parentCls.Parent
+			curNs = pNs
+		}
+		return "IncreaseRef"
+	case RecordsType:
+		rec, ok := pair.Value.(Record)
+		if !ok {
+			return ""
+		}
+		hasRefSink, hasRef := false, false
+		for _, m := range rec.Methods {
+			switch m.Name {
+			case "ref_sink":
+				hasRefSink = true
+			case "ref":
+				hasRef = true
+			}
+		}
+		if hasRefSink {
+			return "RefSink"
+		}
+		if hasRef {
+			return "Ref"
+		}
+		return ""
+	default:
+		return ""
+	}
+}
