+// releaseVerb returns the Go method name a caller should invoke to
+// release a value of (kind, typeName) at the given namespace, or "" if
+// no release call is appropriate (primitives, strings, slices, raw
+// uintptr returns where the wrapper carries no release method).
+//
+// Class/interface returns are wrapped as GObject subclasses, which
+// always expose an Unref() method via the gobject.Object base. Record
+// returns vary: miniobject-derived records have generated Unref()
+// methods; boxed types like glib.Error expose Free(); GValue uses
+// Unset() to clear its content; others (e.g. Caps, Variant) expose
+// Unref() through a GIR-declared method named "unref". Preference
+// order: Unref > Free > Unset (Unref is the canonical refcounted
+// release; Free is for owned-allocation boxed types; Unset is the
+// odd-one-out for GValue's "clear contents" semantics). When none
+// exists in the GIR we return "" so the generator stays silent
+// rather than telling users to call a method that doesn't exist.
+func (km KindMap) releaseVerb(ns, typeName string) string {
+	if typeName == "" {
+		return ""
+	}
+	pair, ok := km[km.key(ns, typeName)]
+	if !ok {
+		return ""
+	}
+	switch pair.K {
+	case ClassesType, InterfacesType:
+		return "Unref"
+	case RecordsType:
+		rec, ok := pair.Value.(Record)
+		if !ok {
+			return ""
+		}
+		hasUnref, hasFree, hasUnset := false, false, false
+		for _, m := range rec.Methods {
+			switch m.Name {
+			case "unref":
+				hasUnref = true
+			case "free":
+				hasFree = true
+			case "unset":
+				hasUnset = true
+			}
+		}
+		if hasUnref {
+			return "Unref"
+		}
+		if hasFree {
+			return "Free"
+		}
+		if hasUnset {
+			return "Unset"
+		}
+		return ""
+	default:
+		return ""
+	}
+}
+
+// verbOr returns verb when non-empty, fallback otherwise. Used by
+// the doc generator when a release-method lookup might come back
+// empty (e.g. for cross-namespace types whose definition we couldn't
+// inspect) but the surrounding sentence still needs a verb to read.
+func verbOr(verb, fallback string) string {
+	if verb == "" {
+		return fallback
+	}
+	return verb
+}
