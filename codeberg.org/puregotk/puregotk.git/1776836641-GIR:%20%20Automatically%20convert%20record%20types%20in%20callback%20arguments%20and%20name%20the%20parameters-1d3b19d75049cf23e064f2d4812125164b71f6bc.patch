+				apiTypes := args.API.Full
 
 				var doc string
 				if f.Callback.Doc != nil && f.Callback.Doc.String != "" {
@@ -362,7 +364,7 @@ 		cbImps := types.NewImportSet(pkgName, p.impModule, p.impPackageImports)
 		cbT := types.CallbackTemplate{
 			Doc:  cb.Doc.StringSafe(),
