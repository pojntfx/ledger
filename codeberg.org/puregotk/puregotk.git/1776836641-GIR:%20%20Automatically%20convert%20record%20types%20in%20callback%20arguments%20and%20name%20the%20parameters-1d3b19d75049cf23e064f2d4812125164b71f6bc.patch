diff --git a/internal/gir/types/template.go b/internal/gir/types/template.go
index 4f3d352725344c7fdda20d7cf335d498dc44621a..cff256d324901ff0c35071996a6009200d472604 100644
--- a/internal/gir/types/template.go
+++ b/internal/gir/types/template.go
@@ -20,6 +20,21 @@
 	Full []string
 }
 
+// NamedTypes pairs each Type with its corresponding Name, falling back to an
+// anonymous `type` entry when there's no name (e.g. the trailing **glib.Error
+// appended by AddThrows, which is added to Types but not Names).
+func (a argsTemplate) NamedTypes() []string {
+	out := make([]string, len(a.Types))
+	for i, t := range a.Types {
+		if i < len(a.Names) && a.Names[i] != "" {
+			out[i] = a.Names[i] + " " + t
+		} else {
+			out[i] = t
+		}
+	}
+	return out
+}
+
 type funcArgsTemplate struct {
 	// Pure are the arguments as passed directly to PureGo
 	// The pure Call is a special case that contains the arguments for a callback call
@@ -166,7 +181,7 @@
 	return false
 }
 
-func (f *funcArgsTemplate) Add(p Parameter, ins string, ns string, kinds KindMap, imps *ImportSet) {
+func (f *funcArgsTemplate) Add(p Parameter, ins string, ns string, kinds KindMap, callbackLike bool, imps *ImportSet) {
 	// get the lookup namespace
 	// as if the interface namespace is non-empty
 	// means we can also lookup in the namespace of the interface
@@ -187,23 +202,74 @@ 	if stars > 0 {
 		goType = util.StarsInFront(strings.ReplaceAll(goType, "*", ""), stars)
 	}
 
+	// Callback-like contexts: a bare `<type name="Record"/>` in a signal or <callback>
+	// is a `Record*` in C. Type.Template collapsed it to "uintptr"; recover the real
+	// type so the public API surfaces `*Record` while the wire stays uintptr.
+	var cbRecordType string
+	if callbackLike && goType == "uintptr" && p.AnyType.Type != nil {
+		tn := p.AnyType.Type.Name
+		if tn != "" && kinds.Kind(lns, tn) == RecordsType {
+			normalized := util.NormalizeNamespace(ns, tn, true)
+			if !isGoPrimitive(normalized) {
+				normalized = util.AddNamespace(normalized, ins)
+			}
+			cbRecordType = "*" + normalized
+			kind = RecordsType
+		}
+	}
+
 	// Get a suitable variable name
 	varName := p.VarName()
 
 	isOut := p.Direction == "out"
 
+	if cbRecordType != "" {
+		f.addCallbackRecord(cbRecordType, varName, isOut, imps)
+		return
+	}
+
 	f.AddAPI(goType, varName, kind, ns, p.Nullable, isOut, imps)
 	f.AddPure(goType, varName, kind, isOut)
 }
 
+// addCallbackRecord handles a record-pointer arg in a callback-like context.
+// In GIR, signal/callback record params are declared bare (no `*`) but the C
+// ABI passes them as `Record*`. A pointer slot is ABI-compatible with both
+// `uintptr` and `*Record`, so we render both sides as `*Record` directly — no
+// casts needed, and the standalone callback-type declaration can keep using
+// Pure.Types without dragging in interface types that purego can't decode.
+func (f *funcArgsTemplate) addCallbackRecord(recType, varName string, isOut bool, imps *ImportSet) {
+	imps.TrackGoType(recType)
+
+	// Public (API) side.
+	f.API.Names = append(f.API.Names, varName)
+	f.API.Types = append(f.API.Types, recType)
+	f.API.Call = append(f.API.Call, varName)
+	f.API.Full = append(f.API.Full, varName+" "+recType)
+
+	// Pure (wire) side: same type so signal fcb wrappers can forward the value
+	// straight through to the user callback with no conversion.
+	pureName := varName + "p"
+	f.Pure.Names = append(f.Pure.Names, pureName)
+	f.Pure.Types = append(f.Pure.Types, recType)
+	f.Pure.Call = append(f.Pure.Call, pureName)
+	f.Pure.Full = append(f.Pure.Full, pureName+" "+recType)
+	_ = isOut // callback-like record params are always "in" in practice
+}
+
 func (f *funcArgsTemplate) AddThrows(ns string, imps *ImportSet) {
 	f.API.Call = append(f.API.Call, "&cerr")
-	if strings.ToLower(ns) != "glib" {
-		f.Pure.Types = append(f.Pure.Types, "**glib.Error")
+	errType := "**glib.Error"
+	if strings.ToLower(ns) == "glib" {
+		errType = "**Error"
+	} else {
 		imps.AddPkg("glib")
-	} else {
-		f.Pure.Types = append(f.Pure.Types, "**Error")
 	}
+	f.Pure.Types = append(f.Pure.Types, errType)
+	// A throws param has no GIR-visible name. Keep Names aligned with Types so
+	// NamedTypes renders a named trailing entry (the Go parser doesn't allow
+	// mixing named and anonymous params in a single signature).
+	f.Pure.Names = append(f.Pure.Names, "errp")
 }
 
 type CallbackTemplate struct {
diff --git a/internal/gir/types/types.go b/internal/gir/types/types.go
index 4854b8d6240fd4de9a4694d3c2e01c37186efc35..8c15e609e2730ca6e454393090126ed84743653a 100644
--- a/internal/gir/types/types.go
+++ b/internal/gir/types/types.go
@@ -675,10 +675,23 @@ 	return snaked + "Var"
 }
 
 func (p *Parameters) Template(ns string, ifacens string, kinds KindMap, throws bool, imps *ImportSet) funcArgsTemplate {
+	return p.template(ns, ifacens, kinds, throws, false, imps)
+}
+
+// TemplateCallback is like Template but flags the context as callback-like
+// (signals, GIR <callback> declarations, and <field><callback/></field> accessors).
+// In callback-like contexts, records passed bare in GIR (e.g. <type name="PublicKey"/>)
+// are actually `PublicKey*` in C, so the public API surfaces them as `*PublicKey`
+// with the wire representation staying `uintptr`.
+func (p *Parameters) TemplateCallback(ns string, ifacens string, kinds KindMap, throws bool, imps *ImportSet) funcArgsTemplate {
+	return p.template(ns, ifacens, kinds, throws, true, imps)
+}
+
+func (p *Parameters) template(ns string, ifacens string, kinds KindMap, throws, callbackLike bool, imps *ImportSet) funcArgsTemplate {
 	args := funcArgsTemplate{}
 	if p != nil {
 		for _, par := range p.Parameters {
-			args.Add(par, ifacens, ns, kinds, imps)
+			args.Add(par, ifacens, ns, kinds, callbackLike, imps)
 		}
 	}
 	if throws {
