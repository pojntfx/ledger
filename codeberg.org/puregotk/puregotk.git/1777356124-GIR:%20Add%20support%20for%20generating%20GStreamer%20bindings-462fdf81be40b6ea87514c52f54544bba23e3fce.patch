+#     -i '///_:type[not(@name) and @c:type="D3D12_RESOURCE_DIMENSION"]' -t 'attr' -n 'name' -v "gint" \
+#     -u '//_:type[@c:type="D3D12_RESOURCE_DIMENSION"]/@c:type' -v "gint" \
