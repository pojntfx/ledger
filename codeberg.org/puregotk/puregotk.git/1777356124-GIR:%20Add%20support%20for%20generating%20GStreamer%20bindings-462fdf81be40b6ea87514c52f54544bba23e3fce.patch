diff --git a/internal/gir/pass/pass.go b/internal/gir/pass/pass.go
index 270117cf2050e8a7c8d97a0e7640bf32922d4122..d8130717715872e4b41edb02a1303c95d863384e 100644
--- a/internal/gir/pass/pass.go
+++ b/internal/gir/pass/pass.go
@@ -302,10 +302,8 @@ 				if _type == "string" {
 					_type = "uintptr"
 				}
 
-				// HACK: Special handling for parent_class field - it should be embedded as a full struct
-				// to match C's memory layout, not converted to uintptr
-				// See https://docs.gtk.org/gobject/tutorial.html
-				if f.Name == "parent_class" && f.AnyType.Type != nil {
+				// Embed all other non-array types in record
+				if f.AnyType.Type != nil {
 					// Check if this is a Record type with no pointers (embedded struct)
 					typeName := util.NormalizeNamespace(ns.Name, f.AnyType.Type.Name, true)
 					kind := p.Types.Kind(ns.Name, typeName)
diff --git a/internal/gir/types/template.go b/internal/gir/types/template.go
index 91dede9e5c2c12178234f2fab7de67f39932fc43..ff8690f742e6589e4faca22577a5690b49fd9ecb 100644
--- a/internal/gir/types/template.go
+++ b/internal/gir/types/template.go
@@ -172,14 +172,19 @@ 		return r == '*' || r == '[' || r == ']' || (r >= '0' && r <= '9')
 	})
 }
 
-// isGoPrimitive checks if a scalar or vector type name is a Go primitive type
-func isGoPrimitive(typeName string) bool {
+// isGoBuiltin checks if a scalar or vector type name is a Go built-in type
+func isGoBuiltin(typeName string) bool {
 	baseType := baseTypeName(typeName)
 
 	for _, goType := range convList {
 		if goType == baseType {
 			return true
 		}
+	}
+
+	// interface{} is also a built-in type
+	if strings.Contains(typeName, "interface{}") {
+		return true
 	}
 
 	return false
@@ -199,7 +204,7 @@
 	stars := strings.Count(goType, "*")
 	goType = util.NormalizeNamespace(ns, goType, true)
 
-	if kind != OtherType && kind != UnknownType && !isGoPrimitive(goType) { // Only add namespace for non-primitive types
+	if kind != OtherType && kind != UnknownType && !isGoBuiltin(goType) { // Only add namespace for non-built in types
 		goType = util.AddNamespace(goType, ins)
 	}
 	if stars > 0 {
