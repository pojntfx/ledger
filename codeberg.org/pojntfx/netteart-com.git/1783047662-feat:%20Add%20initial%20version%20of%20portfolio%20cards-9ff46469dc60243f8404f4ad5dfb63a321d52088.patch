diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index 76c6f665c7db2f7504eb4c6e5657542bb4405e0e..6263f974069b38c8db27fd34406fe2e98c287f84 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -496,3 +496,53 @@
 .portfolio-tabs-content-section {
   --pf-v6-c-page--section--m-limit-width--MaxWidth: 80rem;
 }
+
+.portfolio-item-card {
+  .pf-v6-c-card__footer {
+    position: absolute;
+    bottom: 0;
+    z-index: 1;
+
+    @extend .pf-v6-u-p-md;
+  }
+
+  .pf-v6-c-card__title {
+    @extend .pf-v6-u-pb-md;
+
+    background: transparent;
+  }
+
+  .pf-v6-c-card__body {
+    padding: 0;
+    overflow: hidden;
+  }
+
+  .pf-v6-c-card__header {
+    z-index: 1;
+    background: transparent;
+    position: absolute;
+    width: 100%;
+    height: 100%;
+    align-items: end;
+    background: linear-gradient(
+      to top,
+      var(--pf-v6-c-card--BackgroundColor),
+      transparent
+    );
+
+    @extend .pf-v6-u-p-md;
+  }
+
+  img {
+    width: 100%;
+    max-width: 10rem;
+    max-height: fit-content;
+    transform: scale(1.1);
+    transition: transform 500ms ease-in-out;
+    position: relative !important;
+  }
+
+  .pf-v6-c-card__selectable-actions ::before {
+    background: transparent;
+  }
+}
