From 54789c3c2eee414f594cf420453e7b744082c73a Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Fri, 03 Jul 2026 22:55:30 -0700
Subject: [PATCH] feat: Make skip to content button function properly with PF scroll container

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/layouts/baseof.html b/layouts/baseof.html
index 35dfb98dca77d42418b17a3fa5740de2567c064e..58b59d4f528625a20625bc946876622c5cf0eba9 100644
--- a/layouts/baseof.html
+++ b/layouts/baseof.html
@@ -86,11 +86,14 @@   </head>
 
   <body>
     <div class="pf-v6-c-page pf-m-no-sidebar">
+      {{ if not .IsHome }}
+      <!-- We don't need the skip to content button on the home page, there is no masthead -->
       <div class="pf-v6-c-skip-to-content">
         <a class="pf-v6-c-button pf-m-primary" href="#main-content">
           <span class="pf-v6-c-button__text">Zum Inhalt springen</span>
         </a>
       </div>
+      {{ end }}
 
       {{ if not .IsHome }}
       <header class="pf-v6-c-masthead">
@@ -121,7 +124,6 @@       <div class="pf-v6-c-page__main-container {{ if .IsHome }}pf-v6-c-page__main-container--home{{ end }}" tabindex="-1"> 
         <div
           class="pf-v6-c-page__main"
           tabindex="-1"
-          id="main-content"
           style="--pf-v6-c-page--section--m-limit-width--MaxWidth: 62rem"
         >
           {{ block "main" . }}{{ end }}
diff --git a/layouts/single.html b/layouts/single.html
index ea9d65a9dc7ed0aee4ed2739c65bd59acaefe470..8991c30354ec6a5727703a6d56c46c480083308b 100644
--- a/layouts/single.html
+++ b/layouts/single.html
@@ -4,6 +4,7 @@   <!-- #main-title is in masthead -->
   <section
     class="pf-v6-c-page__main-section pf-m-limit-width pf-m-align-center"
     aria-labelledby="main-title"
+    id="main-content"
   >
     <div class="pf-v6-c-page__main-body">
       <div class="pf-v6-c-content">{{ .Content }}</div>

