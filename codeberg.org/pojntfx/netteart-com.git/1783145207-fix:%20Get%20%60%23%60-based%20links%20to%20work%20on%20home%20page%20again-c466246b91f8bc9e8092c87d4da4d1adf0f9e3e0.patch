From c466246b91f8bc9e8092c87d4da4d1adf0f9e3e0 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Fri, 03 Jul 2026 23:06:47 -0700
Subject: [PATCH] fix: Get `#`-based links to work on home page again

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index e10df2cc2c4f18bfcd52b265fd3bc3329d5a9396..bbc43708226d754304f3f57e8de0c1e6621b0b27 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -320,6 +320,19 @@   @extend .pf-v6-u-m-0;
   border-radius: 0;
   min-height: 100%;
   border: 0;
+
+  // On the home page we want the page itself to scroll so that `#`-based navigation
+  // works as expected
+  .pf-v6-c-page__main {
+    overflow: visible;
+  }
+}
+
+// Since we want the page itself to scroll on the home page, we need to allow the
+// page container to grow vertically too
+.pf-v6-c-page:has(.pf-v6-c-page__main-container--home) {
+  height: auto;
+  max-height: none;
 }
 
 .pf-v6-c-masthead {

