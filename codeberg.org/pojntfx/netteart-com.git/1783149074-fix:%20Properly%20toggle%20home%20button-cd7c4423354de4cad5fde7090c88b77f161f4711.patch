From cd7c4423354de4cad5fde7090c88b77f161f4711 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Sat, 04 Jul 2026 00:11:14 -0700
Subject: [PATCH] fix: Properly toggle home button

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index 67226502048a223d9a5ee7071f669beb929e666d..cb424da8ea71df10dd5453021e50ae1c2d5d9c13 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -264,25 +264,33 @@     );
 
     const navHeader = document.querySelector("#nav--header");
     const footer = document.querySelector("#footer");
+
     const btnBackToTop = document.querySelector("#back-to-top");
 
+    let navHeaderVisible = false;
+    let footerVisible = false;
+
+    const syncState = () => {
+      if (navHeaderVisible || footerVisible) {
+        btnBackToTop.classList.add("pf-m-hidden");
+      } else {
+        btnBackToTop.classList.remove("pf-m-hidden");
+      }
+    };
+
     const observer = new IntersectionObserver((entries) =>
       entries.forEach((entry) => {
         switch (entry.target.id) {
           case navHeader.id:
-            if (entry.isIntersecting) {
-              btnBackToTop.classList.add("pf-m-hidden");
-            } else {
-              btnBackToTop.classList.remove("pf-m-hidden");
-            }
+            navHeaderVisible = entry.isIntersecting;
+
+            break;
 
           case footer.id:
-            if (entry.isIntersecting) {
-              btnBackToTop.classList.add("pf-m-hidden");
-            } else {
-              btnBackToTop.classList.remove("pf-m-hidden");
-            }
+            footerVisible = entry.isIntersecting;
         }
+
+        syncState();
       }),
     );
 

