From 9490c285f7fb2c5ec207cd1b0f4bbf3d01bf0ce3 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Thu, 02 Jul 2026 20:37:52 -0700
Subject: [PATCH] feat: Add masonry layout to home page and fill out example images

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index 6263f974069b38c8db27fd34406fe2e98c287f84..e10df2cc2c4f18bfcd52b265fd3bc3329d5a9396 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -495,9 +495,33 @@ }
 
 .portfolio-tabs-content-section {
   --pf-v6-c-page--section--m-limit-width--MaxWidth: 80rem;
+  width: 100%;
+  max-width: var(--pf-v6-c-page--section--m-limit-width--MaxWidth);
+
+  .pf-v6-c-page__main-body {
+    width: 100%;
+    max-width: 100%;
+  }
+}
+
+.portfolio-masonry {
+  columns: 160px auto;
+  column-gap: var(--pf-t--global--spacer--md);
+  width: 100%;
+
+  > .pf-v6-c-card {
+    display: block;
+    break-inside: avoid;
+    margin-bottom: var(--pf-t--global--spacer--md);
+    width: 100%;
+  }
 }
 
 .portfolio-item-card {
+  position: relative;
+  overflow: hidden;
+  overflow-wrap: break-word; // Long German compound words also need to break
+
   .pf-v6-c-card__footer {
     position: absolute;
     bottom: 0;
@@ -507,7 +531,7 @@     @extend .pf-v6-u-p-md;
   }
 
   .pf-v6-c-card__title {
-    @extend .pf-v6-u-pb-md;
+    @extend .pf-v6-u-pb-lg;
 
     background: transparent;
   }
@@ -535,14 +559,15 @@   }
 
   img {
     width: 100%;
-    max-width: 10rem;
-    max-height: fit-content;
-    transform: scale(1.1);
-    transition: transform 500ms ease-in-out;
-    position: relative !important;
+    height: auto;
+    display: block;
   }
 
   .pf-v6-c-card__selectable-actions ::before {
     background: transparent;
+  }
+
+  .pf-v6-c-card__header-main {
+    width: 100%;
   }
 }
