diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index deb09e9271595d7e3399eac40e70c11fa5d0b231..dcad61dd5cc56e1d00a9f389f5885609dab7d4de 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -730,3 +730,8 @@   &:last-child {
     @extend .pf-v6-u-mr-lg;
   }
 }
+
+.external-icon {
+  display: inline;
+  white-space: nowrap;
+}
diff --git a/layouts/_partials/footer.html b/layouts/_partials/footer.html
index 8f3011a3b5c3d36ba62d676caa1d4b6181aa0ce9..eb1dbed9cba6e0f57fbc37beb688261f430cd196 100644
--- a/layouts/_partials/footer.html
+++ b/layouts/_partials/footer.html
@@ -12,14 +12,23 @@         target="_blank"
         rel="noopener"
         class="pf-v6-l-grid__item pf-m-12-col pf-m-6-col-on-xl"
       >
-        © {{ now.Year }} {{ hugo.Data.site.author }}
+        © {{ now.Year }} {{ hugo.Data.site.author }}<span class="external-icon"
+          >&#8288;<i
+            class="fa-solid fa-arrow-up-right-from-square pf-v6-u-ml-xs"
+            aria-hidden="true"
+          ></i
+        ></span>
       </a>
       <div
         class="pf-v6-l-grid__item pf-m-12-col pf-m-6-col-on-xl pf-v6-u-text-align-end-on-xl"
       >
         <a href="{{ hugo.Data.site.source }}" target="_blank" rel="noopener"
-          >Quelltext</a
-        >
+          >Quelltext<span class="external-icon"
+            >&#8288;<i
+              class="fa-solid fa-arrow-up-right-from-square pf-v6-u-ml-xs"
+              aria-hidden="true"
+            ></i></span
+        ></a>
         <a href="/privacy">Datenschutzerklärung</a>
         <a href="/terms">Nutzungsbedingungen</a>
         <a href="/imprint">Impressum</a>

