From 1745b2e758ff5a5ed8ec1e59edde421f8b0b9bd6 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Fri, 10 Jul 2026 19:35:17 -0700
Subject: [PATCH] feat: Make sticky header more compact when it's stuck on top to improve readability on mobile

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index 1c64e1f0efe04dde07227f2f9ff0a59835c267b8..dc43688b8836d4ec9f070c8ac8efaf89b90c8aff 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -642,8 +642,42 @@ .modal-pagination {
   font-variant-numeric: tabular-nums;
 }
 
-.portfolio-section.pf-m-sticky-top:not(.pf-m-stuck) {
-  box-shadow: none;
+.portfolio-section.pf-m-sticky-top {
+  &:not(.pf-m-stuck) {
+    box-shadow: none;
+  }
+
+  // See https://www.patternfly.org/foundations-and-styles/motion/development-guide
+  // --pf-t--global--motion-timing-function--default seems to be undefined outside of
+  // specific components
+  .portfolio-tabs-wrapper > .pf-v6-c-title {
+    transition: all var(--pf-t--global--motion--duration--fade--default, 200ms)
+      var(
+        --pf-t--global--motion-timing-function--default,
+        cubic-bezier(0.4, 0, 0.2, 1)
+      );
+  }
+
+  .portfolio-tabs-wrapper .pf-v6-c-title {
+    text-align: center;
+  }
+
+  &.pf-m-stuck {
+    @extend .pf-v6-u-py-md;
+
+    .portfolio-tabs-wrapper {
+      > h2.pf-v6-c-title {
+        @extend .pf-m-lg;
+      }
+
+      > p.pf-v6-c-title {
+        // We can't overwrite a larger size by @extend-ing with a smaller size
+        font-size: var(--pf-t--global--font--size--sm);
+
+        @extend .pf-v6-u-mb-sm;
+      }
+    }
+  }
 }
 
 // Fixes to make sure our page doesn't overflow horizontally and narrow screens
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index e57aab0090c0718be86faddee8d33cbbdb6d0f18..44db7fdfa0da0eba28f62e0923d926be798f7005 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -79,7 +79,7 @@ <hr class="pf-v6-c-divider" />
 
 <div class="portfolio-group {{ if eq (mod $i 2 ) 0 }}portfolio-group--striped{{ end }}">
 <section
-  class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center pf-m-sticky-top pf-v6-u-pt-lg pf-v6-u-pb-lg portfolio-section pf-v6-u-px-0 {{ if eq (mod $i 2 ) 0 }}portfolio-section--striped{{ end }}"
+  class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center pf-m-sticky-top pf-v6-u-py-lg portfolio-section pf-v6-u-px-0 {{ if eq (mod $i 2 ) 0 }}portfolio-section--striped{{ end }}"
   id="{{ $group.id }}"
 >
   <div class="portfolio-tabs-wrapper">

