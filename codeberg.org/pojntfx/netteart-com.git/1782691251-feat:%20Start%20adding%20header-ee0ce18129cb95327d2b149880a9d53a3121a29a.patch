From ee0ce18129cb95327d2b149880a9d53a3121a29a Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Sun, 28 Jun 2026 17:00:51 -0700
Subject: [PATCH] feat: Start adding header

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index 2bc1e662c7d1c7f4b38f71218b38abf2a9d4296f..42da4d96981c6ee57e861529e4cc8a8fa7d3aa44 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -50,12 +50,6 @@   background-repeat: no-repeat;
   background-size: cover;
 }
 
-.logo--home {
-  width: auto;
-  max-width: 15rem;
-  padding-left: 8px; // Visual centering
-}
-
 .pf-v6-c-masthead {
   --pf-v6-c-masthead--ColumnGap: 0;
   --pf-v6-c-masthead--GridTemplateColumns: min-content max-content;
@@ -88,3 +82,54 @@ // We should fix this so that both the footer and content are clamped in the same way.
 footer.pf-v6-c-page__main-section {
   align-items: center;
 }
+
+.logo--home {
+  width: auto;
+  max-width: 10rem;
+  padding-left: 8px; // Visual centering
+
+  margin-left: auto;
+  margin-right: auto;
+
+  @media (min-width: $pf-v6-global--breakpoint--sm) {
+    margin-left: 0;
+    margin-right: 0;
+
+    max-width: 12rem;
+    flex-direction: row;
+  }
+}
+
+.hero {
+  @extend .pf-v6-u-py-2xl;
+  background: transparent;
+
+  flex-direction: column;
+  & > h1 {
+    margin: 0 auto;
+  }
+
+  @media (min-width: $pf-v6-global--breakpoint--sm) {
+    flex-direction: row;
+  }
+
+  max-width: var(--pf-v6-c-page--section--m-limit-width--MaxWidth);
+  margin-left: 0;
+  margin-right: 0;
+
+  &__details {
+    @extend .pf-v6-u-mt-lg;
+    @extend .pf-v6-u-mt-0-on-md;
+
+    @extend .pf-v6-u-ml-lg-on-md;
+
+    display: flex;
+    flex-direction: column;
+    justify-content: center;
+    align-items: flex-start;
+  }
+}
+
+.main--home {
+  align-items: center;
+}
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index ab24f61f5ef269f523531cf4b6e39ab413dd37e4..1cf76e28a32934a6c4fd6b4db4e7d26fc1e000f3 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -1,11 +1,20 @@
-<div class="pf-v6-l-bullseye pf-v6-u-flex-1">
-  <div
-    class="pf-v6-l-bullseye__item pf-v6-l-flex pf-m-column pf-m-align-items-center pf-m-space-items-lg"
-  >
-    <h1 class="pf-v6-c-title pf-m-2xl">Coming soon</h1>
+<section class="pf-v6-c-page__main-section hero">
+  <img alt="NetteART Logo" src="/design/icon.svg" class="logo--home" />
+
+  <div class="hero__details">
+    <h1 class="pf-v6-c-title pf-m-4xl pf-m-page-title pf-v6-u-mb-sm">
+      Grafik & Design aus Baiersbronn
+    </h1>
 
-    <img alt="NetteART Logo" src="/design/icon.svg" class="logo--home" />
+    <p class="pf-v6-c-title pf-m-md pf-v6-u-mb-md">
+      Annette Pojtinger gestaltet seit über 20 Jahren Printmedien,
+      Kommunikationsmittel und visuelle Markenidentitäten für Tourismus,
+      Kommunen und Unternehmen im Schwarzwald.
+    </p>
 
-    <a class="pf-v6-c-title pf-m-md" href="mailto:info@netteart.com">info@netteart.com</a>
+    <a class="pf-v6-c-button pf-m-primary" href="mailto:info@netteart.com">
+      <span class="pf-v6-c-button__icon pf-m-start fas fa-envelope"></span>
+      <span class="pf-v6-c-button__text">Kontakt aufnehmen</span>
+    </a>
   </div>
-</div>
+</section>
diff --git a/layouts/home.html b/layouts/home.html
index 8c5fa8b38ebd65d63455effe01d6894a74879abe..56d2f2342c0b11ecab9e1da99003c4e48fdc6c09 100644
--- a/layouts/home.html
+++ b/layouts/home.html
@@ -1,5 +1,5 @@
 {{ define "main" }}
-  <main class="pf-v6-u-flex-1 pf-v6-u-display-flex pf-v6-u-flex-direction-column">
+  <main class="pf-v6-u-flex-1 pf-v6-u-display-flex pf-v6-u-flex-direction-column main--home">
     {{ partial "section-home" . }}
   </main>
 

