From 3bc09c34ee7646a19e379c35634d8e40accf5071 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Sun, 28 Jun 2026 17:08:01 -0700
Subject: [PATCH] refactor: Use proper width limiter for footer and better structure for home section

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index 42da4d96981c6ee57e861529e4cc8a8fa7d3aa44..c61812b1c7155b89b23972b85af8bb0ec6575496 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -72,17 +72,6 @@ .footer--home {
   background: transparent;
 }
 
-.pf-v6-c-page__main-body {
-  max-width: var(--pf-v6-c-page--section--m-limit-width--MaxWidth);
-}
-
-// TODO: This seems to collapse the section down to <992px, unlike `<main>`,
-// which is bounded by `var(--pf-v6-c-page--section--m-limit-width--MaxWidth)`.
-// We should fix this so that both the footer and content are clamped in the same way.
-footer.pf-v6-c-page__main-section {
-  align-items: center;
-}
-
 .logo--home {
   width: auto;
   max-width: 10rem;
@@ -100,10 +89,14 @@     flex-direction: row;
   }
 }
 
+.pf-v6-c-page__main-section--home {
+  background: transparent;
+}
+
 .hero {
   @extend .pf-v6-u-py-2xl;
-  background: transparent;
 
+  display: flex;
   flex-direction: column;
   & > h1 {
     margin: 0 auto;
@@ -113,15 +106,11 @@   @media (min-width: $pf-v6-global--breakpoint--sm) {
     flex-direction: row;
   }
 
-  max-width: var(--pf-v6-c-page--section--m-limit-width--MaxWidth);
-  margin-left: 0;
-  margin-right: 0;
-
   &__details {
     @extend .pf-v6-u-mt-lg;
-    @extend .pf-v6-u-mt-0-on-md;
+    @extend .pf-v6-u-mt-0-on-sm;
 
-    @extend .pf-v6-u-ml-lg-on-md;
+    @extend .pf-v6-u-ml-lg-on-sm;
 
     display: flex;
     flex-direction: column;
diff --git a/layouts/_partials/footer.html b/layouts/_partials/footer.html
index c7832656bfe6173000336683b7bbe3b6ba854b9d..513262eea258ffaed8f34bd8b8dc2e2ac60ae7c2 100644
--- a/layouts/_partials/footer.html
+++ b/layouts/_partials/footer.html
@@ -1,4 +1,4 @@
-<footer class="pf-v6-c-page__main-section pf-m-no-fill {{ if .IsHome }}footer--home{{ end }}">
+<footer class="pf-v6-c-page__main-section pf-m-limit-width pf-m-align-center pf-m-no-fill {{ if .IsHome }}footer--home{{ end }}">
   <div class="pf-v6-c-page__main-body">
     <div
       class="pf-v6-l-grid pf-m-gutter pf-v6-u-py-xl-on-sm pf-v6-u-py-0-on-md pf-v6-u-align-items-center"
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index 1cf76e28a32934a6c4fd6b4db4e7d26fc1e000f3..b999883f5251b7314ff386a0a2720ce377231759 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -1,20 +1,24 @@
-<section class="pf-v6-c-page__main-section hero">
-  <img alt="NetteART Logo" src="/design/icon.svg" class="logo--home" />
+<section
+  class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center"
+>
+  <div class="pf-v6-c-page__main-body hero">
+    <img alt="NetteART Logo" src="/design/icon.svg" class="logo--home" />
 
-  <div class="hero__details">
-    <h1 class="pf-v6-c-title pf-m-4xl pf-m-page-title pf-v6-u-mb-sm">
-      Grafik & Design aus Baiersbronn
-    </h1>
+    <div class="hero__details">
+      <h1 class="pf-v6-c-title pf-m-4xl pf-m-page-title pf-v6-u-mb-sm">
+        Grafik & Design aus Baiersbronn
+      </h1>
 
-    <p class="pf-v6-c-title pf-m-md pf-v6-u-mb-md">
-      Annette Pojtinger gestaltet seit über 20 Jahren Printmedien,
-      Kommunikationsmittel und visuelle Markenidentitäten für Tourismus,
-      Kommunen und Unternehmen im Schwarzwald.
-    </p>
+      <p class="pf-v6-c-title pf-m-md pf-v6-u-mb-md">
+        Annette Pojtinger gestaltet seit über 20 Jahren Printmedien,
+        Kommunikationsmittel und visuelle Markenidentitäten für Tourismus,
+        Kommunen und Unternehmen im Schwarzwald.
+      </p>
 
-    <a class="pf-v6-c-button pf-m-primary" href="mailto:info@netteart.com">
-      <span class="pf-v6-c-button__icon pf-m-start fas fa-envelope"></span>
-      <span class="pf-v6-c-button__text">Kontakt aufnehmen</span>
-    </a>
+      <a class="pf-v6-c-button pf-m-primary" href="mailto:info@netteart.com">
+        <span class="pf-v6-c-button__icon pf-m-start fas fa-envelope"></span>
+        <span class="pf-v6-c-button__text">Kontakt aufnehmen</span>
+      </a>
+    </div>
   </div>
 </section>

