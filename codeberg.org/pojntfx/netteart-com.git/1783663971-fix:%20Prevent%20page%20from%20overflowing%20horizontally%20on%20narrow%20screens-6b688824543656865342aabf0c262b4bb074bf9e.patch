From 6b688824543656865342aabf0c262b4bb074bf9e Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Thu, 09 Jul 2026 23:12:51 -0700
Subject: [PATCH] fix: Prevent page from overflowing horizontally on narrow screens

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index db7b09e7be4cd07bb7a178ea46b8985153f40846..4721670fef990d17a40c55d8d0625441b496a588 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -641,3 +641,27 @@
 .portfolio-section.pf-m-sticky-top:not(.pf-m-stuck) {
   box-shadow: none;
 }
+
+// Fixes to make sure our page doesn't overflow horizontally and narrow screens
+.pf-v6-c-page__main-container,
+.pf-v6-c-page__main,
+main.pf-v6-u-flex-1,
+.pf-v6-c-page__main-body,
+.pf-v6-c-page__main-section {
+  min-width: 0;
+}
+
+.pf-v6-c-page__main-section {
+  flex-shrink: 1;
+}
+
+.pf-v6-c-nav.pf-m-horizontal,
+.pf-v6-c-tabs {
+  min-width: 0;
+}
+
+.pf-v6-c-nav__list,
+.pf-v6-c-tabs__list {
+  min-width: 0;
+  overflow-x: auto;
+}

