From 7b9636e553c08e74cf116f725a1f73c6a10cf343 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Fri, 03 Jul 2026 23:34:32 -0700
Subject: [PATCH] feat: Add striped sections on home page and make padding properly conform to grid

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index bbc43708226d754304f3f57e8de0c1e6621b0b27..2eda32f6526002136d842bcd18d346fdb6f9368c 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -491,7 +491,7 @@ }
 
 .portfolio-section {
   width: 100%;
-  max-width: var(--pf-v6-c-page--section--m-limit-width--MaxWidth);
+  align-items: center;
 }
 
 .portfolio-tabs-wrapper {
@@ -499,6 +499,7 @@   display: flex;
   flex-direction: column;
   align-items: center;
   width: 100%;
+  max-width: var(--pf-v6-c-page--section--m-limit-width--MaxWidth);
 
   > .pf-v6-c-tabs {
     width: 100%;
@@ -584,3 +585,7 @@   .pf-v6-c-card__header-main {
     width: 100%;
   }
 }
+
+.portfolio-section--striped {
+  background: var(--pf-t--global--background--color--secondary--default);
+}
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index c00637d810d3535f2ac0832b35b4e8e0c715a323..b01522923c0852686443e8e8bcf5bdffb2d5992b 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -1,6 +1,6 @@
 <div class="section--full-width">
   <section
-    class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center pf-v6-c-page__main-section--hero"
+    class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center pf-v6-c-page__main-section--hero pf-v6-u-pb-lg"
   >
     <div class="pf-v6-c-page__main-body">
       <nav
@@ -66,13 +66,12 @@     </div>
   </section>
 </div>
 
-{{ range $i, $group := hugo.Data.portfolioitems }}
-{{ if not ( eq $i 0 ) }}
+{{ range $i, $group := hugo.Data.portfolioitems }} {{ if not ( eq $i 0 ) }}
 <hr class="pf-v6-c-divider" />
 {{ end }}
 
 <section
-  class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center pf-v6-u-mt-md portfolio-section pf-v6-u-px-0"
+  class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center pf-v6-u-pt-lg pf-v6-u-pb-lg portfolio-section pf-v6-u-px-0 {{ if eq (mod $i 2 ) 0 }}portfolio-section--striped{{ end }}"
   id="{{ $group.id }}"
 >
   <div class="portfolio-tabs-wrapper">
@@ -118,7 +117,7 @@   </div>
 </section>
 
 <section
-  class="pf-v6-c-page__main-section pf-v6-u-pt-0 pf-v6-u-mb-md pf-m-limit-width portfolio-tabs-content-section"
+  class="pf-v6-c-page__main-section pf-v6-u-pb-lg pf-v6-u-pt-lg pf-m-limit-width portfolio-tabs-content-section"
 >
   <div class="pf-v6-c-page__main-body">
     {{ range $i, $tab := .items }}

