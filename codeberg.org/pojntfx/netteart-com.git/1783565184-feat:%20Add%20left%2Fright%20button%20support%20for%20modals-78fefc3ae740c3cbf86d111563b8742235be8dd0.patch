From 78fefc3ae740c3cbf86d111563b8742235be8dd0 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 08 Jul 2026 19:46:24 -0700
Subject: [PATCH] feat: Add left/right button support for modals

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index 48d68664c76307bda9bfd044bd2a29a61fb702b8..fcddb79cfe26000552a0d88c71bff130df686329 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -418,14 +418,22 @@
         const lastFocus = e.currentTarget
 
         const closeModal = () => {
+          document.removeEventListener("keydown", onKeyDown)
           modal.remove()
           lastFocus.focus()
         }
-        
+
         const onKeyDown = (e) => {
-          if (e.key === "Escape") {
-            closeModal()
-            document.removeEventListener("keydown", onKeyDown)
+          switch (e.key) {
+            case "Escape":
+              closeModal()
+              break
+            case "ArrowLeft":
+              selectPrevious()
+              break
+            case "ArrowRight":
+              selectNext()
+              break
           }
         }
         document.addEventListener("keydown", onKeyDown)
@@ -461,13 +469,17 @@           nextButton.disabled = atEnd
           nextButton.ariaDisabled = String(atEnd)
         }
 
-        previousButton.addEventListener("click", () => {
+        const selectPrevious = () => {
           if (currentIndex > 0) selectImage(currentIndex - 1)
-        })
+        }
 
-        nextButton.addEventListener("click", () => {
+        const selectNext = () => {
           if (currentIndex < item.images.length - 1) selectImage(currentIndex + 1)
-        })
+        }
+
+        previousButton.addEventListener("click", selectPrevious)
+
+        nextButton.addEventListener("click", selectNext)
 
         selectImage(0)
 

