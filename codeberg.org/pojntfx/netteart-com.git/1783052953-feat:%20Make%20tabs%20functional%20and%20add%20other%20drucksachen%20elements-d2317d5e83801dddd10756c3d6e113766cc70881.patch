diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index 91a9f2f3ecfbd9f3a787b959c243687d2a54dc31..d6472898bc698d56c42b889e725acdb6120579c1 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -90,7 +90,10 @@         role="tablist"
         aria-label="Unterbereiche zu Broschüren, Plakaten und Flyer"
       >
         {{ range $i, $tab := hugo.Data.drucksachen }}
-        <li class="pf-v6-c-tabs__item{{ if eq $i 0 }} pf-m-current{{ end }}" role="presentation">
+        <li
+          class="pf-v6-c-tabs__item{{ if eq $i 0 }} pf-m-current{{ end }}"
+          role="presentation"
+        >
           <button
             type="button"
             class="pf-v6-c-tabs__link"
@@ -112,17 +115,25 @@ <section
   class="pf-v6-c-page__main-section pf-v6-u-pt-0 pf-v6-u-mb-lg pf-m-limit-width portfolio-tabs-content-section"
 >
   <div class="pf-v6-c-page__main-body">
-    {{ range hugo.Data.drucksachen }}
+    {{ range $i, $tab := hugo.Data.drucksachen }}
     <section
       class="pf-v6-c-tab-content"
-      aria-labelledby="{{ .tabID }}"
-      id="{{ .panelID }}"
+      aria-labelledby="{{ $tab.tabID }}"
+      id="{{ $tab.panelID }}"
       role="tabpanel"
       tabindex="0"
+      {{
+      if
+      ne
+      $i
+      0
+      }}hidden{{
+      end
+      }}
     >
       <div class="pf-v6-c-tab-content__body">
         <div class="portfolio-masonry">
-          {{ range .items }}
+          {{ range $tab.items }}
           <div
             class="pf-v6-c-card pf-m-clickable portfolio-item-card"
             id="{{ .id }}"
@@ -206,3 +217,33 @@       </div>
     </div>
   </section>
 </div>
+
+<script>
+  const tabs = document.querySelector(".pf-v6-c-tabs__list[role='tablist']");
+  const panels = document.querySelectorAll(
+    ".pf-v6-c-tab-content[role='tabpanel']",
+  );
+
+  tabs.addEventListener("click", (e) => {
+    const btn = e.target.closest(".pf-v6-c-tabs__link");
+    if (!btn) return; // Ignore events that don't originate from a button
+
+    const panel = document.querySelector(
+      `#${btn.getAttribute("aria-controls")}`,
+    );
+
+    tabs.querySelectorAll(".pf-v6-c-tabs__link").forEach((tab) => {
+      tab.setAttribute("aria-selected", tab.id === btn.id);
+
+      if (tab.id === btn.id) {
+        tab.closest(".pf-v6-c-tabs__item").classList.add("pf-m-current");
+      } else {
+        tab.closest(".pf-v6-c-tabs__item").classList.remove("pf-m-current");
+      }
+    });
+
+    panels.forEach(
+      (candidate) => (candidate.hidden = candidate.id != panel.id),
+    );
+  });
+</script>

