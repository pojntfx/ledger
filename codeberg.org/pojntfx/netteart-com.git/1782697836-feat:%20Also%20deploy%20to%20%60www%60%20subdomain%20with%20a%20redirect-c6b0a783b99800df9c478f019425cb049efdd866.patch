From c6b0a783b99800df9c478f019425cb049efdd866 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Sun, 28 Jun 2026 18:50:36 -0700
Subject: [PATCH] feat: Also deploy to `www` subdomain with a redirect

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/.domains b/.domains
deleted file mode 100644
index dd83c15d90d8d34cfeb12a92b1e7dfe79ac7680b..0000000000000000000000000000000000000000
--- a/.domains
+++ /dev/null
@@ -1 +0,0 @@
-netteart.com
\ No newline at end of file
diff --git a/.forgejo/workflows/hugo.yaml b/.forgejo/workflows/hugo.yaml
index db86d38c49565a099dbb7176a46e030fa0704959..0c324607be106ff00085b149bd59f8b71c7ebdf1 100644
--- a/.forgejo/workflows/hugo.yaml
+++ b/.forgejo/workflows/hugo.yaml
@@ -45,10 +45,18 @@           hugo build \
             --gc \
             --minify \
             --baseURL "https://netteart.com/"
-      - name: Deploy to Forgejo Pages
+      - name: Deploy to Forgejo Pages at netteart.com
         uses: actions/git-pages@v2
         with:
           site: https://netteart.com/
           server: codeberg.page
           token: ${{ forge.token }}
           source: public/
+      # See https://docs.codeberg.org/codeberg-pages/using-custom-domain/#deploying-to-versions-of-your-domain-both-with-and-without-www.
+      - name: Deploy to Forgejo Pages at www.netteart.com
+        uses: actions/git-pages@v2
+        with:
+          site: https://www.netteart.com/
+          server: codeberg.page
+          token: ${{ forge.token }}
+          source: public/
diff --git a/static/_redirects b/static/_redirects
new file mode 100644
index 0000000000000000000000000000000000000000..52915211ab6fef41b973fa6c7dc63b31828e76d9
--- /dev/null
+++ b/static/_redirects
@@ -0,0 +1 @@
+//www.netteart.com/* https://netteart.com/:splat 301!

