index 69c713c16397c2a4590d8b91af0c8ecb717e9943..c63b9cd985d583093eb4abf0f945ee1b1bcb6751 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -597,3 +597,19 @@ .pf-v6-c-back-to-top--home {
   // We made the whole home page scroll, so we can't use the regular back to top button positioning anymore
   position: fixed;
 }
+
+.modal-actions-footer {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+}
+
+.modal-actions-body {
+  display: flex;
+  align-content: center;
+  justify-content: center;
+
+  > img {
+    width: 100%;
+  }
+}
