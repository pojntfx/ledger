From 22356e6aafc5e6784e7fd28d966103ee44b10bdc Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Sun, 28 Jun 2026 17:21:01 -0700
Subject: [PATCH] feat: Add outro section to home page

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index c61812b1c7155b89b23972b85af8bb0ec6575496..86b54d3ce88286440dbf4d5e8b8a5cf3a744a217 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -93,6 +93,10 @@ .pf-v6-c-page__main-section--home {
   background: transparent;
 }
 
+.pf-v6-c-page__main-section--hero {
+  min-height: 75vh;
+}
+
 .hero {
   @extend .pf-v6-u-py-2xl;
 
@@ -122,3 +126,23 @@
 .main--home {
   align-items: center;
 }
+
+.logo--outro {
+  width: auto;
+  max-width: 10rem;
+  padding-left: 8px; // Visual centering
+}
+
+.outro {
+  @extend .pf-v6-u-py-2xl;
+
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+}
+
+.pf-v6-c-page__main-section--outro {
+  justify-content: center;
+  // Best-effort; 53px for the footer
+  min-height: calc(100vh - 53px);
+}
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index b999883f5251b7314ff386a0a2720ce377231759..8425c5b1b2349e3ea2b54e87a7c0ab93f07582f1 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -1,5 +1,5 @@
 <section
-  class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center"
+  class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center pf-v6-c-page__main-section--hero"
 >
   <div class="pf-v6-c-page__main-body hero">
     <img alt="NetteART Logo" src="/design/icon.svg" class="logo--home" />
@@ -22,3 +22,25 @@       </a>
     </div>
   </div>
 </section>
+
+<section
+  class="pf-v6-c-page__main-section pf-v6-c-page__main-section--home pf-m-limit-width pf-m-align-center pf-v6-c-page__main-section--outro"
+>
+  <div class="pf-v6-c-page__main-body outro">
+    <img alt="NetteART Logo" src="/design/icon.svg" class="logo--outro" />
+
+    <h1 class="pf-v6-c-title pf-m-4xl pf-m-page-title pf-v6-u-mb-sm">
+      Ihr Projekt. Meine Gestaltung.
+    </h1>
+
+    <p class="pf-v6-c-title pf-m-md pf-v6-u-mb-md">
+      Ob Broschüre, Kampagne oder komplette Markenidentität - ich freue mich auf
+      Ihre Anfrage.
+    </p>
+
+    <a class="pf-v6-c-button pf-m-primary" href="mailto:info@netteart.com">
+      <span class="pf-v6-c-button__icon pf-m-start fas fa-envelope"></span>
+      <span class="pf-v6-c-button__text">Kontakt aufnehmen</span>
+    </a>
+  </div>
+</section>

