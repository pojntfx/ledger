From c2b5db1526e5ca3de835b257fa462a7a581751cb Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Fri, 10 Jul 2026 20:26:16 -0700
Subject: [PATCH] feat: Set min-height for the individual cards, make description text for them smaller, and fix readability for busy items

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index 6f18e34565c911de6280a76230d2d78c016d9ef4..deb09e9271595d7e3399eac40e70c11fa5d0b231 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -553,22 +553,28 @@   overflow: hidden;
   overflow-wrap: break-word; // Long German compound words also need to break
 
   .pf-v6-c-card__footer {
+    @extend .pf-v6-u-p-md;
+
     position: absolute;
     bottom: 0;
     z-index: 1;
-
-    @extend .pf-v6-u-p-md;
+    font-size: var(--pf-t--global--font--size--body--sm);
   }
 
   .pf-v6-c-card__title {
-    @extend .pf-v6-u-pb-lg;
+    @extend .pf-v6-u-pb-md;
 
     background: transparent;
+
+    > .pf-v6-c-card__title-text {
+      font-size: var(--pf-t--global--font--size--body--md);
+    }
   }
 
   .pf-v6-c-card__body {
     padding: 0;
     overflow: hidden;
+    min-height: 8rem;
   }
 
   .pf-v6-c-card__header {
@@ -581,6 +587,7 @@     align-items: end;
     background: linear-gradient(
       to top,
       var(--pf-v6-c-card--BackgroundColor),
+      color-mix(in srgb, var(--pf-v6-c-card--BackgroundColor) 75%, transparent),
       transparent
     );
 
@@ -589,7 +596,9 @@   }
 
   img {
     width: 100%;
-    height: auto;
+    height: 100%;
+    min-height: 8rem;
+    object-fit: cover;
     display: block;
   }
 
@@ -634,7 +643,7 @@   align-content: center;
   justify-content: center;
 
   > img {
-    width: 100%;
+    width: auto;
   }
 }
 

