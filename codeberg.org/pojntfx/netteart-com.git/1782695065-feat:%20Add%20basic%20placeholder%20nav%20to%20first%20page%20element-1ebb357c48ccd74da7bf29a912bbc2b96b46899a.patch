diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index fe32e730b2b9b8a255c6c2c240a1af5a699a4bcb..06e16b8755ce6f87c7691ccdb7418eae5becd7b2 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -83,6 +83,14 @@ }
 
 .pf-v6-c-page__main-section--hero {
   min-height: 75vh;
+  display: flex;
+  flex-direction: column;
+
+  & > .pf-v6-c-page__main-body {
+    display: flex;
+    flex-direction: column;
+    flex: 1;
+  }
 }
 
 .hero {
@@ -90,6 +98,7 @@   @extend .pf-v6-u-py-2xl;
 
   display: flex;
   flex-direction: column;
+  margin-block: auto;
   & > h1 {
     margin: 0 auto;
   }
@@ -164,3 +173,7 @@   background-attachment: fixed;
   background-image:
     linear-gradient(var(--bg-tint), var(--bg-tint)), url(/img/bg.webp);
 }
+
+.nav--hero {
+  justify-content: end;
+}
