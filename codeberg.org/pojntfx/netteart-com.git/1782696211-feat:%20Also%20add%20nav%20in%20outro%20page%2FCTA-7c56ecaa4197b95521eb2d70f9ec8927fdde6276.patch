   align-items: center;
   @media (min-width: $pf-v6-global--breakpoint--sm) {
     flex-direction: row;
-    align-items: start;
+    align-items: center;
     text-align: start;
   }
 
@@ -145,15 +145,23 @@   @extend .pf-v6-u-py-2xl;
 
   display: flex;
   flex-direction: column;
+  flex: 1;
 
   text-align: center;
   align-items: center;
+  justify-content: center;
 }
 
 .pf-v6-c-page__main-section--outro {
   justify-content: center;
   // Best-effort; 53px for the footer
   min-height: calc(100vh - 53px);
+
+  > .pf-v6-c-page__main-body {
+    display: flex;
+    flex-direction: column;
+    flex: 1;
+  }
 }
 
