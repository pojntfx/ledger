From f6bbade51dc765d0225b84f3a6aed644bd86ead0 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Tue, 02 Jun 2026 23:40:27 -0700
Subject: [PATCH] build: Create local dirs instead of expecting them to be there

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/.forgejo/workflows/hugo.yaml b/.forgejo/workflows/hugo.yaml
index 7233f8f681fe3b3d4ad5344ce98764eb79899b5a..5738a83d306f9c6454054961e0f92a5250f03c8f 100644
--- a/.forgejo/workflows/hugo.yaml
+++ b/.forgejo/workflows/hugo.yaml
@@ -24,17 +24,18 @@         with:
           node-version: ${{ env.NODE_VERSION }}
       - name: Install Dart Sass
         run: |
+          mkdir -p "${HOME}/.local"
           curl -sLJO "https://github.com/sass/dart-sass/releases/download/${DART_SASS_VERSION}/dart-sass-${DART_SASS_VERSION}-linux-x64.tar.gz"
           tar -C "${HOME}/.local" -xf "dart-sass-${DART_SASS_VERSION}-linux-x64.tar.gz"
           rm "dart-sass-${DART_SASS_VERSION}-linux-x64.tar.gz"
-          echo "${HOME}/.local/dart-sass" >> "${GITHUB_PATH}"
+          echo "${HOME}/.local/dart-sass" >> "${FORGEJO_PATH}"
       - name: Install Hugo
         run: |
           curl -sLJO "https://github.com/gohugoio/hugo/releases/download/v${HUGO_VERSION}/hugo_extended_${HUGO_VERSION}_linux-amd64.tar.gz"
-          mkdir "${HOME}/.local/hugo"
+          mkdir -p "${HOME}/.local/hugo"
           tar -C "${HOME}/.local/hugo" -xf "hugo_extended_${HUGO_VERSION}_linux-amd64.tar.gz"
           rm "hugo_extended_${HUGO_VERSION}_linux-amd64.tar.gz"
-          echo "${HOME}/.local/hugo" >> "${GITHUB_PATH}"
+          echo "${HOME}/.local/hugo" >> "${FORGEJO_PATH}"
       - name: Install Node.js dependencies
         run: |
           [[ -f package-lock.json || -f npm-shrinkwrap.json ]] && npm ci || true

