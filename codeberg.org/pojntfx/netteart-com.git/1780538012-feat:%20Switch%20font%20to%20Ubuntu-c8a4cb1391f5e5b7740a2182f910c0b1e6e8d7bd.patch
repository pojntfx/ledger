From c8a4cb1391f5e5b7740a2182f910c0b1e6e8d7bd Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 03 Jun 2026 18:53:32 -0700
Subject: [PATCH] feat: Switch font to Ubuntu

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index 35b5e5431c4d9d8a43a2069fd6c476c41a8dd5d9..fcb6e7f8610c99319f216b1a4860ffe07f08e164 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -19,6 +19,8 @@ @import "@fortawesome/fontawesome-free/scss/fontawesome";
 @import "@fortawesome/fontawesome-free/scss/solid";
 @import "@fortawesome/fontawesome-free/scss/brands";
 
-.ubuntu {
-  font-family: "Ubuntu";
+:root {
+  --pf-t--global--font--family--body: "Ubuntu", sans-serif;
+  --pf-t--global--font--family--heading: "Ubuntu", sans-serif;
+}
 }

