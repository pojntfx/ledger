From f0b0f29a2b2e7afb6fab868e13361acef3c9e7e0 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Sun, 28 Jun 2026 16:08:30 -0700
Subject: [PATCH] feat: Use new Hugo conventions for language codes and root objects

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/hugo.yaml b/hugo.yaml
index 9ef43675bd1f7e852516c726b505fd2435337c41..49fd4d705d731f729c9c7b8bf775fd5d5c6730e4 100644
--- a/hugo.yaml
+++ b/hugo.yaml
@@ -1,5 +1,5 @@
 baseURL: https://netteart.com/
-languageCode: en-CA
+locale: en-CA
 title: "NetteART Grafik & Design"
 relativeURLs: true
 build:
diff --git a/layouts/_partials/footer.html b/layouts/_partials/footer.html
index de9b4ab318402e6d8daeea5b48308992f88ea663..c7832656bfe6173000336683b7bbe3b6ba854b9d 100644
--- a/layouts/_partials/footer.html
+++ b/layouts/_partials/footer.html
@@ -4,15 +4,15 @@     <div
       class="pf-v6-l-grid pf-m-gutter pf-v6-u-py-xl-on-sm pf-v6-u-py-0-on-md pf-v6-u-align-items-center"
     >
       <a
-        href="{{ .Site.Data.site.source }}#license"
+        href="{{ hugo.Data.site.source }}#license"
         target="_blank"
         rel="noopener"
         class="pf-v6-l-grid__item pf-m-12-col pf-m-6-col-on-xl"
       >
-        © {{ now.Year }} {{ .Site.Data.site.author }}
+        © {{ now.Year }} {{ hugo.Data.site.author }}
       </a>
       <div class="pf-v6-l-grid__item pf-m-12-col pf-m-6-col-on-xl pf-v6-u-text-align-end-on-xl">
-        <a href="{{ .Site.Data.site.source }}" target="_blank" rel="noopener"
+        <a href="{{ hugo.Data.site.source }}" target="_blank" rel="noopener"
           >Quelltext</a
         >
         <a href="/privacy">Datenschutzerklärung</a>
diff --git a/layouts/baseof.html b/layouts/baseof.html
index e464d10f97956e3ea069535a67ecbc5f993ce052..726bbe2dfdd92df1a4a5602c1b63e61695954d6d 100644
--- a/layouts/baseof.html
+++ b/layouts/baseof.html
@@ -1,5 +1,5 @@
 <!doctype html>
-<html lang="{{ .Site.Language.LanguageCode }}">
+<html lang="{{ .Language.Locale }}">
   <head>
     <meta charset="UTF-8" />
     <meta name="viewport" content="width=device-width, initial-scale=1.0" />
@@ -35,27 +35,27 @@     <!-- Keep these in sync with the <html> element's background colour -->
     <meta name="theme-color" content="#f2f2f2" media="(prefers-color-scheme: light)" />
     <meta name="theme-color" content="#151515" media="(prefers-color-scheme: dark)" />
 
-    <meta name="author" content="{{ .Site.Data.site.author }}" />
-    <meta name="description" content="{{ .Site.Data.site.description }}" />
+    <meta name="author" content="{{ hugo.Data.site.author }}" />
+    <meta name="description" content="{{ hugo.Data.site.description }}" />
     <meta
       name="keywords"
-      content="{{ delimit .Site.Data.site.keywords `, ` }}"
+      content="{{ delimit hugo.Data.site.keywords `, ` }}"
     />
     <meta
       name="copyright"
-      content="© {{ now.Year }} {{ .Site.Data.site.author }} ({{ .Site.Data.site.license }})"
+      content="© {{ now.Year }} {{ hugo.Data.site.author }} ({{ hugo.Data.site.license }})"
     />
 
     <meta property="og:title" content="{{ .Site.Title }}" />
     <meta
       property="og:description"
-      content="{{ .Site.Data.site.description }}"
+      content="{{ hugo.Data.site.description }}"
     />
     <meta property="og:image" content="/design/header.png" />
     <meta property="og:url" content="{{ .Site.BaseURL }}" />
     <meta property="og:type" content="website" />
-    <meta property="og:site_name" content="{{ .Site.Data.site.author }}" />
-    <meta property="og:locale" content="{{ .Site.Language.LanguageCode }}" />
+    <meta property="og:site_name" content="{{ hugo.Data.site.author }}" />
+    <meta property="og:locale" content="{{ .Language.Locale }}" />
     {{ with resources.Get "js/head.js" }}
       {{ $opts := dict
         "minify" (not hugo.IsDevelopment)

