From 67f47d836d32b6492eb62beac6e2b35f17af625f Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 03 Jun 2026 18:53:10 -0700
Subject: [PATCH] refactor: Swap to `netteart.com` for base URL

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/.forgejo/workflows/hugo.yaml b/.forgejo/workflows/hugo.yaml
index adb6a6961d0595167e6deaa316ea4c71589e6522..552c33047c7a3c74b14022f0d27bbc3981c4dae3 100644
--- a/.forgejo/workflows/hugo.yaml
+++ b/.forgejo/workflows/hugo.yaml
@@ -44,10 +44,10 @@         run: |
           hugo build \
             --gc \
             --minify \
-            --baseURL "https://pojntfx.codeberg.page/netteart-com/"
+            --baseURL "https://netteart.com/"
       - name: Deploy to Forgejo Pages
         uses: actions/git-pages@v2
         with:
-          site: https://pojntfx.codeberg.page/netteart-com/
+          site: https://netteart.com/
           token: ${{ forge.token }}
           source: public/
diff --git a/hugo.yaml b/hugo.yaml
index 13a1b59a361d65eb1de9478701fe5159f5262994..9ef43675bd1f7e852516c726b505fd2435337c41 100644
--- a/hugo.yaml
+++ b/hugo.yaml
@@ -1,7 +1,7 @@
-baseURL: https://pojntfx.codeberg.page/netteart-com/
+baseURL: https://netteart.com/
 languageCode: en-CA
 title: "NetteART Grafik & Design"
-# relativeURLs: true # Disabled since we're deploying on a sub-path
+relativeURLs: true
 build:
   noJSConfigInAssets: true
 disableKinds:

