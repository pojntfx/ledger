From e1534c3350d3c1581471a1329783b8eac842ff57 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 03 Jun 2026 18:55:21 -0700
Subject: [PATCH] feat: Port home page to Patternfly styles, add proper container and start styling

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index fcb6e7f8610c99319f216b1a4860ffe07f08e164..f1b4eeef26cb539bcbd4c1c3e7366204b18fdeb7 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -23,4 +23,14 @@ :root {
   --pf-t--global--font--family--body: "Ubuntu", sans-serif;
   --pf-t--global--font--family--heading: "Ubuntu", sans-serif;
 }
+
+.pf-v6-c-page__main-container--home {
+  @extend .pf-v6-u-m-0;
+  border-radius: 0;
+  min-height: 100%;
+}
+
+.logo--home {
+  width: auto;
+  max-width: 15rem;
 }
diff --git a/layouts/_partials/section-home.html b/layouts/_partials/section-home.html
index 19da55b800fbea0361e7779bbc08a68b0c03b050..097d842f7cd85ad07a1dd1342dc7ae4c2ad1393a 100644
--- a/layouts/_partials/section-home.html
+++ b/layouts/_partials/section-home.html
@@ -1,5 +1,11 @@
-<p class="ubuntu">Coming soon</p>
+<div class="pf-v6-l-bullseye pf-v6-u-flex-1">
+  <div
+    class="pf-v6-l-bullseye__item pf-v6-l-flex pf-m-column pf-m-align-items-center pf-m-space-items-lg"
+  >
+    <h1 class="pf-v6-c-title pf-m-xl">Coming soon</h1>
 
-<img alt="NetteART Logo" src="/design/icon.svg" />
+    <img alt="NetteART Logo" src="/design/icon.svg" class="logo--home" />
 
-<a href="mailto:info@netteart.com">info@netteart.com</a>
+    <a href="mailto:info@netteart.com">info@netteart.com</a>
+  </div>
+</div>
diff --git a/layouts/baseof.html b/layouts/baseof.html
index 5c4266329b30b256188dfcd0c438c12d08f4fada..fc7c4ebb2b528cf5a489be1cc2c23b2c73b5bf37 100644
--- a/layouts/baseof.html
+++ b/layouts/baseof.html
@@ -84,9 +84,23 @@     </noscript>
   </head>
 
   <body>
-    <main>
-      {{ block "main" . }}{{ end }}
-    </main>
+    <div class="pf-v6-c-page pf-m-no-sidebar">
+      <div class="pf-v6-c-skip-to-content">
+        <a class="pf-v6-c-button pf-m-primary" href="#main-content">
+          <span class="pf-v6-c-button__text">Zum Inhalt springen</span>
+        </a>
+      </div>
+
+      <div class="pf-v6-c-page__main-container {{ if .IsHome }}pf-v6-c-page__main-container--home{{ end }}" tabindex="-1"> 
+        <div
+          class="pf-v6-c-page__main"
+          tabindex="-1"
+          id="main-content"
+        >
+          {{ block "main" . }}{{ end }}
+        </div>
+      </div>
+    </div>
 
     {{ with resources.Get "js/main.js" }}
       {{ $opts := dict
diff --git a/layouts/home.html b/layouts/home.html
index c8d7815eb17aff80d793d937ac9fd7c1492443eb..8c5fa8b38ebd65d63455effe01d6894a74879abe 100644
--- a/layouts/home.html
+++ b/layouts/home.html
@@ -1,4 +1,7 @@
 {{ define "main" }}
-  {{ partial "section-home" . }}
+  <main class="pf-v6-u-flex-1 pf-v6-u-display-flex pf-v6-u-flex-direction-column">
+    {{ partial "section-home" . }}
+  </main>
+
   {{ partial "footer" . }}
 {{ end }}

