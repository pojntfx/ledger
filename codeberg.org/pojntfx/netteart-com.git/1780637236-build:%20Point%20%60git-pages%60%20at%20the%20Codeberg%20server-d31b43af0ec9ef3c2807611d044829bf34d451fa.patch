Subject: [PATCH] build: Point `git-pages` at the Codeberg server

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/.forgejo/workflows/hugo.yaml b/.forgejo/workflows/hugo.yaml
index 552c33047c7a3c74b14022f0d27bbc3981c4dae3..db86d38c49565a099dbb7176a46e030fa0704959 100644
--- a/.forgejo/workflows/hugo.yaml
+++ b/.forgejo/workflows/hugo.yaml
@@ -49,5 +49,6 @@       - name: Deploy to Forgejo Pages
         uses: actions/git-pages@v2
         with:
           site: https://netteart.com/
+          server: codeberg.page
           token: ${{ forge.token }}
           source: public/

