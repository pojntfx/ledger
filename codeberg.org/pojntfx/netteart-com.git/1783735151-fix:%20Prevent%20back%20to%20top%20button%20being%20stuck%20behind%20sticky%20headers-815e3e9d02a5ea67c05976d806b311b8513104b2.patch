From 815e3e9d02a5ea67c05976d806b311b8513104b2 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Fri, 10 Jul 2026 18:59:11 -0700
Subject: [PATCH] fix: Prevent back to top button being stuck behind sticky headers

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index 4721670fef990d17a40c55d8d0625441b496a588..1c64e1f0efe04dde07227f2f9ff0a59835c267b8 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -613,6 +613,10 @@     --pf-t--global--background--color--secondary--default
   ) !important;
 }
 
+.pf-v6-c-back-to-top {
+  z-index: var(--pf-t--global--z-index--lg);
+}
+
 .pf-v6-c-back-to-top--home {
   // We made the whole home page scroll, so we can't use the regular back to top button positioning anymore
   position: fixed;

