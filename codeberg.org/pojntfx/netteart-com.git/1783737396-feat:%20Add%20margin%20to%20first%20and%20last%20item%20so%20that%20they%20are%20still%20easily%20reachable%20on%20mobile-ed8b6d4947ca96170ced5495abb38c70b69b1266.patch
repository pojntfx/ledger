From ed8b6d4947ca96170ced5495abb38c70b69b1266 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Fri, 10 Jul 2026 19:36:36 -0700
Subject: [PATCH] feat: Add margin to first and last item so that they are still easily reachable on mobile

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index dc43688b8836d4ec9f070c8ac8efaf89b90c8aff..8d5d436cb2e98ce4d8a3941ca8be29642806263a 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -703,3 +703,13 @@ .pf-v6-c-tabs__list {
   min-width: 0;
   overflow-x: auto;
 }
+
+.pf-v6-c-tabs__item {
+  &:first-child {
+    @extend .pf-v6-u-ml-lg;
+  }
+
+  &:last-child {
+    @extend .pf-v6-u-mr-lg;
+  }
+}

