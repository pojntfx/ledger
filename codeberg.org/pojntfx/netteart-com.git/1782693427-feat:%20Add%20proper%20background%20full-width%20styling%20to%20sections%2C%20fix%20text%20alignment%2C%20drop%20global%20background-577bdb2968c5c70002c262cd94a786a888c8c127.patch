From 577bdb2968c5c70002c262cd94a786a888c8c127 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Sun, 28 Jun 2026 17:37:07 -0700
Subject: [PATCH] feat: Add proper background full-width styling to sections, fix text alignment, drop global background

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/assets/scss/main.scss b/assets/scss/main.scss
index 86b54d3ce88286440dbf4d5e8b8a5cf3a744a217..fe32e730b2b9b8a255c6c2c240a1af5a699a4bcb 100644
--- a/assets/scss/main.scss
+++ b/assets/scss/main.scss
@@ -35,19 +35,6 @@   @extend .pf-v6-u-m-0;
   border-radius: 0;
   min-height: 100%;
   border: 0;
-
-  // Keep this in sync with the <html> background-color
-  --bg-tint: color-mix(
-    in srgb,
-    var(--pf-t--global--background--color--secondary--default) 90%,
-    transparent
-  );
-
-  background-image:
-    linear-gradient(var(--bg-tint), var(--bg-tint)), url(/img/bg.webp);
-  background-position: center;
-  background-repeat: no-repeat;
-  background-size: cover;
 }
 
 .pf-v6-c-masthead {
@@ -90,6 +77,7 @@   }
 }
 
 .pf-v6-c-page__main-section--home {
+  justify-content: center;
   background: transparent;
 }
 
@@ -106,8 +94,12 @@   & > h1 {
     margin: 0 auto;
   }
 
+  text-align: center;
+  align-items: center;
   @media (min-width: $pf-v6-global--breakpoint--sm) {
     flex-direction: row;
+    align-items: start;
+    text-align: start;
   }
 
   &__details {
@@ -119,7 +111,11 @@
     display: flex;
     flex-direction: column;
     justify-content: center;
-    align-items: flex-start;
+
+    align-items: center;
+    @media (min-width: $pf-v6-global--breakpoint--sm) {
+      align-items: start;
+    }
   }
 }
 
@@ -131,6 +127,8 @@ .logo--outro {
   width: auto;
   max-width: 10rem;
   padding-left: 8px; // Visual centering
+
+  @extend .pf-v6-u-mb-md;
 }
 
 .outro {
@@ -138,6 +136,8 @@   @extend .pf-v6-u-py-2xl;
 
   display: flex;
   flex-direction: column;
+
+  text-align: center;
   align-items: center;
 }
 
@@ -146,3 +146,21 @@   justify-content: center;
   // Best-effort; 53px for the footer
   min-height: calc(100vh - 53px);
 }
+
+.section--full-width {
+  width: 100%;
+
+  // Keep this in sync with the <html> background-color
+  --bg-tint: color-mix(
+    in srgb,
+    var(--pf-t--global--background--color--secondary--default) 90%,
+    transparent
+  );
+
+  background-position: center;
+  background-repeat: no-repeat;
+  background-size: cover;
+  background-attachment: fixed;
+  background-image:
+    linear-gradient(var(--bg-tint), var(--bg-tint)), url(/img/bg.webp);
+}
