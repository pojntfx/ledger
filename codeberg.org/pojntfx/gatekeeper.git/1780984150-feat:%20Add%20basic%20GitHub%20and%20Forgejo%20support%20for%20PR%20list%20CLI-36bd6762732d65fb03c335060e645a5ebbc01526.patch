From 36bd6762732d65fb03c335060e645a5ebbc01526 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Mon, 08 Jun 2026 22:49:10 -0700
Subject: [PATCH] feat: Add basic GitHub and Forgejo support for PR list CLI

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/cmd/gatekeeper-list-prs/main.go b/cmd/gatekeeper-list-prs/main.go
new file mode 100644
index 0000000000000000000000000000000000000000..302c9c172fd087ab8e261d15ad8a450f8ce694fd
--- /dev/null
+++ b/cmd/gatekeeper-list-prs/main.go
@@ -0,0 +1,174 @@
+package main
+
+import (
+	"context"
+	"encoding/json"
+	"errors"
+	"flag"
+	"os"
+
+	"codeberg.org/mvdkleijn/forgejo-sdk/forgejo"
+	"github.com/google/go-github/v88/github"
+	"gopkg.in/yaml.v3"
+)
+
+type ForgeType string
+
+const (
+	ForgeTypeGitHub  ForgeType = "github"
+	ForgeTypeForgejo ForgeType = "forgejo"
+)
+
+type ForgeConfig struct {
+	Type ForgeType `yaml:"type"`
+	API  string    `yaml:"api"`
+}
+
+type RepoRepoConfig struct {
+	Owner string `yaml:"owner"`
+	Repo  string `yaml:"repo"`
+}
+
+type RepoConfig struct {
+	Name  string         `yaml:"name"`
+	Forge ForgeConfig    `yaml:"forge"`
+	Repo  RepoRepoConfig `yaml:"repo"`
+}
+
+type PullRequest struct {
+	Title  string   `yaml:"title"`
+	Labels []string `yaml:"labels"` // TODO: Use a well-known list of labels (e.g. "blocked")
+}
+
+func fetchGitHubPullRequests(ctx context.Context, repo RepoConfig, token string) ([]PullRequest, error) {
+	options := []github.ClientOptionsFunc{}
+	if token != "" {
+		options = append(options, github.WithAuthToken(token))
+	}
+
+	client, err := github.NewClient()
+	if err != nil {
+		return []PullRequest{}, err
+	}
+
+	var pullRequests []PullRequest
+	for pr, err := range client.PullRequests.ListIter(
+		ctx,
+		repo.Repo.Owner,
+		repo.Repo.Repo,
+		&github.PullRequestListOptions{
+			State: "open",
+		},
+	) {
+		if err != nil {
+			return pullRequests, err
+		}
+
+		labels := []string{}
+		for _, label := range pr.Labels {
+			labels = append(labels, label.GetName())
+		}
+
+		pullRequests = append(pullRequests, PullRequest{
+			Title:  pr.GetTitle(),
+			Labels: labels,
+		})
+	}
+
+	return pullRequests, nil
+}
+
+func fetchForgejoPullRequests(ctx context.Context, repo RepoConfig, token string) ([]PullRequest, error) {
+	options := []forgejo.ClientOption{
+		forgejo.SetContext(ctx),
+	}
+	if token != "" {
+		options = append(options, forgejo.SetToken(token))
+	}
+
+	client, err := forgejo.NewClient(repo.Forge.API, options...)
+	if err != nil {
+		return []PullRequest{}, err
+	}
+
+	rawPullRequests, _, err := client.ListRepoPullRequests(
+		repo.Repo.Owner,
+		repo.Repo.Repo,
+		forgejo.ListPullRequestsOptions{
+			State: "open",
+		},
+	)
+	if err != nil {
+		panic(err)
+	}
+
+	var pullRequests []PullRequest
+	for _, pr := range rawPullRequests {
+		labels := []string{}
+		for _, label := range pr.Labels {
+			labels = append(labels, label.Name)
+		}
+
+		pullRequests = append(pullRequests, PullRequest{
+			Title:  pr.Title,
+			Labels: labels,
+		})
+	}
+
+	return pullRequests, nil
+}
+
+func main() {
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+
+	rawRepos := flag.String("repos", "repos.yaml", "Repos configuration file")
+	rawTokens := flag.String("tokens", "", "Forge tokens as JSON object, e.g. {\"github.com\": \"token\"}")
+
+	flag.Parse()
+
+	reposFile, err := os.Open(*rawRepos)
+	if err != nil {
+		panic(err)
+	}
+
+	var repos []RepoConfig
+	if err := yaml.NewDecoder(reposFile).Decode(&repos); err != nil {
+		panic(err)
+	}
+
+	tokens := map[string]string{}
+	if *rawTokens != "" {
+		if err := json.Unmarshal([]byte(*rawTokens), &tokens); err != nil {
+			panic(errors.Join(errors.New("could not parse forge tokens"), err))
+		}
+	}
+
+	var allPullRequests []PullRequest
+	for _, repo := range repos {
+		token := tokens[repo.Forge.API]
+
+		var (
+			pullRequests []PullRequest
+			err          error
+		)
+
+		switch repo.Forge.Type {
+		case ForgeTypeGitHub:
+			pullRequests, err = fetchGitHubPullRequests(ctx, repo, token)
+
+		case ForgeTypeForgejo:
+			pullRequests, err = fetchForgejoPullRequests(ctx, repo, token)
+		}
+
+		if err != nil {
+			panic(err)
+		}
+
+		allPullRequests = append(allPullRequests, pullRequests...)
+	}
+
+	if err := yaml.NewEncoder(os.Stdout).Encode(allPullRequests); err != nil {
+		panic(err)
+	}
+}
