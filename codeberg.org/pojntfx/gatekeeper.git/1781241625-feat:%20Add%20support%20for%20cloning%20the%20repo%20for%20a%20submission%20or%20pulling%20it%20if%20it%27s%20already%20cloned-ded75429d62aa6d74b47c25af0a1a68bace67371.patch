From ded75429d62aa6d74b47c25af0a1a68bace67371 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Thu, 11 Jun 2026 22:20:25 -0700
Subject: [PATCH] feat: Add support for cloning the repo for a submission or pulling it if it's already cloned

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/cmd/gatekeeper-try-submission/main.go b/cmd/gatekeeper-try-submission/main.go
index 44c05518693e81c61a348df392ab95abde5bd90d..3865eb328a468ed41809826ad209359d79b51bad 100644
--- a/cmd/gatekeeper-try-submission/main.go
+++ b/cmd/gatekeeper-try-submission/main.go
@@ -4,11 +4,17 @@ import (
 	"context"
 	"errors"
 	"flag"
+	"fmt"
 	"os"
+	"path/filepath"
 
 	"codeberg.org/pojntfx/gatekeeper/internal/config"
 	"codeberg.org/pojntfx/gatekeeper/internal/forges"
+	"github.com/adrg/xdg"
 	"gopkg.in/yaml.v3"
+
+	"github.com/go-git/go-git/v6"
+	"github.com/go-git/go-git/v6/plumbing"
 )
 
 func main() {
@@ -21,6 +27,8 @@
 	repoID := flag.String("repo-id", "", "ID of the repo in the repos configuration file that the PR is hosted on")
 	prID := flag.Int64("pr-id", 0, "ID of the PR for the submission to try out")
 
+	workDir := flag.String("work-dir", filepath.Join(xdg.StateHome, "gatekeeper"), "Work directory for cloning and building submissios etc. in")
+
 	flag.Parse()
 
 	repos, tokens, err := config.ParseReposFileAndTokens(*rawRepos, *rawTokens)
@@ -43,6 +51,10 @@ 	}
 
 	token := tokens[repo.Forge.API]
 
+	var (
+		cloneURL,
+		cloneBranch string
+	)
 	switch repo.Forge.Type {
 	case config.ForgeTypeGitHub:
 		client, err := forges.NewGitHubClient(token, repo.Forge.API)
@@ -56,9 +68,8 @@ 		if err != nil {
 			panic(err)
 		}
 
-		if err := yaml.NewEncoder(os.Stdout).Encode(pr); err != nil {
-			panic(err)
-		}
+		head := pr.GetHead()
+		cloneURL, cloneBranch = head.GetRepo().GetCloneURL(), head.GetRef()
 
 	case config.ForgeTypeForgejo:
 		client, err := forges.NewForgejoClient(ctx, token, repo.Forge.API)
@@ -71,10 +82,44 @@ 		if err != nil {
 			panic(err)
 		}
 
-		if err := yaml.NewEncoder(os.Stdout).Encode(pr); err != nil {
+		head := pr.Head
+		cloneURL, cloneBranch = head.Repository.CloneURL, head.Ref
+	}
+
+	repoPath := filepath.Join(*workDir, "clones", *repoID, fmt.Sprintf("%v", *prID))
+	if err := os.MkdirAll(repoPath, os.ModePerm); err != nil {
+		panic(err)
+	}
+
+	openRepo, err := git.PlainOpen(repoPath)
+	if err == nil {
+		// We've cloned this before; pull
+		worktree, err := openRepo.Worktree()
+		if err != nil {
+			panic(err)
+		}
+
+		// TODO: Support hard-resetting to origin HEAD if we can't pull (e.g. if remote was force-pushed to)
+		if err := worktree.PullContext(ctx, &git.PullOptions{}); err != nil && !errors.Is(err, git.NoErrAlreadyUpToDate) {
+			panic(err)
+		}
+	} else {
+		if !errors.Is(err, git.ErrRepositoryNotExists) {
+			panic(err)
+		}
+
+		openRepo, err = git.PlainCloneContext(ctx, repoPath, &git.CloneOptions{
+			URL:           cloneURL,
+			ReferenceName: plumbing.ReferenceName(cloneBranch),
+		})
+		if err != nil {
 			panic(err)
 		}
 	}
 
-	// TODO: Using go-git, clone submission from PR (via HTTPS), run `flatpak build` via the Flathub-vendored flatpak-builder (including all deps), install as user, then run `flatpak run`
+	if err := yaml.NewEncoder(os.Stdout).Encode(openRepo); err != nil {
+		panic(err)
+	}
+
+	// TODO: Using go-git, clone submission from PR (via HTTPS), run `flatpak build` via the Flathub-vendored flatpak-builder (including all deps), install as user, then run `flatpak run` (allow forwarding all flags to `flatpak run` past `--`)
 }
