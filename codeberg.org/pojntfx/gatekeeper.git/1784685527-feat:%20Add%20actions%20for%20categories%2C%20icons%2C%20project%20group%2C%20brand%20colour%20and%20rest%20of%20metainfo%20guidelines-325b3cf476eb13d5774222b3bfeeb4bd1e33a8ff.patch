From 325b3cf476eb13d5774222b3bfeeb4bd1e33a8ff Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Tue, 21 Jul 2026 18:58:47 -0700
Subject: [PATCH] feat: Add actions for categories, icons, project group, brand colour and rest of metainfo guidelines

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/guidelines.yaml b/guidelines.yaml
index 5f1a129c2fc37f530b568e502df0af69f677730f..9a2f629bcd2a645ad758eaf156150f360b5daca4 100644
--- a/guidelines.yaml
+++ b/guidelines.yaml
@@ -1290,17 +1290,34 @@             For graphical apps with a launchable, categories and keywords are defined in the desktop file (not duplicated/overridden
             in the MetaInfo).
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_DESKTOP_FILE # To see if we have a desktop file
+            - SHOW_METAINFO_LAUNCHABLE # To see the the launchable tag in metainfo
+            - SHOW_METAINFO_CATEGORIES # To see the categories tag in metainfo
+            - SHOW_METAINFO_KEYWORDS # To see the keywords tag in metainfo
         - name:
             Generic categories (GTK, Qt, KDE, GNOME, Motif, Java, GUI, Application, XFCE, DDE) are not used as <category>;
             if needed they appear under <keywords> instead.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_CATEGORIES # To see the categories tag in metainfo
+            - SHOW_METAINFO_KEYWORDS # To see the keywords tag in metainfo
         - name: Console applications with no desktop file define <categories> and <keywords> in the MetaInfo file.
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_DESKTOP_FILE # To see if we have a desktop file
+            - SHOW_METAINFO_CATEGORIES # To see the categories tag in metainfo
+            - SHOW_METAINFO_KEYWORDS # To see the keywords tag in metainfo
         - name: All category values are valid per the Menu specification.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_CATEGORIES # To see the categories tag in metainfo
+            - SHOW_MENU_SPEC # See https://specifications.freedesktop.org/menu/latest/category-registry.html
     - name: Icons
       description: |
         The icon should not violate any trademarks.
@@ -1316,22 +1333,50 @@       items:
         - name: Icon does not violate any trademarks.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_ICON # To resolve icon to actual asset
+            - SHOW_EUIPO_MATCHES # Get EUIPO trademark search results for icon (see https://euipo.europa.eu/eSearch/)
+            - SHOW_USPTO_MATCHES # Get USPTO trademark search results for icon (see https://www.uspto.gov/subscription-center/2026/trademarks-introduces-ai-features-make-your-experience-easier)
+            - SHOW_REVERSE_IMAGE_SEARCH_MATCHES # Check, via reverse-image search, whether any media is in use by somebody else
         - name:
             All desktop applications install icons of the required size to the proper location and have a <launchable> entry
             so appstreamcli compose can fetch the icon.
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_DESKTOP_FILE # To see if we have a desktop file
+            - SHOW_METAINFO_LAUNCHABLE # To see the the launchable tag in metainfo
+            - SHOW_METAINFO_ICON # To resolve icon to actual asset and see whether it matches the advertisement
+            - SHOW_METAINFO_ICON_METADATA # To resolve icon to actual asset and see what it's metadata (permission etc.) is
+            - SHOW_METAINFO_ICON_PATH # To resolve icon path and see what the icon is named
+            - SHOW_APP_ID # To see what the icon path should be
         - name: Console applications that want to appear in Flathub search results provide icons.
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_DESKTOP_FILE # To see if we have a desktop file
+            - SHOW_METAINFO_LAUNCHABLE # To see the the launchable tag in metainfo
+            - SHOW_METAINFO_ICON # To resolve icon to actual asset and see whether it matches the advertisement
+            - SHOW_METAINFO_ICON_METADATA # To resolve icon to actual asset and see what it's metadata (permission etc.) is
+            - SHOW_METAINFO_ICON_PATH # To resolve icon path and see what the icon is named
+            - SHOW_APP_ID # To see what the icon path should be
         - name:
             Console applications use <icon type="stock"> with the filename of the installed icon (no extension), or <icon
             type="remote"> with a direct HTTP(S) link if no icon is installed.
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_METAINFO_ICON # To resolve icon to actual asset to see whether it exists
+            - SHOW_METAINFO_ICON_TAG # To check if we have the stock type or remote type in case the icon is not resolveable
         - name: Icon also follows the quality guidelines.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_ICON # To resolve icon to actual asset
+            - SHOW_QUALITY_GUIDELINES_LINK # We'll check for this further down
     - name: Project Group
       description: |
         The <project_group/> tag can be used if the application is affiliated with a known software project like for example GNOME, KDE or Mozilla.
@@ -1343,11 +1388,21 @@       items:
         - name: <project_group> tag is used only if the application is affiliated with a known software project.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_PROJECT_GROUP # To check whether tag is set
+            - SHOW_APP_ID # To check if the ID is the specificed allow list-specific reserved prefix
+            - SHOW_MODULES # To check where the sources are hosted
+            - SHOW_IS_SUBMITTER_CONTRIBUTOR # To see if the submitter is an upstream contributor, but we need to be careful to validate if the project is an official project too here
         - name:
             Protected <project_group> values (Freedesktop/FreeDesktop, GNOME, KDE) are only used by application IDs starting
             with org.freedesktop, org.gnome, or org.kde respectively, and only for official applications.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_PROJECT_GROUP # To check whether tag is set
+            - SHOW_APP_ID # To check if the ID is the specificed allow list-specific reserved prefix
+            - SHOW_MODULES # To check where the sources are hosted
+            - SHOW_IS_SUBMITTER_CONTRIBUTOR # To see if the submitter is an upstream contributor, but we need to be careful to validate if the project is an official project too here
     - name: Brand color
       description: |
         Applications should set a brand color in both light and dark variants. This is used by Flathub and native app store clients on banners, app pages, etc.
@@ -1357,9 +1412,13 @@       items:
         - name: <branding> includes a primary <color> with scheme_preference="light".
           description: null
           items: null
+          actions:
+            - SHOW_BRANDING_PRIMARY_COLOR_LIGHT # To check if we have a light primary colour
         - name: <branding> includes a primary <color> with scheme_preference="dark".
           description: null
           items: null
+          actions:
+            - SHOW_BRANDING_PRIMARY_COLOR_DARK # To check if we have a dark primary colour
     - name: Open Age Ratings Service (OARS)
       description: |
         Use the OARS website to generate age rating information for your application. Make sure to use type="oars-1.1".
@@ -1369,9 +1428,16 @@       items:
         - name: MetaInfo file contains a <content_rating> tag with type="oars-1.1".
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_CONTENT_RATING # To check what the content rating is
         - name: Application is properly tagged by OARS data based on its content.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_CONTENT_RATING # To check what the content rating is
+            - SHOW_METAINFO_DESCRIPTION # To see what the app advertises itself as
+            - SHOW_FINISH_ARGS # To check what we have permission to do (e.g. internet access)
+            - RUN_SUBMISSION # To check what kind of features that are relevant to safety (e.g. chat) the app offers
     - name: URL
       description: |
         At minimum url type="homepage" tag must be present to pass validation but it is best to include other links too.
@@ -1381,14 +1447,22 @@       items:
         - name: <url type="homepage"> tag is present (mandatory).
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_URL_HOMEPAGE # To see the value of the home page URL tag
         - name:
             Where applicable, additional <url> tags (bugtracker, donation, contact, faq, translate, contribute, vcs-browser)
             are present.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_URL_TAGS # To see all URL tags
         - name: For open-source projects, <url type="vcs-browser"> is included.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_PROJECT_LICENSE # To see project license as declared in metainfo
+            - SHOW_SUBMISSION_REPO_LICENSE_CANDIDATES # To see tree and contents of license file candidates in the submission's repo, plus SPDX headers
+            - SHOW_METAINFO_URL_VCS_BROWSER # To see the value of the VCS browser URL tag
     - name: Screenshots
       description: |
         All graphical applications must have one or more screenshots in the MetaInfo. Please make sure to follow the quality guidelines for screenshots.
@@ -1400,21 +1474,41 @@       items:
         - name: All graphical applications have one or more screenshots in the MetaInfo.
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo
         - name: Console applications appearing in Flathub search results provide screenshots.
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo
         - name: Each <image> link is a direct link to an image resource on the web.
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo
+            - FETCH_METAINFO_SCREENSHOTS # To check if we can fetch the screenshots via a direct request
         - name: If images are hosted in a git repository, the link is from a tag or a commit, not a branch.
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo
+            - SHOW_METAINFO_SCREENSHOT_URLS # To check if the link points to a git repo, and whether they have a tag/commit instead of a branch
         - name: One <screenshot> is marked type="default".
           description: null
           items: null
+          actions:
+            - SHOW_FINISH_ARGS # To check if we have permissions for this to be a graphical app
+            - SHOW_METAINFO_SCREENSHOT_DEFAULT # To check if we have a default metainfo screenshot
         - name: Screenshots follow the quality guidelines.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo
+            - SHOW_QUALITY_GUIDELINES_LINK # We'll check for this further down
     - name: Release
       description: |
         Applications must supply a releases tag in their MetaInfo to pass validation. Please make sure to also follow the quality guidelines while writing release notes.
@@ -1426,24 +1520,39 @@       items:
         - name: <releases> tag is present in the MetaInfo.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_RELEASES_TAG # To check whether we have a releases tag
         - name: Each <release> has a version attribute and a date attribute.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_RELEASES # To check whether each release has a version and date attribute
         - name: Release dates are not in the future.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_RELEASES # To check whether each release date is in the past
         - name: Versions are properly ordered (verified e.g. with appstreamcli vercmp).
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_RELEASES # The linter should already have caught this, but double-check
         - name: Release description follows the same formatting rules as the top-level <description> tag.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_RELEASES_CHILD_TYPES # Also see SHOW_METAINFO_DESCRIPTION_CHILD_TYPES
         - name: Where detailed release notes exist, a <url type="details"> tag is included inside the release.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_RELEASES # To check whether we have the URL tags inside
         - name: Release notes follow the quality guidelines.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_RELEASES # To check the releases
+            - SHOW_QUALITY_GUIDELINES_LINK # We'll check for this further down
     - name: Translations
       description: |
         Appstream provides translation information, so that software centers can inform users if the app is translated into their language. If the app uses Mozilla .xpi or Google .pak files for translation, the translation info is populated automatically. If the app uses gettext .mo or Qt .qm files, you'll need to provide the prefix of these files with a <translation/> tag.
@@ -1453,15 +1562,24 @@             If the app uses gettext or Qt translation files, a <translation> tag with the correct type and prefix is provided
             (multiple tags allowed where needed).
           description: null
           items: null
+          actions:
+            - SHOW_APPLICATION_REPO_I18N # To manually sweep the _application_ repo for i18n-related files (`.po` extensions etc.) of any kind and show their contents to check if the English translation is complete
+            - SHOW_METAINFO_TRANSLATION_TAGS # To check if we have the (right) translation tags and whether they match the sweep for i18n-related files
         - name: For gettext, translation files are located at ${FLATPAK_DEST}/share/locale/<lang>/LC_MESSAGES/<id>.mo.
           description: null
           items: null
+          actions:
+            - SHOW_INSTALLED_I18N # To check the installed i18n files (gettext & qt) and whether they are at the right location
         - name: For Qt, translation files are located per the documented path conventions based on whether the id contains slashes.
           description: null
           items: null
+          actions:
+            - SHOW_INSTALLED_I18N # To check the installed i18n files (gettext & qt) and whether they are at the right location
         - name: The translation info detection has been verified in the generated output.
           description: null
           items: null
+          actions:
+            - RENDER_METAINFO_TRANSLATION_DETECTED # To check whether the translation info is picked up correctly (same as manually installing the Flatpak and checking whether e.g. GNOME software shows it as translated or "available in English only")
     - name: MetaInfo translations
       description: |
         English tag values must not use the xml:lang property. A tag value without xml:lang must be present.
@@ -1477,20 +1595,30 @@       items:
         - name: English tag values do not use the xml:lang property.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO # To check if there are any translatable tags w/o xml:lang set
         - name: For every translatable tag, an untranslated tag value (without xml:lang) is present.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_TRANSLATABLE_TAGS # To resolve each translatable tag and check whether there is an untranslatable tag for each
         - name:
             Translations are provided only on tags that support translation (name, developer/name, summary, keywords, image,
             caption, description).
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_XML_LANG_TAGS # To check if everything that has a xml:lang tag is in the allowlist
         - name: Inside <description>, each <p> and <li> is translated individually rather than translating the whole block.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_DESCRIPTION_CHILDREN # To check whether each element in the description is translated individually
         - name: Where translation is not desired for a tag, translate="no" is used.
           description: null
           items: null
+          actions:
+            - SHOW_METAINFO_TRANSLATABLE_BUT_NOT_TRANSLATED_TAGS # To show all tags that could be translated, but aren't translated; these should have translate="no"
     - name: Device support
       description: |
         appstreamcli check-syscompat --details $FLATPAK_ID.metainfo.xml can be used to get an overview of the compatibility.
@@ -1504,9 +1632,16 @@       items:
         - name: <requires>, <recommends>, and <supports> tags each appear at most once in the MetaInfo.
           description: null
           items: null
-        - Device support is correctly expressed: <requires> for absolute requirements, <recommends>/<supports> for recommendations.
+          actions:
+            - SHOW_METAINFO_REQUIRES_COUNT # To show count of all requires tags
+            - SHOW_METAINFO_RECOMMENDS_COUNT # To show count of all recommends tags
+            - SHOW_METAINFO_SUPPORTS_COUNT # To show count of all supports tags
+        - name: "Device support is correctly expressed: <requires> for absolute requirements, <recommends>/<supports> for recommendations."
           items: null
           description: null
+          actions:
+            - SHOW_METAINFO_REQUIRES # To show requires tags (absolute)
+            - SHOW_METAINFO_RECOMMENDS # To show recommends tags (recommendations)
         - name: Control
           description: |
             The <control> children of <requires>, <recommends>, or <supports> indicate what input methods the app uses (keyboard, pointing, touch, tablet, gamepad, etc.).
@@ -1514,11 +1649,30 @@           items:
             - name:
                 Input controls are placed under <requires> for mandatory inputs and under <supports> for inputs that are supported
                 but not required.
+              actions:
+                - SHOW_METAINFO_REQUIRES_CONTROLS # To show mandatory inputs
+                - SHOW_METAINFO_SUPPORTS_CONTROLS # To show supported but not required inputs
             - name: Desktop-only apps require keyboard and pointing.
+              actions:
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as a desktop-only app
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether this is a desktop-only app
+                - SHOW_METAINFO_REQUIRES_CONTROLS # To show mandatory inputs
+                - RUN_SUBMISSION # To manually check
             - name: Touch-only apps require touch.
+              actions:
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as a touch-only app
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether this is a touch-only app
+                - SHOW_METAINFO_REQUIRES_CONTROLS # To show mandatory inputs
+                - RUN_SUBMISSION # To manually check
             - name:
                 Apps that support gamepad only mandatorily declare it under <requires>; otherwise gamepad sits under <supports>
                 alongside other inputs.
+              actions:
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as supporting gamepads
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether this is a gamepad-supporting or required app
+                - SHOW_METAINFO_REQUIRES_CONTROLS # To show mandatory inputs
+                - SHOW_METAINFO_SUPPORTS_CONTROLS # To show supported but not required inputs
+                - RUN_SUBMISSION # To manually check
         - name: Display size
           description: |
             This can be used to indicate support for a specific display size(s). The tag value must be a positive integer, measured in logical pixels.
@@ -1528,10 +1682,36 @@
             The specific value used in the tag should be a realistic measurement of the minimum size that the app can scale to without harming functionality. Software stores may use specific values or ranges to classify an app into mobile, tablet or desktop compatible app.
           items:
             - name: <display_length> values are positive integers in logical pixels.
+              actions:
+                - SHOW_METAINFO_DISPLAY_LENGTH # To see what's set for display length
             - name: The specific value used is a realistic measurement of the minimum size at which the app remains functional.
+              actions:
+                - SHOW_METAINFO_DISPLAY_LENGTH # To see what's set for display length
+                - RUN_SUBMISSION # To manually check
             - name: Mobile/tablet AND desktop apps use <display_length compare="ge">360</display_length> (baseline 360).
+              actions:
+                - SHOW_METAINFO_DISPLAY_LENGTH # To see what's set for display length
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as a mobile/tablet AND desktop app
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether something advertises itself as a mobile/tablet AND desktop app
+                - SHOW_METAINFO_REQUIRES_CONTROLS # To show mandatory inputs
+                - SHOW_METAINFO_SUPPORTS_CONTROLS # To show supported but not required inputs
+                - RUN_SUBMISSION # To manually check
             - name: Desktop-only apps use <display_length compare="ge">768</display_length> (baseline 768).
+              actions:
+                - SHOW_METAINFO_DISPLAY_LENGTH # To see what's set for display length
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as a desktop-only app
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether something advertises itself as a desktop-only app
+                - SHOW_METAINFO_REQUIRES_CONTROLS # To show mandatory inputs
+                - SHOW_METAINFO_SUPPORTS_CONTROLS # To show supported but not required inputs
+                - RUN_SUBMISSION # To manually check
             - name: Mobile/tablet-only apps use <display_length compare="le">1279</display_length> (baseline 1279).
+              actions:
+                - SHOW_METAINFO_DISPLAY_LENGTH # To see what's set for display length
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as a mobile-only app
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether something advertises itself as a mobile-only app
+                - SHOW_METAINFO_REQUIRES_CONTROLS # To show mandatory inputs
+                - SHOW_METAINFO_SUPPORTS_CONTROLS # To show supported but not required inputs
+                - RUN_SUBMISSION # To manually check
         - name: Desktop only apps
           description: |
             Desktop only apps typically should have keyboard and pointing controls plus a display_length of at least 768.
@@ -1539,11 +1719,23 @@           items:
             - name:
                 Desktop-only apps declare <requires> with <control>keyboard</control>, <control>pointing</control>, and <display_length
                 compare="ge">768</display_length>.
+              actions:
+                - SHOW_METAINFO_DISPLAY_LENGTH # To see what's set for display length
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as a desktop-only app
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether something advertises itself as a desktop-only app
+                - SHOW_METAINFO_REQUIRES_CONTROLS # To show mandatory inputs
+                - RUN_SUBMISSION # To manually check
         - name: Mobile only apps
           description: |
             Mobile and tablet only apps typically should have touch control plus a display_length of at most 1279.
           items:
             - name: Mobile/tablet-only apps declare <requires> with <control>touch</control> and <display_length compare="le">1279</display_length>.
+              actions:
+                - SHOW_METAINFO_DISPLAY_LENGTH # To see what's set for display length
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as a mobile-only app
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether something advertises itself as a mobile-only app
+                - SHOW_METAINFO_REQUIRES_CONTROLS # To show mandatory inputs
+                - RUN_SUBMISSION # To manually check
         - name: Desktop and mobile apps
           description: |
             Apps that support and work on mobile, tablet and desktop typically should declare keyboard, pointing, and touch support, plus a display_length of at least 360.
@@ -1551,6 +1743,12 @@           items:
             - name:
                 Cross-device apps declare <supports> with keyboard, pointing, and touch controls and <requires> with <display_length
                 compare="ge">360</display_length>.
+              actions:
+                - SHOW_METAINFO_DISPLAY_LENGTH # To see what's set for display length
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as a mobile AND desktop app
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether something advertises itself as a mobile AND desktop app
+                - SHOW_METAINFO_SUPPORTS_CONTROLS # To show supported but not required inputs
+                - RUN_SUBMISSION # To manually check
         - name: Mobile collection
           description: |
             An app is eligible to appear in the Flathub store mobile collection if it has the above tags with values that support mobile and tablets. It must also have an icon. The collection is sorted in descending order based on trending.
@@ -1558,6 +1756,13 @@           items:
             - name:
                 For mobile collection eligibility, the app declares touch support and a display_length compatible with mobile/tablet
                 sizes, and has an icon.
+              actions:
+                - SHOW_METAINFO_DISPLAY_LENGTH # To see what's set for display length
+                - SHOW_METAINFO_DESCRIPTION # To see the description tag for whether something advertises itself as a mobile AND desktop app
+                - SHOW_METAINFO_SCREENSHOTS # To check which screenshots we have set in metainfo as these might help show whether something advertises itself as a mobile AND desktop app
+                - SHOW_METAINFO_SUPPORTS_CONTROLS # To show supported but not required inputs
+                - RUN_SUBMISSION # To manually check
+                - SHOW_METAINFO_ICON # To resolve icon to actual asset
