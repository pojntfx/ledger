"string","minLength":6,"maxLength":255,"pattern":"^[A-Za-z_][\\w\\-\\.]+$","examples":["org.gnome.Glade"],"title":"App Id"}},{"name":"locale","in":"query","required":false,"schema":{"type":"string","default":"en","title":"Locale"}}],"responses":{"200":{"description":"AppStream metadata for the app","content":{"application/json":{"schema":{"oneOf":[{"$ref":"#/components/schemas/DesktopAppstream"},{"$ref":"#/components/schemas/AddonAppstream"},{"$ref":"#/components/schemas/LocalizationAppstream"},{"$ref":"#/components/schemas/GenericAppstream"},{"$ref":"#/components/schemas/RuntimeAppstream"}],"discriminator":{"propertyName":"type","mapping":{"desktop-application":"#/components/schemas/DesktopAppstream","console-application":"#/components/schemas/DesktopAppstream","desktop":"#/components/schemas/DesktopAppstream","addon":"#/components/schemas/AddonAppstream","localization":"#/components/schemas/LocalizationAppstream","generic":"#/components/schemas/GenericAppstream","runtime":"#/components/schemas/RuntimeAppstream"}},"title":"Response Get Appstream Appstream  App Id  Get"}}}},"404":{"description":"App not found"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/is-fullscreen-app/{app_id}":{"get":{"tags":["app"],"summary":"Get Isfullscreenapp","description":"Check if an application is configured to run in fullscreen mode.","operationId":"get_isFullscreenApp_is_fullscreen_app__app_id__get","parameters":[{"name":"app_id","in":"path","required":true,"schema":{"type":"string","minLength":6,"maxLength":255,"pattern":"^[A-Za-z_][\\w\\-\\.]+$","examples":["org.gnome.Glade"],"title":"App Id"}}],"responses":{"200":{"description":"Whether the app is a fullscreen app","content":{"application/json":{"schema":{"type":"boolean","title":"Response Get Isfullscreenapp Is Fullscreen App  App Id  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/search":{"post":{"tags":["app"],"summary":"Post Search","description":"Search for applications using Meilisearch.\n\nAccepts a search query with filters and returns matching applications\nwith facets and pagination information.","operationId":"post_search_search_post","parameters":[{"name":"locale","in":"query","required":false,"schema":{"type":"string","default":"en","title":"Locale"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SearchQuery"}}}},"responses":{"200":{"description":"Search results for apps","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MeilisearchResponse_AppsIndex_"}}}},"400":{"description":"Invalid search query"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/runtimes":{"get":{"tags":["app"],"summary":"Get Runtime List","description":"Get a list of available Flatpak runtimes with usage counts.\n\nReturns a mapping of runtime names to the number of apps using each runtime.","operationId":"get_runtime_list_runtimes_get","responses":{"200":{"description":"List of available runtimes","content":{"application/json":{"schema":{"additionalProperties":{"type":"integer"},"type":"object","title":"Response Get Runtime List Runtimes Get"}}}}}}},"/summary/{app_id}":{"get":{"tags":["app"],"summary":"Get Summary","description":"Get summary information for a specific application.\n\nReturns information about the app's size, architectures, runtime metadata,\nand flatpak-specific configuration.","operationId":"get_summary_summary__app_id__get","parameters":[{"name":"app_id","in":"path","required":true,"schema":{"type":"string","minLength":6,"maxLength":255,"pattern":"^[A-Za-z_][\\w\\-\\.]+$","examples":["org.gnome.Glade"],"title":"App Id"}},{"name":"branch","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Branch"}}],"responses":{"200":{"description":"App summary information","content":{"application/json":{"schema":{"$ref":"#/components/schemas/SummaryResponse"}}}},"404":{"description":"App not found"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/platforms":{"get":{"tags":["app"],"summary":"Get Platforms","description":"Return a mapping from org-name to platform aliases and dependencies which are\nrecognised by the backend.  These are used by things such as the transactions\nand donations APIs to address amounts to the platforms.","operationId":"get_platforms_platforms_get","responses":{"200":{"description":"Available platforms information","content":{"application/json":{"schema":{"additionalProperties":{"$ref":"#/components/schemas/Platform"},"type":"object","title":"Response Get Platforms Platforms Get"}}}}}}},"/addon/{app_id}":{"get":{"tags":["app"],"summary":"Get Addons","description":"Get a list of addon IDs that are compatible with the specified application.\n\nAddons extend the functionality of base applications (e.g., codecs, themes).","operationId":"get_addons_addon__app_id__get","parameters":[{"name":"app_id","in":"path","required":true,"schema":{"type":"string","title":"App Id"}}],"responses":{"200":{"description":"List of addons for the app","content":{"application/json":{"schema":{"type":"array","items":{"type":"string"},"title":"Response Get Addons Addon  App Id  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/update":{"post":{"tags":["update"],"summary":"Update","operationId":"update_update_post","responses":{"200":{"description":"Update completed successfully","content":{"application/json":{"schema":{}}}},"500":{"description":"Internal server error"}}}},"/update/stats":{"post":{"tags":["update"],"summary":"Update Stats","operationId":"update_stats_update_stats_post","responses":{"200":{"description":"Stats updated successfully","content":{"application/json":{"schema":{}}}},"500":{"description":"Internal server error"}}}},"/update/process-pending-transfers":{"post":{"tags":["update"],"summary":"Process Transfers","description":"Process any pending transfers which may be in the system","operationId":"process_transfers_update_process_pending_transfers_post","responses":{"200":{"description":"Pending transfers processed successfully","content":{"application/json":{"schema":{}}}},"500":{"description":"Internal server error"}}}},"/update/app-picks":{"post":{"tags":["update"],"summary":"Update App Picks","operationId":"update_app_picks_update_app_picks_post","responses":{"200":{"description":"App picks updated successfully","content":{"application/json":{"schema":{}}}},"500":{"description":"Internal server error"}}}},"/emails/build-notification":{"post":{"tags":["email"],"summary":"Build Notification","operationId":"build_notification_emails_build_notification_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/BuildNotificationRequest"}}},"required":true},"responses":{"200":{"description":"Build notification sent successfully","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation error"},"500":{"description":"Internal server error"}},"security":[{"HTTPBearer":[]}]}},"/auth/login":{"get":{"tags":["auth"],"summary":"Get Login Methods","description":"Retrieve the login methods available from the backend.\n\nFor each method returned, flow starts with a `GET` to the endpoint\n`.../login/{method}` and upon completion from the user-agent, with a `POST`\nto that same endpoint name.\n\nEach method is also given a button icon and some text to use, though\nfrontends with localisation may choose to render other text instead.","operationId":"get_login_methods_auth_login_get","responses":{"200":{"description":"Available login methods","content":{"application/json":{"schema":{"items":{"$ref":"#/components/schemas/LoginMethod"},"type":"array","title":"Response Get Login Methods Auth Login Get"}}}}}}},"/auth/login/github":{"get":{"tags":["auth"],"summary":"Start Github Flow","description":"Starts a github login flow.  This will set session cookie values and\nwill return a redirect.  The frontend is expected to save the cookie\nfor use later, and follow the redirect to Github\n\nUpon return from Github to the frontend, the frontend should POST to this\nendpoint with the relevant data from Github\n\nIf the user is already logged in, and has a valid github token stored,\nthen this will return an error instead.","operationId":"start_github_flow_auth_login_github_get","responses":{"200":{"description":"OAuth flow started successfully","content":{"application/json":{"schema":{}}}},"400":{"description":"User already logged in with GitHub"}}},"post":{"tags":["auth"],"summary":"Continue Github Flow","description":"Process the result of the Github oauth flow\n\nThis expects to have some JSON posted to it which (on success) contains:\n\n```\n{\n    \"state\": \"the state code\",\n    \"code\": \"the github oauth code\",\n}\n```\n\nOn failure, the frontend should pass through the state and error so that\nthe backend can clear the stored flow state\n\n```\n{\n    \"state\": \"the state code\",\n    \"error\": \"the error code returned from github\",\n}\n```\n\nThis endpoint will either return an error, if something was wrong in the\nbackend state machines; or it will return a success code with an indication\nof whether or not the login sequence completed OK.","operationId":"continue_github_flow_auth_login_github_post","requestBody":{"content":{"application/json":{"schema":{"anyOf":[{"$ref":"#/components/schemas/OauthLoginResponseSuccess"},{"$ref":"#/components/schemas/OauthLoginResponseFailure"}],"title":"Data"}}},"required":true},"responses":{"200":{"description":"Login flow completed successfully","content":{"application/json":{"schema":{}}}},"400":{"description":"Invalid flow state or token expired"},"500":{"description":"OAuth provider error or login failure"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/auth/login/gitlab":{"get":{"tags":["auth"],"summary":"Start Gitlab Flow","description":"Starts a gitlab login flow.  This will set session cookie values and\nwill return a redirect.  The frontend is expected to save the cookie\nfor use later, and follow the redirect to Gitlab\n\nUpon return from Gitlab to the frontend, the frontend should POST to this\nendpoint with the relevant data from Gitlab\n\nIf the user is already logged in, and has a valid gitlab token stored,\nthen this will return an error instead.","operationId":"start_gitlab_flow_auth_login_gitlab_get","responses":{"200":{"description":"OAuth flow started successfully","content":{"application/json":{"schema":{}}}},"400":{"description":"User already logged in with GitLab"}}},"post":{"tags":["auth"],"summary":"Continue Gitlab Flow","description":"Process the result of the Gitlab oauth flow\n\nThis expects to have some JSON posted to it which (on success) contains:\n\n```\n{\n    \"state\": \"the state code\",\n    \"code\": \"the gitlab oauth code\",\n}\n```\n\nOn failure, the frontend should pass through the state and error so that\nthe backend can clear the stored flow state\n\n```\n{\n    \"state\": \"the state code\",\n    \"error\": \"the error code returned from gitlab\",\n}\n```\n\nThis endpoint will either return an error, if something was wrong in the\nbackend state machines; or it will return a success code with an indication\nof whether or not the login sequence completed OK.","operationId":"continue_gitlab_flow_auth_login_gitlab_post","requestBody":{"content":{"application/json":{"schema":{"anyOf":[{"$ref":"#/components/schemas/OauthLoginResponseSuccess"},{"$ref":"#/components/schemas/OauthLoginResponseFailure"}],"title":"Data"}}},"required":true},"responses":{"200":{"description":"Login flow completed successfully","content":{"application/json":{"schema":{}}}},"400":{"description":"Invalid flow state or token expired"},"500":{"description":"OAuth provider error or login failure"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/auth/login/gnome":{"get":{"tags":["auth"],"summary":"Start Gnome Flow","description":"Starts a GNOME login flow.  This will set session cookie values and\nwill return a redirect.  The frontend is expected to save the cookie\nfor use later, and follow the redirect to GNOME Gitlab\n\nUpon return from GNOME to the frontend, the frontend should POST to this\nendpoint with the relevant data from GNOME Gitlab\n\nIf the user is already logged in, and has a valid GNOME Gitlab token stored,\nthen this will return an error instead.","operationId":"start_gnome_flow_auth_login_gnome_get","responses":{"200":{"description":"OAuth flow started successfully","content":{"application/json":{"schema":{}}}},"400":{"description":"User already logged in with GNOME GitLab"}}},"post":{"tags":["auth"],"summary":"Continue Gnome Flow","description":"Process the result of the GNOME oauth flow\n\nThis expects to have some JSON posted to it which (on success) contains:\n\n```\n{\n    \"state\": \"the state code\",\n    \"code\": \"the gitlab oauth code\",\n}\n```\n\nOn failure, the frontend should pass through the state and error so that\nthe backend can clear the stored flow state\n\n```\n{\n    \"state\": \"the state code\",\n    \"error\": \"the error code returned from GNOME gitlab\",\n}\n```\n\nThis endpoint will either return an error, if something was wrong in the\nbackend state machines; or it will return a success code with an indication\nof whether or not the login sequence completed OK.","operationId":"continue_gnome_flow_auth_login_gnome_post","requestBody":{"content":{"application/json":{"schema":{"anyOf":[{"$ref":"#/components/schemas/OauthLoginResponseSuccess"},{"$ref":"#/components/schemas/OauthLoginResponseFailure"}],"title":"Data"}}},"required":true},"responses":{"200":{"description":"Login flow completed successfully","content":{"application/json":{"schema":{}}}},"400":{"description":"Invalid flow state or token expired"},"500":{"description":"OAuth provider error or login failure"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/auth/login/kde":{"get":{"tags":["auth"],"summary":"Start Kde Flow","operationId":"start_kde_flow_auth_login_kde_get","responses":{"200":{"description":"OAuth flow started successfully","content":{"application/json":{"schema":{}}}},"400":{"description":"User already logged in with KDE GitLab"}}},"post":{"tags":["auth"],"summary":"Continue Kde Flow","operationId":"continue_kde_flow_auth_login_kde_post","requestBody":{"content":{"application/json":{"schema":{"anyOf":[{"$ref":"#/components/schemas/OauthLoginResponseSuccess"},{"$ref":"#/components/schemas/OauthLoginResponseFailure"}],"title":"Data"}}},"required":true},"responses":{"200":{"description":"Login flow completed successfully","content":{"application/json":{"schema":{}}}},"400":{"description":"Invalid flow state or token expired"},"500":{"description":"OAuth provider error or login failure"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/auth/login/google":{"post":{"tags":["auth"],"summary":"Continue Google Flow","description":"Process the result of the Google oauth flow\n\nThis expects to have some JSON posted to it which (on success) contains:\n\n```\n{\n    \"state\": \"the state code\",\n    \"code\": \"the google oauth code\",\n}\n```\n\nOn failure, the frontend should pass through the state and error so that\nthe backend can clear the stored flow state\n\n```\n{\n    \"state\": \"the state code\",\n    \"error\": \"the error code returned from google\",\n}\n```\n\nThis endpoint will either return an error, if something was wrong in the\nbackend state machines; or it will return a success code with an indication\nof whether or not the login sequence completed OK.","operationId":"continue_google_flow_auth_login_google_post","requestBody":{"content":{"application/json":{"schema":{"anyOf":[{"$ref":"#/components/schemas/OauthLoginResponseSuccess"},{"$ref":"#/components/schemas/OauthLoginResponseFailure"}],"title":"Data"}}},"required":true},"responses":{"200":{"description":"Login flow completed successfully","content":{"application/json":{"schema":{}}}},"400":{"description":"Invalid flow state or token expired"},"500":{"description":"OAuth provider error or login failure"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/auth/userinfo":{"get":{"tags":["auth"],"summary":"Get Userinfo","description":"Retrieve the current login's user information.  If the user is not logged in\nyou will get a `204` return.  Otherwise you will receive JSON describing the\ncurrently logged in user, for example:\n\n```\n{\n    \"displayname\": \"Mx Human Person\",\n    \"dev_flatpaks\": [ \"org.people.human.Appname\" ],\n    \"owned_flatpaks\": [ \"org.foo.bar.Appname\" ],\n    \"accepted_publisher-agreement_at\": \"2023-06-23T20:38:28.553028\"\n}\n```\n\nIf the user has an active github login, you'll also get their github login\nname, and avatar.  If they have some other login, details for that login\nwill be provided.\n\ndev_flatpaks is filtered against IDs available in AppStream","operationId":"get_userinfo_auth_userinfo_get","responses":{"200":{"description":"User information retrieved successfully","content":{"application/json":{"schema":{"anyOf":[{"$ref":"#/components/schemas/UserInfo"},{"type":"null"}],"title":"Response Get Userinfo Auth Userinfo Get"}}}},"204":{"description":"Not logged in"}}}},"/auth/refresh-dev-flatpaks":{"post":{"tags":["auth"],"summary":"Do Refresh Dev Flatpaks","operationId":"do_refresh_dev_flatpaks_auth_refresh_dev_flatpaks_post","responses":{"200":{"description":"Dev flatpaks refreshed successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/RefreshDevFlatpaksReturn"}}}},"401":{"description":"No GitHub account linked"}}}},"/auth/logout":{"post":{"tags":["auth"],"summary":"Do Logout","description":"Clear the login state. This will discard tokens which access socials,\nand will clear the session cookie so that the user is not logged in.","operationId":"do_logout_auth_logout_post","responses":{"200":{"description":"Logout successful","content":{"application/json":{"schema":{}}}},"500":{"description":"Session error"}}}},"/auth/deleteuser":{"get":{"tags":["auth"],"summary":"Get Deleteuser","description":"Delete a user's login information.\nIf they're not logged in, they'll get a `403` return.\nOtherwise they will get an option to delete their account\nand data.","operationId":"get_deleteuser_auth_deleteuser_get","responses":{"200":{"description":"Delete user token generated","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GetDeleteUserResult"}}}},"403":{"description":"Not logged in"}}},"delete":{"tags":["auth"],"summary":"Do Deleteuser","description":"Clear the login state. This will then delete the user's account\nand associated data. Unless there is an error.\n\nThe input to this should be of the form:\n\n```json\n{\n    \"token\": \"...\",\n}\n```","operationId":"do_deleteuser_auth_deleteuser_delete","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UserDeleteRequest"}}},"required":true},"responses":{"200":{"description":"User deleted successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeleteUserResult"}}}},"400":{"description":"Invalid token or deletion failed"},"403":{"description":"Not logged in"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/auth/accept-publisher-agreement":{"post":{"tags":["auth"],"summary":"Do Agree To Publisher Agreement","operationId":"do_agree_to_publisher_agreement_auth_accept_publisher_agreement_post","responses":{"200":{"description":"Publisher agreement accepted","content":{"application/json":{"schema":{}}}},"403":{"description":"Not logged in"}}}},"/auth/change-default-account":{"post":{"tags":["auth"],"summary":"Do Change Default Account","description":"Changes the user's default account, which determines which display name and email we use.","operationId":"do_change_default_account_auth_change_default_account_post","parameters":[{"name":"provider","in":"query","required":true,"schema":{"$ref":"#/components/schemas/ConnectedAccountProvider"}}],"responses":{"204":{"description":"Default account changed successfully"},"403":{"description":"Not logged in"},"404":{"description":"Account not found"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/moderation/apps":{"get":{"tags":["moderation"],"summary":"Get Moderation Apps","description":"Get a list of apps with unhandled moderation requests.","operationId":"get_moderation_apps_moderation_apps_get","parameters":[{"name":"new_submissions","in":"query","required":false,"schema":{"anyOf":[{"type":"boolean"},{"type":"null"}],"title":"New Submissions"}},{"name":"show_handled","in":"query","required":false,"schema":{"type":"boolean","default":false,"title":"Show Handled"}},{"name":"limit","in":"query","required":false,"schema":{"type":"integer","default":100,"title":"Limit"}},{"name":"offset","in":"query","required":false,"schema":{"type":"integer","default":0,"title":"Offset"}}],"responses":{"200":{"description":"List of apps with moderation requests","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Mo