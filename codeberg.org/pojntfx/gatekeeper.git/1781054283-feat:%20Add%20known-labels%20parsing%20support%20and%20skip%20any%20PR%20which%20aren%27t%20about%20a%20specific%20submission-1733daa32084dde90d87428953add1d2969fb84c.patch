-		for _, label := range pr.Labels {
+		checklist, err := parseChecklistFromMarkdown([]byte(pr.GetBody()))
+		if err != nil {
+			return pullRequests, err
+		}
+
+		var labels []string
+		for _, label := range pr.GetLabels() {
 			labels = append(labels, label.GetName())
 		}
 
-		checklist, err := parseChecklistFromMarkdown([]byte(pr.GetBody()))
-		if err != nil {
-			return pullRequests, err
+		knownLabels, skip := parseKnownLabelsFromLabels(labels)
+		if skip {
+			continue
 		}
 
 		pullRequests = append(pullRequests, PullRequest{
-			URL:       pr.GetHTMLURL(),
-			Title:     pr.GetTitle(),
-			Labels:    labels,
-			Checklist: checklist,
+			URL:         pr.GetHTMLURL(),
+			Title:       pr.GetTitle(),
+			Checklist:   checklist,
+			KnownLabels: knownLabels,
 		})
 	}
 
@@ -182,21 +249,26 @@ 	}
 
 	var pullRequests []PullRequest
 	for _, pr := range rawPullRequests {
-		labels := []string{}
+		checklist, err := parseChecklistFromMarkdown([]byte(pr.Body))
+		if err != nil {
+			return pullRequests, err
+		}
+
+		var labels []string
 		for _, label := range pr.Labels {
 			labels = append(labels, label.Name)
 		}
 
-		checklist, err := parseChecklistFromMarkdown([]byte(pr.Body))
-		if err != nil {
-			return pullRequests, err
+		knownLabels, skip := parseKnownLabelsFromLabels(labels)
+		if skip {
+			continue
 		}
 
 		pullRequests = append(pullRequests, PullRequest{
-			URL:       pr.URL,
-			Title:     pr.Title,
-			Labels:    labels,
-			Checklist: checklist,
+			URL:         pr.URL,
+			Title:       pr.Title,
+			Checklist:   checklist,
+			KnownLabels: knownLabels,
 		})
 	}
 

