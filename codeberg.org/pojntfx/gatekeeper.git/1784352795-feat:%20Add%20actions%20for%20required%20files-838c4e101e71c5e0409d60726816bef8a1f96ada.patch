From 838c4e101e71c5e0409d60726816bef8a1f96ada Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Fri, 17 Jul 2026 22:33:15 -0700
Subject: [PATCH] feat: Add actions for required files

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/guidelines.yaml b/guidelines.yaml
index 4c7086973113c8ed238690369c64a9dc1cdd02df..a1b02c92b3d12047fb66282869904f7cf6658de3 100644
--- a/guidelines.yaml
+++ b/guidelines.yaml
@@ -678,9 +678,15 @@       items:
         - name: No application source code is included in the submission.
           description: null
           items: null
+          actions:
+            - SHOW_MODULES # To see which modules this app depends on and how it's built
+            - SHOW_SUBMISSION_REPO_SOURCE # To manually sweep the _submission_ repo (not main module) for any source code that's app source code, which should be in the app repo itself
         - name: No build artifacts (including dependency binaries) are included in the submission.
           description: null
           items: null
+          actions:
+            - SHOW_MODULES # To see which modules this app depends on and how it's built
+            - SHOW_MODULES_REPO_SOURCE_BLOBS # To manually sweep the _depdency_ repos for blobs of any kind and flag them (same as we do for the application and submission repo)
         - name: Manifest
           description: |
             The application manifest must be at the top level and named after the application ID with the extension .json, .yml or .yaml depending on whether it is a JSON or YAML file.
@@ -688,9 +694,18 @@
             The runtime(s) used in the manifest must be hosted on Flathub and must be the latest version at that time of submission.
           items:
             - name: The application manifest is at the top level of the submission.
+              actions:
+                - SHOW_MANIFEST_PATH # To check if it's top-level; we already extract this somewhere in order to show the manifest in the first place and can probably re-use that logic
             - name: The manifest is named after the application ID, with extension .json, .yml, or .yaml as appropriate.
+              actions:
+                - SHOW_APP_ID # To get the FQDN
+                - SHOW_MANIFEST_PATH # To check if it's top-level; we already extract this somewhere in order to show the manifest in the first place and can probably re-use that logic
             - name: The runtime(s) used in the manifest are hosted on Flathub.
+              actions:
+                - SHOW_RUNTIME # To check the runtime and it's version; it should always be hosted on Flathub here since there is no way to install different remotes here
             - name: The runtime(s) used in the manifest are the latest version at the time of submission.
+              actions:
+                - SHOW_RUNTIME # To check if the runtime is the latest version, not just whether it's EOL
         - name: Flatpak builder Manifest Style Guide
           description: |
             The style guide ensures manifests are readable, maintainable and has a logical meaning and flow.
@@ -704,21 +719,33 @@                     'Manifest is valid JSON per RFC 7159 (non-standard features such as comments use "//": or "x-comment": keys,
                     or YAML manifests are used instead).'
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: Indentation is 4 tabs with LF line endings.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: Encoding is UTF-8.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: File has a trailing newline.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: Double quotes are used for all keys and string values.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: No trailing commas are used.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
             - name: YAML manifest style
               description: |
                 Style rules for YAML manifests.
@@ -726,30 +753,48 @@               items:
                 - name: Manifest is valid YAML.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: Indentation is 2 spaces with LF line endings.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: Encoding is UTF-8.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: File has a trailing newline.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: Child elements are always indented.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: Blank lines are inserted between modules.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: Values are not vertically aligned.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: List items are indented consistently.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
                 - name: Strings remain unquoted unless quoting is required.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter should already catch this, but double-check
             - name: Logical ordering of keys
               description: |
                 Manifest properties must be ordered logically and not alphabetically. Expected order at the top level: id/app-id, runtime, runtime-version, sdk, branch/default-branch, build-runtime/build-extension, separate-locales, appstream-compose, command, base, base-version, base-extensions, inherit-extensions, sdk-extensions, inherit-sdk-extensions, platform-extensions, add-extensions, add-build-extensions, rename-desktop-file, rename-appdata-file, rename-mime-file, rename-mime-icons, rename-icon, copy-icon, finish-args, cleanup, cleanup-commands, build-options, modules. Within a module: name, buildsystem, build-options, make-args, make-install-args, rm-configure, no-autogen, no-parallel-make, subdir, builddir, run-tests, license-files, only-arches/skip-arches, config-opts/build-commands, post-install, cleanup, sources. Within a source: type, url/path/paths/commands/contents, mirror-urls, disable-http-decompression, archive-type, sha/commit/tag/(tag then commit), size, dest/dest-filename/filename, strip-components/disable-submodules/disable-lfs/disable-shallow-clone, only-arches/skip-arches, x-checker-data.
@@ -757,12 +802,18 @@               items:
                 - name: Top-level manifest properties are ordered logically (not alphabetically) per the documented order.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter doesn't catch this IIRC; see parent item's description for ordering
                 - name: Module properties are ordered logically (not alphabetically) per the documented order.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter doesn't catch this IIRC; see parent item's description for ordering
                 - name: Source properties are ordered logically (not alphabetically) per the documented order.
                   description: null
                   items: null
+                  actions:
+                    - SHOW_MANIFEST # The linter doesn't catch this IIRC; see parent item's description for ordering
         - name: Creating submanifests
           description: |
             Sub-manifests with sources must only be created when they are generated using an external tooling or in an automatic manner, otherwise, everything must be in the main manifest.
@@ -770,6 +821,9 @@           items:
             - name:
                 Sub-manifests with sources only exist where they are generated by external tooling or in an automatic manner;
                 otherwise everything is in the main manifest.
+              actions:
+                - SHOW_MANIFEST # To manually check what the main manifest references
+                - SHOW_SUBMISSION_REPO_SOURCE # To manually sweep the _submission_ repo (not main module) for any sub-manifests
         - name: flathub.json
           description: |
             Flathub builds on both x86_64 and aarch64 by default. If the application is supported on only one architecture, please include a flathub.json file in the submission pull request with the proper contents.
@@ -777,7 +831,12 @@           items:
             - name:
                 If the application supports only one of x86_64 or aarch64, a flathub.json file with the proper contents is included
                 in the submission.
+              actions:
+                - SHOW_CICD_STATUS # To check whether the build passed and for which architectures
+                - SHOW_FLATHUB_JSON # To check whether there is a flathub.json file and whether it allowlists the right, supported architectures
             - name: The flathub.json file resides in the top-level root, next to the Flatpak manifest.
+              actions:
+                - SHOW_FLATHUB_JSON_PATH # To verify that the file is in the top-level root
         - name: Dependency manifest
           description: |
             There is no network access during the build process so all dependencies used by the application must be supplied in the specified in the manifest as sources with publicly accessible URLs so that they can be downloaded before the build starts.
@@ -785,7 +844,13 @@
             There is a community provided set of tools that can be used to generate dependency manifests for npm, yarn, cargo, pip etc.
           items:
             - name: All dependencies are supplied in the manifest as sources with publicly accessible URLs.
+              actions:
+                - SHOW_SUBMISSION_REPO_SOURCE # To manually sweep the _submission_ repo (not main module) for dependency source files (see e.g. https://github.com/nstbayless/flathub/blob/crankboy-manager-submission/python3-requirements-flatpak.json)
+                - SHOW_MODULES # To list any sources directly listed in the Flatpak manifest
             - name: Generated dependency manifests (for npm, yarn, cargo, pip, etc.) are included in the submission.
+              actions:
+                - SHOW_SUBMISSION_REPO_SOURCE # To manually sweep the _submission_ repo (not main module) for dependency source files (see e.g. https://github.com/nstbayless/flathub/blob/crankboy-manager-submission/python3-requirements-flatpak.json)
+                - SHOW_MODULES # To list any sources directly listed in the Flatpak manifest
     - name: Required metadata
       description: |
         Applications must provide the following metadata typically as part of their source code.

