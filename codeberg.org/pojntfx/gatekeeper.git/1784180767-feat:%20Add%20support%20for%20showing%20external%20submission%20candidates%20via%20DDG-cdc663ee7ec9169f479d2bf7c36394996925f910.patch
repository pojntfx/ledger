diff --git a/guidelines.yaml b/guidelines.yaml
index 3d61bae6524034519df2dcbaced666a77b9cc39c..15eafd511fbe947aa761a4c966e9b7e9012a7abb 100644
--- a/guidelines.yaml
+++ b/guidelines.yaml
@@ -54,7 +54,7 @@             - name:
                 Submission does not conflict with an existing Flatpak provided by the upstream author or developers outside
                 of Flathub.
               actions:
-                - SHOW_POTENTIAL_DUPLICATE_SUBMISSIONS
+                - SHOW_SIMILAR_EXTERNAL_SUBMISSIONS
             - name:
                 Submission is not Windows software using Wine, nor any other software that is not native to the Linux desktop
                 and uses an emulation or translation layer — unless submitted officially by upstream with intent to maintain it
diff --git a/internal/config/guideline.go b/internal/config/guideline.go
index 408f5954d62dfa44bd0af8140b7384cee6c6be4b..8b52d03df8ec53184477b11da48ac8d83bf78207 100644
--- a/internal/config/guideline.go
+++ b/internal/config/guideline.go
@@ -15,7 +15,8 @@ 	ActionShowExtensions = "SHOW_EXTENSIONS"
 	ActionShowBaseApp    = "SHOW_BASEAPP"
 	ActionShowFinishArgs = "SHOW_FINISH_ARGS"
 
-	ActionShowSimilarFlathubSubmissions = "SHOW_SIMILAR_FLATHUB_SUBMISSIONS"
+	ActionShowSimilarFlathubSubmissions  = "SHOW_SIMILAR_FLATHUB_SUBMISSIONS"
+	ActionShowSimilarExternalSubmissions = "SHOW_SIMILAR_EXTERNAL_SUBMISSIONS"
 )
 
