From cdc663ee7ec9169f479d2bf7c36394996925f910 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 15 Jul 2026 22:46:07 -0700
Subject: [PATCH] feat: Add support for showing external submission candidates via DDG

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/cmd/gatekeeper-suggest-actions/main.go b/cmd/gatekeeper-suggest-actions/main.go
index 141bf37b367bdc01bd84ea0ae45e0cebdaafb8b5..4010b197039afbdd801886c18e91379112d8c6df 100644
--- a/cmd/gatekeeper-suggest-actions/main.go
+++ b/cmd/gatekeeper-suggest-actions/main.go
@@ -7,6 +7,7 @@ 	"errors"
 	"flag"
 	"fmt"
 	"net/http"
+	"net/url"
 	"os"
 	"strconv"
 	"strings"
@@ -15,6 +16,7 @@ 	v2 "codeberg.org/pojntfx/gatekeeper/internal/api/openapi/flathub/v2"
 	"codeberg.org/pojntfx/gatekeeper/internal/config"
 	"github.com/goccy/go-yaml"
 	"github.com/jeandeaual/go-locale"
+	"github.com/rymdport/portal/openuri"
 )
 
 type guidelineLeaf struct {
@@ -173,6 +175,16 @@ 				panic(errors.New(res.Status()))
 			}
 
 			if err := encoder.Encode(res.JSON200); err != nil {
+				panic(err)
+			}
+
+		case config.ActionShowSimilarExternalSubmissions:
+			u, err := url.Parse(fmt.Sprintf("https://duckduckgo.com/?q=%v+Flatpak+repo", manifest.AppID))
+			if err != nil {
+				panic(err)
+			}
+
+			if err := openuri.OpenURI("", u.String(), &openuri.Options{}); err != nil {
 				panic(err)
 			}
 
