From 3530d61898db4be8e8763ee895ab94bc36bb1668 Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Tue, 17 Mar 2026 23:55:28 -0700
Subject: [PATCH] feat: Add initial CMP port from pilot-link

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/pkg/cmp/constants.go b/pkg/cmp/constants.go
new file mode 100644
index 0000000000000000000000000000000000000000..11d678e09a777f6787033a0ac4949fb9706050cb
--- /dev/null
+++ b/pkg/cmp/constants.go
@@ -0,0 +1,14 @@
+package cmp
+
+const (
+	XID         = 0xFF
+	InitialBaud = 9600
+
+	typeWakeup   = 1
+	typeInit     = 2
+	versionMajor = 1
+	versionMinor = 2
+
+	flagChangeBaud      = 0x80
+	flagLongPacketSupport = 0x10
+)
diff --git a/pkg/cmp/exec.go b/pkg/cmp/exec.go
new file mode 100644
index 0000000000000000000000000000000000000000..0bb20711c3c06be351ae83863ae9af1f038b2098
--- /dev/null
+++ b/pkg/cmp/exec.go
@@ -0,0 +1,41 @@
+package cmp
+
+// pilot-link: libpisock/cmp.c cmp_rx_handshake + cmp_init
+
+import (
+	"encoding/binary"
+	"time"
+
+	"go.bug.st/serial"
+
+	"codeberg.org/pojntfx/runway/pkg/padp"
+)
+
+func Handshake(port serial.Port) int {
+	wakeup := padp.Recv(port)
+	if len(wakeup) < 10 || wakeup[0] != typeWakeup {
+		panic("expected CMP WAKEUP")
+	}
+
+	baud := int(binary.BigEndian.Uint32(wakeup[6:10]))
+
+	init := make([]byte, 10)
+	init[0] = typeInit
+
+	if baud != InitialBaud {
+		init[1] = flagChangeBaud
+		binary.BigEndian.PutUint32(init[6:10], uint32(baud))
+	} else {
+		init[1] = flagLongPacketSupport
+	}
+
+	init[2], init[3] = versionMajor, versionMinor
+	padp.Send(port, XID, init)
+
+	if baud != InitialBaud {
+		time.Sleep(100 * time.Millisecond)
+		port.SetMode(&serial.Mode{BaudRate: baud, DataBits: 8, Parity: serial.NoParity, StopBits: serial.OneStopBit})
+	}
+
+	return baud
+}

