index 0000000000000000000000000000000000000000..66c356a2b93983683506d42a3a5e48a9e75b89eb
--- /dev/null
+++ b/internal/gir/types/imports.go
@@ -0,0 +1,144 @@
+package types
+
+import (
+	"sort"
+	"strings"
+)
+
+// ImportConfig holds module paths and a PackageImports map (namespace name -> Go import path).
+type ImportConfig struct {
+	// ModuleBase is the Go module path (e.g. "codeberg.org/puregotk/puregotk")
+	ModuleBase string
+
+	// PathPrefix is the sub-directory within ModuleBase where packages live (e.g. "v4")
+	PathPrefix string
+
+	// PuregoModule is the module path for purego (e.g. "codeberg.org/puregotk/purego")
+	PuregoModule string
+
+	// CoreModule overrides ModuleBase when resolving pkg/core.
+	// When generating a third-party library that depends on puregotk,
+	// CoreModule should point to puregotk's module so pkg/core resolves correctly.
+	CoreModule string
+
+	// PackageImports maps lowercased namespace names to their Go import paths.
+	PackageImports map[string]string
+}
+
+// AddPackages bulk-registers namespaces from an external dependency.
+// For each namespace name, it registers module/prefix/lowercased-name as the import path.
+func (c *ImportConfig) AddPackages(module string, prefix string, namespaces []string) {
+	if c.PackageImports == nil {
+		c.PackageImports = make(map[string]string)
+	}
+	for _, ns := range namespaces {
+		pkg := strings.ToLower(ns)
+		c.PackageImports[pkg] = module + "/" + prefix + "/" + pkg
+	}
+}
+
+// ImportSet is a per-file import accumulator.
+type ImportSet struct {
+	pkgName string
+	config  *ImportConfig
+	imports map[string]bool
+}
+
+// NewImportSet creates a new import accumulator for the given package.
+func NewImportSet(pkgName string, config *ImportConfig) *ImportSet {
+	return &ImportSet{
+		pkgName: pkgName,
+		config:  config,
+		imports: make(map[string]bool),
+	}
+}
+
+// AddPkg looks up the package in PackageImports and adds the import.
+func (s *ImportSet) AddPkg(pkg string) {
+	pkg = strings.ToLower(pkg)
+	if pkg == s.pkgName {
+		return
+	}
+	if imp, ok := s.config.PackageImports[pkg]; ok {
+		s.imports[imp] = true
+	}
+}
+
+// AddCore adds the import for pkg/core.
+func (s *ImportSet) AddCore() {
+	module := s.config.CoreModule
+	if module == "" {
+		module = s.config.ModuleBase
+	}
+	s.imports[module+"/pkg/core"] = true
+}
+
+// AddPurego adds the purego import.
+func (s *ImportSet) AddPurego() {
+	s.imports[s.config.PuregoModule] = true
+}
+
+// AddUnsafe adds the "unsafe" import.
+func (s *ImportSet) AddUnsafe() {
+	s.imports["unsafe"] = true
+}
+
+// AddStructs adds the "structs" import.
+func (s *ImportSet) AddStructs() {
+	s.imports["structs"] = true
+}
+
+// AddTypes looks up gobject in PackageImports and appends /types.
+func (s *ImportSet) AddTypes() {
+	if imp, ok := s.config.PackageImports["gobject"]; ok {
+		s.imports[imp+"/types"] = true
+	}
+}
+
+// TrackGoType scans a Go type string for pkg. prefixes and calls AddPkg for each match.
+func (s *ImportSet) TrackGoType(goType string) {
+	// Look for patterns like "pkg.Something" in the type string
+	parts := strings.Split(goType, ".")
+	if len(parts) < 2 {
+		return
+	}
+	// The package name is everything before the first dot, stripped of pointer/slice/array prefixes
+	pkg := strings.TrimLeftFunc(parts[0], func(r rune) bool {
+		return r == '*' || r == '[' || r == ']' || (r >= '0' && r <= '9')
+	})
+	if pkg == "" {
+		return
+	}
+	// Special case: types.GType comes from gobject/types, not a namespace
+	if pkg == "types" {
+		s.AddTypes()
+		return
+	}
+	s.AddPkg(pkg)
+}
+
+// Sorted returns imports grouped: stdlib first, blank line separator, then third-party.
+func (s *ImportSet) Sorted() []string {
+	if len(s.imports) == 0 {
+		return nil
+	}
+
+	var stdlib, thirdparty []string
+	for imp := range s.imports {
+		if !strings.Contains(imp, ".") {
+			stdlib = append(stdlib, imp)
+		} else {
+			thirdparty = append(thirdparty, imp)
+		}
+	}
+	sort.Strings(stdlib)
+	sort.Strings(thirdparty)
+
+	var result []string
+	result = append(result, stdlib...)
+	if len(stdlib) > 0 && len(thirdparty) > 0 {
+		result = append(result, "") // blank line separator
+	}
+	result = append(result, thirdparty...)
+	return result
+}
