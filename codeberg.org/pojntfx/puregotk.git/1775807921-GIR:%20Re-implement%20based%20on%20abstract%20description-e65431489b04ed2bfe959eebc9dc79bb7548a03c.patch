@@ -40,14 +40,27 @@ 		panic("puregotk dependency not found: " + err.Error())
 	}
 	puregotk := strings.TrimSpace(string(output))
 
+	// Extract puregotk namespace names from GIR filenames
+	var puregotkNamespaces []string
 	filepath.Walk(filepath.Join(puregotk, "internal/gir/spec"), func(path string, f os.FileInfo, err error) error {
 		if strings.HasSuffix(path, ".gir") {
 			girs = append(girs, path)
+			base := filepath.Base(path)
+			if idx := strings.Index(base, "-"); idx != -1 {
+				puregotkNamespaces = append(puregotkNamespaces, base[:idx])
+			}
 		}
 		return nil
 	})
 
-	p, err := pass.New(girs)
+	config := &pass.ImportConfig{
+		ModuleBase:   "codeberg.org/puregotk/puregotk/examples/mylib-gtk-meson-go",
+		CoreModule:   "codeberg.org/puregotk/puregotk",
+		PuregoModule: "codeberg.org/puregotk/purego",
+	}
+	config.AddPackages("codeberg.org/puregotk/puregotk", "v4", puregotkNamespaces)
+
+	p, err := pass.New(girs, config)
 	if err != nil {
 		panic(err)
 	}
@@ -66,6 +79,7 @@ 		"propsset": util.PropertyScalarSet,
 		"propsget": util.PropertyScalarGet,
 		"propvset": util.PropertyVectorSet,
 		"propvget": util.PropertyVectorGet,
+		"nl":       func() string { return "\n" },
 	}).ParseFiles(filepath.Join(puregotk, "templates/go"))
 	if err != nil {
 		panic(err)
