+		g.Go(func() error {
+			p.writeGo(r, gotemp, dir, &rawFiles, &mu)
+			return nil
+		})
+	}
+	if err := g.Wait(); err != nil {
+		panic(err)
 	}
+
+	// Format all output files in parallel
+	g2, _ := errgroup.WithContext(context.Background())
+	for _, f := range rawFiles {
+		f := f
+		g2.Go(func() error {
+			src, err := os.ReadFile(f)
+			if err != nil {
+				return err
+			}
+			formatted, err := format.Source(src)
+			if err != nil {
+				log.Printf("warning: could not format %s: %v", f, err)
+				return nil
+			}
+			formatted = removeRedundantBlanks(formatted)
+			return os.WriteFile(f, formatted, 0o644)
+		})
+	}
+	if err := g2.Wait(); err != nil {
+		panic(err)
+	}
