+
+// removeRedundantBlanks removes blank lines after opening braces and before
+// closing braces, matching gofumpt's behavior for function bodies.
+func removeRedundantBlanks(src []byte) []byte {
+	lines := bytes.Split(src, []byte("\n"))
+	var out [][]byte
+	for i, line := range lines {
+		trimmed := bytes.TrimSpace(line)
+		// Skip blank lines that follow a line ending with "{"
+		if len(trimmed) == 0 && i > 0 {
+			prevTrimmed := bytes.TrimSpace(lines[i-1])
+			if bytes.HasSuffix(prevTrimmed, []byte("{")) {
+				continue
+			}
+		}
+		// Skip blank lines that precede a line starting with "}"
+		if len(trimmed) == 0 && i+1 < len(lines) {
+			nextTrimmed := bytes.TrimSpace(lines[i+1])
+			if bytes.HasPrefix(nextTrimmed, []byte("}")) {
+				continue
+			}
+		}
+		out = append(out, line)
+	}
+	return bytes.Join(out, []byte("\n"))
 }
diff --git a/internal/gir/types/imports.go b/internal/gir/types/imports.go
