From a19946f1f13a340a856c013166390e280082fe6d Mon Sep 17 00:00:00 2001
From: Felicitas Pojtinger <felicitas@pojtinger.com>
Date: Wed, 22 Jul 2026 21:51:32 -0700
Subject: [PATCH] feat: Add basic Caddy Podman quadlet with automatic updates via Ansible

Signed-off-by: Felicitas Pojtinger <felicitas@pojtinger.com>
---
diff --git a/caddy.container b/caddy.container
new file mode 100644
index 0000000000000000000000000000000000000000..bd64ccbd8d9c09f788a21b6cda77066d2054903e
--- /dev/null
+++ b/caddy.container
@@ -0,0 +1,14 @@
+[Container]
+ContainerName=caddy
+Image=docker.io/caddy/caddy:latest
+Label=io.containers.autoupdate=registry
+PublishPort=80:80
+PublishPort=443:443
+PublishPort=443:443/udp
+Volume=caddy_data:/data
+
+[Service]
+Restart=always
+
+[Install]
+WantedBy=default.target
\ No newline at end of file
diff --git a/caddy.yaml b/caddy.yaml
new file mode 100644
index 0000000000000000000000000000000000000000..b82220d24c82bcfb6fb21fa896d33d6319d4ab8e
--- /dev/null
+++ b/caddy.yaml
@@ -0,0 +1,58 @@
+- name: Configure Caddy # See https://major.io/p/podman-quadlet-automatic-updates/
+  hosts: all
+  gather_facts: false
+  tasks:
+    - name: Install Podman
+      become: true
+      ansible.builtin.package:
+        name:
+          - podman
+          - acl # For become_user
+        state: present
+    - name: Create user for Caddy
+      become: true
+      register: caddy_user
+      ansible.builtin.user:
+        name: caddy
+    - name: Enable linger for Caddy user # See https://old.reddit.com/r/systemd/comments/suaa5x/proper_way_to_enable_lingering_ansible/
+      become: true
+      ansible.builtin.command: loginctl enable-linger caddy
+      args:
+        creates: /var/lib/systemd/linger/caddy
+    - name: Create quadlet directory for Caddy
+      become: true
+      ansible.builtin.file:
+        path: /home/caddy/.config/containers/systemd
+        state: directory
+        owner: caddy
+        group: caddy
+        mode: "0755"
+    - name: Write quadlet file for Caddy
+      become: true
+      ansible.builtin.copy:
+        src: caddy.container
+        dest: /home/caddy/.config/containers/systemd/caddy.container
+        owner: caddy
+        group: caddy
+        mode: "0644"
+    - name: Enable Caddy user service
+      become: true
+      become_user: caddy
+      ansible.builtin.systemd_service:
+        name: caddy.service
+        state: started
+        enabled: true
+        daemon_reload: true
+        scope: user
+      environment:
+        XDG_RUNTIME_DIR: "/run/user/{{ caddy_user.uid }}"
+    - name: Enable Podman auto-update user service
+      become: true
+      become_user: caddy
+      ansible.builtin.systemd_service:
+        name: podman-auto-update.timer
+        state: started
+        enabled: true
+        scope: user
+      environment:
+        XDG_RUNTIME_DIR: "/run/user/{{ caddy_user.uid }}"
