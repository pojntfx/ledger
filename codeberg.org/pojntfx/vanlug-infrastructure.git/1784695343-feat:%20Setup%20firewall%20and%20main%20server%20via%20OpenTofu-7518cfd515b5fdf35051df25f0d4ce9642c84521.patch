diff --git a/main.tofu b/main.tofu
new file mode 100644
index 0000000000000000000000000000000000000000..3db9045a15a0f8c05784373b259b8b25cd12e8b9
--- /dev/null
+++ b/main.tofu
@@ -0,0 +1,71 @@
+resource "hcloud_firewall" "vanlug_main" {
+  name = "vanlug-main"
+
+  rule {
+    direction  = "in"
+    protocol   = "tcp"
+    port       = "22"
+    source_ips = ["::/0", "0.0.0.0/0"]
+  }
+
+  # Forgejo SSH port
+  rule {
+    direction  = "in"
+    protocol   = "tcp"
+    port       = "220"
+    source_ips = ["::/0", "0.0.0.0/0"]
+  }
+
+  rule {
+    direction  = "in"
+    protocol   = "tcp"
+    port       = "80"
+    source_ips = ["::/0", "0.0.0.0/0"]
+  }
+
+  rule {
+    direction  = "in"
+    protocol   = "tcp"
+    port       = "443"
+    source_ips = ["::/0", "0.0.0.0/0"]
+  }
+
+  # HTTP/3
+  rule {
+    direction  = "in"
+    protocol   = "udp"
+    port       = "443"
+    source_ips = ["::/0", "0.0.0.0/0"]
+  }
+}
+
+resource "hcloud_ssh_key" "pojntfx" {
+  name = "pojntfx"
+
+  public_key = var.ssh_public_key
+}
+
+resource "hcloud_server" "vanlug_main" {
+  name     = "vanlug-main"
+  location = "fsn1"
+
+  image       = "alma-10"
+  server_type = "cpx22"
+
+  ssh_keys     = [hcloud_ssh_key.pojntfx.id]
+  firewall_ids = [hcloud_firewall.vanlug_main.id]
+
+  backups = true
+
+  # Data is stored on the server's volume directly; we should not destroy it
+  delete_protection  = true
+  rebuild_protection = true
+
+  lifecycle {
+    prevent_destroy = true # Data is stored on the server's volume directly; we should not destroy it
+
+    ignore_changes = [
+      ssh_keys # We can't update SSH keys without destroying the server and restarting it
+    ]
+  }
+}
diff --git a/outputs.tofu b/outputs.tofu
