index 0000000000000000000000000000000000000000..a5282948d747a42d3705f3e52e5bf04550bc3e3c
--- /dev/null
+++ b/outputs.tofu
@@ -0,0 +1,14 @@
+output "ipv6_address" {
+  description = "IPv6 address of the server"
+  value       = hcloud_server.vanlug_main.ipv6_address
+}
+
+output "ipv4_address" {
+  description = "IPv4 address of the server"
+  value       = hcloud_server.vanlug_main.ipv4_address
+}
+
+output "user" {
+  description = "User of the server"
+  value       = "root"
+}
